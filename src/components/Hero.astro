---
import { business } from '../data/business';

const shieldIcon = `<svg class="w-5 h-5 text-orange-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>`;
const starIcon = `<svg class="w-5 h-5 text-orange-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`;
const checkIcon = `<svg class="w-5 h-5 text-orange-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z"/></svg>`;

const badgeIcons = [shieldIcon, starIcon, checkIcon, shieldIcon];
---

<section
  class="relative min-h-[100svh] flex flex-col justify-center overflow-hidden"
  aria-labelledby="hero-heading"
>
  <!-- Background: navy + dot-grid texture + orange radial glow -->
  <div class="absolute inset-0 hero-bg" aria-hidden="true"></div>

  <!-- Orange accent stripe at very top -->
  <div class="absolute top-0 left-0 right-0 h-1 bg-orange-500" aria-hidden="true"></div>

  <!-- Decorative large text watermark -->
  <div
    class="absolute right-0 bottom-0 font-display font-black text-[20vw] leading-none text-white/[0.03] select-none pointer-events-none uppercase tracking-tighter"
    aria-hidden="true"
  >
    24/7
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 w-full pt-28 pb-24">
    <div class="max-w-3xl">
      <!-- Eyebrow badge -->
      <div class="inline-flex items-center gap-2.5 bg-orange-500/15 border border-orange-500/30 rounded-full px-4 py-1.5 mb-8">
        <span class="w-2 h-2 bg-orange-500 rounded-full animate-pulse flex-shrink-0" aria-hidden="true"></span>
        <span class="text-orange-300 text-sm font-body font-semibold">{business.hero.eyebrow}</span>
      </div>

      <!-- Main headline -->
      <h1 id="hero-heading" class="font-display font-black uppercase leading-[0.88] mb-6">
        <span class="block text-white" style="font-size: clamp(3.5rem, 9vw, 7.5rem);">
          {business.hero.headlineLine1}
        </span>
        <span class="block text-orange-500" style="font-size: clamp(3.5rem, 9vw, 7.5rem);">
          {business.hero.headlineLine2}
        </span>
      </h1>

      <p class="text-slate-300 font-body font-medium mb-10" style="font-size: clamp(1.15rem, 2.5vw, 1.5rem);">
        {business.hero.subheadline}
        <span class="block mt-1 text-slate-400 text-base">{business.hero.description}</span>
      </p>

      <!-- Phone number — THE HERO ELEMENT -->
      <a
        href={business.phoneHref}
        class="group inline-flex items-center gap-4 mb-10 -mx-1 px-1 rounded-xl hover:bg-white/5 transition-colors"
        aria-label={`Call us now at ${business.phone}`}
      >
        <div
          class="w-14 h-14 bg-orange-500 rounded-full flex items-center justify-center flex-shrink-0 shadow-[0_0_0_6px_rgba(249,115,22,0.15)] group-hover:shadow-[0_0_0_10px_rgba(249,115,22,0.2)] transition-all animate-pulse-slow"
          aria-hidden="true"
        >
          <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
          </svg>
        </div>
        <span
          class="font-display font-black text-white group-hover:text-orange-400 transition-colors leading-none"
          style="font-size: clamp(2.25rem, 6.5vw, 5rem);"
        >
          {business.phone}
        </span>
      </a>

      <!-- CTA buttons -->
      <div class="flex flex-wrap gap-4 mb-16">
        <a
          href="#quote"
          class="inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-600 text-white font-body font-bold rounded-xl transition-all hover:scale-[1.02] active:scale-100 shadow-[0_8px_32px_rgba(249,115,22,0.35)]"
          style="font-size: clamp(1rem, 1.5vw, 1.125rem); padding: 1rem 2rem;"
        >
          {business.hero.cta}
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
          </svg>
        </a>
        <a
          href="#services"
          class="inline-flex items-center gap-2 border-2 border-white/25 hover:border-orange-500/60 text-white hover:text-orange-300 font-body font-semibold rounded-xl transition-all"
          style="font-size: clamp(1rem, 1.5vw, 1.125rem); padding: 1rem 2rem;"
        >
          {business.hero.ctaSecondary}
        </a>
      </div>

      <!-- Trust badges -->
      <div class="flex flex-wrap gap-4" role="list" aria-label="Trust certifications">
        {business.badges.map((badge, i) => (
          <div
            class="flex items-center gap-2.5 bg-white/8 border border-white/12 rounded-xl px-4 py-3"
            role="listitem"
          >
            <span set:html={badgeIcons[i]} />
            <div>
              <div class="text-white font-body font-semibold text-sm leading-none">{badge.label}</div>
              <div class="text-slate-400 text-xs leading-none mt-1">{badge.sublabel}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Bottom wave divider -->
  <div class="absolute bottom-0 left-0 right-0 overflow-hidden leading-none pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="w-full h-[60px]">
      <path d="M0,60 L0,20 Q360,0 720,20 Q1080,40 1440,10 L1440,60 Z" fill="#0c1d38"/>
    </svg>
  </div>
</section>

<style>
  .hero-bg {
    background-color: #0f2855;
    background-image:
      radial-gradient(ellipse 80% 60% at 100% 0%, rgba(249,115,22,0.12) 0%, transparent 60%),
      radial-gradient(ellipse 60% 80% at 0% 100%, rgba(249,115,22,0.05) 0%, transparent 60%),
      radial-gradient(circle at 50px 50px, rgba(249,115,22,0.04) 1px, transparent 0),
      radial-gradient(circle at 50px 50px, rgba(255,255,255,0.03) 1px, transparent 0);
    background-size: 100% 100%, 100% 100%, 60px 60px, 30px 30px;
  }
</style>
