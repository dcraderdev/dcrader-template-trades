---
import { business } from '../data/business';
---

<section id="projects" class="relative bg-navy-900 py-20 lg:py-28" aria-labelledby="projects-heading">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-orange-500/30 to-transparent" aria-hidden="true"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Section header -->
    <div class="text-center mb-14">
      <span class="inline-block text-orange-500 font-body font-semibold text-sm uppercase tracking-widest mb-3">
        Our Work
      </span>
      <h2
        id="projects-heading"
        class="font-display font-black uppercase text-white mb-4"
        style="font-size: clamp(2.25rem, 5vw, 3.75rem);"
      >
        Recent Projects
      </h2>
      <p class="text-slate-400 font-body max-w-xl mx-auto text-lg">
        Real jobs. Real results. Drag the slider to see before and after.
      </p>
    </div>

    <!-- Carousel -->
    <div class="relative" aria-roledescription="carousel" aria-label="Recent projects before and after">
      <!-- Slides wrapper -->
      <div id="project-carousel" class="overflow-hidden rounded-2xl">
        <div id="project-track" class="flex transition-transform duration-500 ease-out" style="width: 300%;">
          {business.projects.map((project, i) => (
            <div
              class="w-full flex-shrink-0"
              style="width: 33.333%;"
              role="group"
              aria-roledescription="slide"
              aria-label={`Project ${i + 1} of ${business.projects.length}: ${project.title}`}
            >
              <!-- Before/After slider -->
              <div class="relative overflow-hidden rounded-2xl bg-navy-800" style="aspect-ratio: 16/9;">
                <!-- BEFORE image -->
                <img
                  src={project.beforeImg}
                  alt={`Before: ${project.title} in ${project.location}`}
                  class="absolute inset-0 w-full h-full object-cover"
                  loading="lazy"
                />

                <!-- AFTER image (clipped) -->
                <img
                  src={project.afterImg}
                  alt={`After: ${project.title} in ${project.location}`}
                  class="after-img absolute inset-0 w-full h-full object-cover"
                  style="clip-path: inset(0 50% 0 0);"
                  loading="lazy"
                />

                <!-- Range input (transparent overlay) -->
                <input
                  type="range"
                  min="0"
                  max="100"
                  value="50"
                  class="ba-slider absolute inset-0 w-full h-full opacity-0 cursor-col-resize z-10"
                  aria-label={`Before and after slider for ${project.title}`}
                />

                <!-- Divider handle -->
                <div class="ba-divider absolute top-0 bottom-0 left-1/2 w-0.5 bg-white pointer-events-none z-20 -translate-x-1/2">
                  <div class="absolute top-1/2 -translate-y-1/2 -translate-x-1/2 w-10 h-10 bg-white rounded-full shadow-xl flex items-center justify-center gap-0.5">
                    <svg class="w-4 h-4 text-navy-700" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l-3 3 3 3M16 9l3 3-3 3"/>
                    </svg>
                  </div>
                </div>

                <!-- Before/After labels -->
                <div class="absolute top-4 left-4 bg-black/60 text-white text-xs font-body font-bold px-3 py-1.5 rounded-full pointer-events-none z-20 uppercase tracking-wider" aria-hidden="true">Before</div>
                <div class="absolute top-4 right-4 bg-orange-500/90 text-white text-xs font-body font-bold px-3 py-1.5 rounded-full pointer-events-none z-20 uppercase tracking-wider" aria-hidden="true">After</div>
              </div>

              <!-- Project info -->
              <div class="pt-5 px-1">
                <h3 class="font-display font-black uppercase text-white text-2xl leading-tight">
                  {project.title}
                </h3>
                <p class="text-orange-400 font-body text-sm font-semibold mb-2">
                  <svg class="inline w-3.5 h-3.5 mr-1" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 1 1 9.9 9.9L10 18.9l-4.95-4.95a7 7 0 0 1 0-9.9ZM10 11a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" clip-rule="evenodd"/>
                  </svg>
                  {project.location}, San Diego County
                </p>
                <p class="text-slate-400 font-body text-sm">{project.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Navigation -->
      <div class="flex items-center justify-between mt-6">
        <!-- Prev/Next buttons -->
        <div class="flex gap-3">
          <button
            id="prev-btn"
            class="w-11 h-11 rounded-full bg-white/10 border border-white/20 text-white hover:bg-orange-500 hover:border-orange-500 transition-all flex items-center justify-center"
            aria-label="Previous project"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/>
            </svg>
          </button>
          <button
            id="next-btn"
            class="w-11 h-11 rounded-full bg-white/10 border border-white/20 text-white hover:bg-orange-500 hover:border-orange-500 transition-all flex items-center justify-center"
            aria-label="Next project"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
            </svg>
          </button>
        </div>

        <!-- Dot indicators -->
        <div class="flex gap-2" role="tablist" aria-label="Project slides">
          {business.projects.map((_, i) => (
            <button
              class={`dot w-2.5 h-2.5 rounded-full transition-all ${i === 0 ? 'bg-orange-500 w-6' : 'bg-white/30'}`}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-label={`Go to project ${i + 1}`}
              data-index={i}
            />
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // ── Before/After sliders ─────────────────────────────────────────────────
  document.querySelectorAll<HTMLDivElement>('.ba-slider').forEach((slider) => {
    const container = slider.closest<HTMLDivElement>('.relative');
    if (!container) return;
    const afterImg = container.querySelector<HTMLImageElement>('.after-img');
    const divider = container.querySelector<HTMLDivElement>('.ba-divider');
    if (!afterImg || !divider) return;

    slider.addEventListener('input', () => {
      const val = Number(slider.value);
      afterImg.style.clipPath = `inset(0 ${100 - val}% 0 0)`;
      divider.style.left = `${val}%`;
    });
  });

  // ── Carousel ─────────────────────────────────────────────────────────────
  const track = document.getElementById('project-track') as HTMLDivElement | null;
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const dots = document.querySelectorAll<HTMLButtonElement>('.dot');
  const total = dots.length;
  let current = 0;

  function goTo(index: number) {
    current = (index + total) % total;
    if (track) track.style.transform = `translateX(-${current * (100 / total)}%)`;
    dots.forEach((dot, i) => {
      const active = i === current;
      dot.classList.toggle('bg-orange-500', active);
      dot.classList.toggle('w-6', active);
      dot.classList.toggle('bg-white/30', !active);
      dot.setAttribute('aria-selected', active ? 'true' : 'false');
    });
  }

  prevBtn?.addEventListener('click', () => goTo(current - 1));
  nextBtn?.addEventListener('click', () => goTo(current + 1));
  dots.forEach((dot) => {
    dot.addEventListener('click', () => goTo(Number(dot.dataset.index)));
  });

  // Auto-advance every 6 seconds
  setInterval(() => goTo(current + 1), 6000);
</script>
