---
// ServiceTileGrid — used by v3: icons for each service form the hero
interface Props {
  business: any;
  accent?: string;
  surface?: string;
  ink?: string;
}
const { business, accent = '#2d5a27', surface = '#fef8f0', ink = '#2c2318' } = Astro.props;

// Pick simple SVG icons keyed by service slug fragment
const iconFor = (slug: string) => {
  const s = slug.toLowerCase();
  if (s.includes('furnace') || s.includes('heat')) return 'flame';
  if (s.includes('ac') || s.includes('cool')) return 'snow';
  if (s.includes('drain')) return 'drop';
  if (s.includes('water')) return 'wave';
  if (s.includes('pipe')) return 'pipe';
  if (s.includes('sewer')) return 'sewer';
  if (s.includes('gas')) return 'spark';
  if (s.includes('camera')) return 'camera';
  if (s.includes('toilet') || s.includes('faucet')) return 'faucet';
  if (s.includes('emergency')) return 'alert';
  if (s.includes('ev') || s.includes('charge')) return 'bolt';
  if (s.includes('panel')) return 'panel';
  if (s.includes('smart')) return 'chip';
  if (s.includes('light')) return 'bulb';
  if (s.includes('duct') || s.includes('air')) return 'wind';
  if (s.includes('tune') || s.includes('maint')) return 'gear';
  return 'tool';
};
---

<section
  class="relative"
  aria-labelledby="grid-hero-heading"
  style={`background:${surface}; color:${ink};`}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 lg:py-20">
    <div class="text-center max-w-3xl mx-auto mb-12">
      <p class="font-mono uppercase tracking-[0.3em] text-xs mb-4" style={`color:${accent};`}>
        {business.hero.eyebrow}
      </p>
      <h1
        id="grid-hero-heading"
        class="font-display font-bold leading-tight mb-5"
        style={`font-size:clamp(2.25rem,5vw,3.75rem); color:${ink};`}
      >
        {business.hero.headlineLine1}
        <span class="block italic" style={`color:${accent};`}>{business.hero.headlineLine2}</span>
      </h1>
      <p class="text-lg opacity-80 mb-7">{business.hero.description}</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a
          href="#quote"
          class="inline-flex items-center gap-2 px-6 py-3 font-semibold rounded-full text-white shadow-md hover:shadow-lg transition"
          style={`background:${accent};`}
        >
          {business.hero.cta}
        </a>
        <a
          href={business.phoneHref}
          class="inline-flex items-center gap-2 px-6 py-3 font-semibold rounded-full"
          style={`color:${accent}; border:2px solid ${accent};`}
        >
          ☎ {business.phone}
        </a>
      </div>
    </div>

    <!-- THE SERVICE TILE GRID — this is the hero -->
    <ul
      class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4"
      role="list"
      aria-label="Services we provide"
    >
      {business.services.slice(0, 8).map((service: any) => {
        const icon = iconFor(service.slug);
        return (
          <li>
            <a
              href={`#services`}
              class="group relative block p-5 sm:p-6 rounded-2xl bg-white shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-200"
              style="border:1px solid rgba(0,0,0,0.06);"
            >
              <div
                class="w-12 h-12 rounded-xl flex items-center justify-center mb-4"
                style={`background:${accent}15; color:${accent};`}
                aria-hidden="true"
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-6 h-6">
                  {icon === 'flame' && <path stroke-linecap="round" stroke-linejoin="round" d="M12 2s4 4 4 8a4 4 0 11-8 0c0-2 1-3 2-4-1 4 2 5 2 5s-2-4 0-9z"/>}
                  {icon === 'snow' && <g><line x1="12" y1="2" x2="12" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="4" y1="4" x2="20" y2="20"/><line x1="20" y1="4" x2="4" y2="20"/></g>}
                  {icon === 'drop' && <path stroke-linecap="round" stroke-linejoin="round" d="M12 3s6 7 6 11a6 6 0 11-12 0c0-4 6-11 6-11z"/>}
                  {icon === 'wave' && <path stroke-linecap="round" stroke-linejoin="round" d="M3 12c2-3 4-3 6 0s4 3 6 0 4-3 6 0M3 17c2-3 4-3 6 0s4 3 6 0 4-3 6 0"/>}
                  {icon === 'pipe' && <path stroke-linecap="round" stroke-linejoin="round" d="M3 9h6V3M3 15h6v6M21 9h-6V3M21 15h-6v6M9 9v6h6V9z"/>}
                  {icon === 'sewer' && <g><circle cx="12" cy="12" r="9"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="12" y1="3" x2="12" y2="21"/></g>}
                  {icon === 'spark' && <path stroke-linecap="round" stroke-linejoin="round" d="M13 2L4 14h7l-1 8 9-12h-7l1-8z"/>}
                  {icon === 'camera' && <g><rect x="3" y="7" width="18" height="13" rx="2"/><circle cx="12" cy="13" r="3.5"/><path d="M9 7l1.5-2h3L15 7"/></g>}
                  {icon === 'faucet' && <path stroke-linecap="round" stroke-linejoin="round" d="M6 5h12M9 5v4h6V5M12 9v5m-3 0h6v3a3 3 0 11-6 0v-3z"/>}
                  {icon === 'alert' && <path stroke-linecap="round" stroke-linejoin="round" d="M12 2L2 20h20L12 2zm0 7v5m0 3v.01"/>}
                  {icon === 'bolt' && <path stroke-linecap="round" stroke-linejoin="round" d="M13 2L4 14h7l-1 8 9-12h-7l1-8z"/>}
                  {icon === 'panel' && <g><rect x="4" y="3" width="16" height="18" rx="1"/><line x1="4" y1="9" x2="20" y2="9"/><line x1="12" y1="9" x2="12" y2="21"/></g>}
                  {icon === 'chip' && <g><rect x="6" y="6" width="12" height="12" rx="1"/><path d="M9 2v4M15 2v4M9 18v4M15 18v4M2 9h4M2 15h4M18 9h4M18 15h4"/></g>}
                  {icon === 'bulb' && <path stroke-linecap="round" stroke-linejoin="round" d="M9 18h6m-5 3h4M12 2a6 6 0 00-4 10.5c1 1 1.5 1.5 1.5 2.5v0h5v0c0-1 .5-1.5 1.5-2.5A6 6 0 0012 2z"/>}
                  {icon === 'wind' && <path stroke-linecap="round" stroke-linejoin="round" d="M3 8h12a3 3 0 100-6M3 14h17a3 3 0 110 6M3 11h7"/>}
                  {icon === 'gear' && <g><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.7 1.7 0 00.3 1.8l.1.1a2 2 0 11-2.8 2.8l-.1-.1a1.7 1.7 0 00-1.8-.3 1.7 1.7 0 00-1 1.5V21a2 2 0 11-4 0v-.1a1.7 1.7 0 00-1.1-1.5 1.7 1.7 0 00-1.8.3l-.1.1a2 2 0 11-2.8-2.8l.1-.1a1.7 1.7 0 00.3-1.8 1.7 1.7 0 00-1.5-1H3a2 2 0 110-4h.1a1.7 1.7 0 001.5-1.1 1.7 1.7 0 00-.3-1.8l-.1-.1a2 2 0 112.8-2.8l.1.1a1.7 1.7 0 001.8.3H9a1.7 1.7 0 001-1.5V3a2 2 0 114 0v.1a1.7 1.7 0 001 1.5 1.7 1.7 0 001.8-.3l.1-.1a2 2 0 112.8 2.8l-.1.1a1.7 1.7 0 00-.3 1.8V9a1.7 1.7 0 001.5 1H21a2 2 0 110 4h-.1a1.7 1.7 0 00-1.5 1z"/></g>}
                  {icon === 'tool' && <path stroke-linecap="round" stroke-linejoin="round" d="M14.7 6.3a4 4 0 105.4 5.4l-7.7 7.7a2 2 0 11-2.8-2.8z"/>}
                </svg>
              </div>
              <h2 class="font-display font-bold text-base sm:text-lg mb-1" style={`color:${ink};`}>{service.title}</h2>
              <p class="text-sm opacity-70 leading-snug">{service.description}</p>
              <span
                class="absolute top-3 right-3 opacity-0 group-hover:opacity-100 transition text-xs font-semibold"
                style={`color:${accent};`}
                aria-hidden="true"
              >→</span>
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</section>
