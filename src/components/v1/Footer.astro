---
import { business } from '../../data/v1';
---

<footer class="bg-navy-950 border-t border-white/8" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Footer</h2>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

      <!-- Column 1: Brand -->
      <div class="lg:col-span-1">
        <!-- Logo -->
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-orange-500 rounded-lg flex items-center justify-center flex-shrink-0" aria-hidden="true">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" />
            </svg>
          </div>
          <div>
            <p class="font-display font-black text-white uppercase text-base leading-none tracking-wide">{business.shortName}</p>
            <p class="text-slate-500 text-xs mt-0.5">{business.tagline}</p>
          </div>
        </div>
        <p class="text-slate-400 font-body text-sm leading-relaxed mb-5">{business.footer.description}</p>

        <!-- Social links -->
        <div class="flex gap-3" aria-label="Follow us on social media">
          <a
            href={business.social.facebook}
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 bg-white/8 hover:bg-orange-500 border border-white/10 rounded-lg flex items-center justify-center text-slate-400 hover:text-white transition-all"
            aria-label="Facebook"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a
            href={business.social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 bg-white/8 hover:bg-orange-500 border border-white/10 rounded-lg flex items-center justify-center text-slate-400 hover:text-white transition-all"
            aria-label="Instagram"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a
            href={business.social.yelp}
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 bg-white/8 hover:bg-orange-500 border border-white/10 rounded-lg flex items-center justify-center text-slate-400 hover:text-white transition-all"
            aria-label="Yelp"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.16 12.74l-4.3 1.6c-.7.26-1.4-.38-1.14-1.08l1.67-4.28c.25-.66 1.12-.7 1.44-.07l2.6 5.07c.28.54-.1.9-.27.76zM14.93 9.1l-2.72-3.84c-.42-.6.07-1.36.77-1.28l4.6.53c.7.08.92.9.36 1.28l-1.88 3.3c-.37.65-1.2.5-1.13.01zM10.83 8.83l-4.1-1.03c-.66-.17-.8-1.03-.24-1.42l3.87-2.64c.57-.39 1.27.07 1.2.76l-.23 4.1c-.05.86-.95 1.06-1.5.23zm-3.76 4.3l4.12-1.12c.68-.18.68-1.1 0-1.28L6.9 9.74c-.65-.18-1.24.35-1.1 1.02l.35 3.5c.07.7.62 1.04 1.02.87zm5.27 3.77l-2.55-3.4c-.42-.56-1.22-.27-1.25.43l-.14 4.49c-.03.7.73 1.1 1.27.67l2.7-2.18c.46-.38.41-1.4-.03-1.01z"/>
            </svg>
          </a>
          <a
            href={business.social.google}
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 bg-white/8 hover:bg-orange-500 border border-white/10 rounded-lg flex items-center justify-center text-slate-400 hover:text-white transition-all"
            aria-label="Google Maps"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Column 2: Contact -->
      <div>
        <h3 class="font-display font-bold uppercase text-white text-base tracking-wider mb-5">Contact</h3>
        <ul class="space-y-4 list-none m-0 p-0">
          <li>
            <a
              href={business.phoneHref}
              class="flex items-center gap-3 text-slate-300 hover:text-orange-400 transition-colors group"
              aria-label={`Call us at ${business.phone}`}
            >
              <svg class="w-4 h-4 text-orange-500 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
              </svg>
              <span class="font-body font-semibold">{business.phone}</span>
            </a>
          </li>
          <li>
            <a
              href={business.emailHref}
              class="flex items-center gap-3 text-slate-300 hover:text-orange-400 transition-colors"
              aria-label={`Email us at ${business.email}`}
            >
              <svg class="w-4 h-4 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
              </svg>
              <span class="font-body text-sm">{business.email}</span>
            </a>
          </li>
          <li class="flex items-start gap-3 text-slate-400 text-sm font-body">
            <svg class="w-4 h-4 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Zm6-10.125a1.875 1.875 0 1 1-3.75 0 1.875 1.875 0 0 1 3.75 0Zm1.294 6.336a6.721 6.721 0 0 1-3.17.789 6.721 6.721 0 0 1-3.168-.789 3.376 3.376 0 0 1 6.338 0Z"/>
            </svg>
            License {business.license}
          </li>
          <li class="flex items-start gap-3 text-slate-400 text-sm font-body">
            <svg class="w-4 h-4 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
            </svg>
            {business.address}
          </li>
        </ul>
      </div>

      <!-- Column 3: Hours -->
      <div>
        <h3 class="font-display font-bold uppercase text-white text-base tracking-wider mb-5">Service Hours</h3>
        <ul class="space-y-3 list-none m-0 p-0">
          {business.hours.map((h) => (
            <li class="flex justify-between gap-4">
              <span class="text-slate-500 font-body text-sm">{h.day}</span>
              <span class="text-slate-300 font-body font-semibold text-sm text-right">{h.hours}</span>
            </li>
          ))}
        </ul>
        <div class="mt-5 flex items-center gap-2 text-orange-400 font-body font-semibold text-sm">
          <span class="w-2 h-2 bg-orange-500 rounded-full animate-pulse flex-shrink-0" aria-hidden="true"></span>
          {business.emergencyNote}
        </div>
      </div>

      <!-- Column 4: Quick Links -->
      <div>
        <h3 class="font-display font-bold uppercase text-white text-base tracking-wider mb-5">Quick Links</h3>
        <ul class="space-y-2.5 list-none m-0 p-0">
          {business.footer.links.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-slate-400 hover:text-orange-400 font-body text-sm flex items-center gap-2 transition-colors"
              >
                <svg class="w-3.5 h-3.5 text-orange-500/60" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
                </svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Emergency callout box -->
        <div class="mt-8 p-4 bg-orange-500/10 border border-orange-500/25 rounded-xl">
          <p class="text-orange-400 font-body font-bold text-sm mb-1">Plumbing Emergency?</p>
          <p class="text-slate-400 font-body text-xs mb-3">We answer 24 hours a day, 7 days a week.</p>
          <a
            href={business.phoneHref}
            class="block text-center bg-orange-500 hover:bg-orange-600 text-white font-body font-bold text-sm py-2 px-4 rounded-lg transition-all"
            aria-label={`Emergency: call ${business.phone}`}
          >
            Call Now: {business.phone}
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/8 pt-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <p class="text-slate-600 font-body text-sm">{business.footer.copyright}</p>
      <p class="text-slate-600 font-body text-sm">License {business.license} · San Diego County, CA</p>
    </div>
  </div>
</footer>
