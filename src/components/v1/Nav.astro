---
import { business } from '../../data/v1';
---

<!-- Mobile sticky phone bar (bottom) -->
<div
  class="fixed bottom-0 left-0 right-0 z-50 md:hidden bg-orange-500 shadow-[0_-4px_24px_rgba(0,0,0,0.4)]"
  role="banner"
  aria-label="Quick call banner"
>
  <a
    href={business.phoneHref}
    class="flex items-center justify-center gap-3 py-4 font-body font-bold text-xl text-white active:bg-orange-600 transition-colors"
    aria-label={`Call us now at ${business.phone}`}
  >
    <svg class="w-6 h-6 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
    </svg>
    Tap to Call — {business.phone}
  </a>
</div>

<!-- Main navigation -->
<header
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-40 transition-all duration-300"
  style="background: transparent;"
>
  <nav
    class="max-w-7xl mx-auto px-4 sm:px-6 h-[72px] flex items-center justify-between gap-4"
    aria-label="Main navigation"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 flex-shrink-0 group" aria-label={`${business.name} home`}>
      <div class="w-9 h-9 bg-orange-500 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-orange-400 transition-colors" aria-hidden="true">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" />
        </svg>
      </div>
      <div class="hidden sm:block">
        <span class="block font-display font-black text-white text-lg leading-none tracking-wide uppercase">
          {business.shortName}
        </span>
        <span class="block text-orange-400 text-xs font-body font-semibold leading-none mt-0.5">
          {business.tagline}
        </span>
      </div>
    </a>

    <!-- Desktop nav links -->
    <ul class="hidden lg:flex items-center gap-1 list-none m-0 p-0" role="list">
      {[
        { label: 'Services', href: '#services' },
        { label: 'Service Area', href: '#service-area' },
        { label: 'Why Us', href: '#why-us' },
        { label: 'Reviews', href: '#reviews' },
      ].map(link => (
        <li>
          <a
            href={link.href}
            class="px-4 py-2 text-slate-300 hover:text-white font-body font-medium text-sm rounded-lg hover:bg-white/10 transition-all"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Desktop CTA group -->
    <div class="flex items-center gap-3 flex-shrink-0">
      <a
        href={business.phoneHref}
        class="hidden md:flex items-center gap-2 text-white font-display font-bold text-xl uppercase tracking-wide hover:text-orange-400 transition-colors"
        aria-label={`Call ${business.phone}`}
      >
        <svg class="w-5 h-5 text-orange-500 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
        </svg>
        {business.phone}
      </a>
      <a
        href="#quote"
        class="hidden sm:block bg-orange-500 hover:bg-orange-600 text-white font-body font-bold text-sm px-5 py-2.5 rounded-lg transition-all hover:scale-[1.02] active:scale-100"
      >
        Request Service
      </a>
    </div>
  </nav>
</header>

<script>
  const nav = document.getElementById('site-nav');
  let lastScroll = 0;

  function updateNav() {
    const scrolled = window.scrollY > 40;
    if (scrolled) {
      nav?.style.setProperty('background', 'rgba(9,22,41,0.97)');
      nav?.style.setProperty('box-shadow', '0 2px 32px rgba(0,0,0,0.4)');
      nav?.style.setProperty('backdrop-filter', 'blur(12px)');
    } else {
      nav?.style.setProperty('background', 'transparent');
      nav?.style.setProperty('box-shadow', 'none');
      nav?.style.setProperty('backdrop-filter', 'none');
    }
    lastScroll = window.scrollY;
  }

  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();
</script>
