---
import { business } from '../../data/v1';
---

<section
  id="projects"
  class="relative py-20 lg:py-28"
  style="background:#0c1d38;"
  aria-labelledby="projects-heading"
>
  <!-- Top double rule -->
  <div class="absolute top-0 left-0 right-0" aria-hidden="true">
    <div class="h-1" style="background:#f97316;"></div>
    <div class="h-0.5" style="background:rgba(249,115,22,0.25);"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Section header — left-aligned -->
    <div class="mb-14">
      <div class="flex items-center gap-3 mb-3" aria-hidden="true">
        <div class="h-px w-12" style="background:#f97316;"></div>
        <span class="font-body font-bold text-xs uppercase tracking-widest" style="color:#f97316;">
          Our Work
        </span>
      </div>
      <h2
        id="projects-heading"
        class="font-display font-black uppercase text-white leading-none"
        style="font-size: clamp(2.75rem, 6vw, 5rem); letter-spacing:-0.02em;"
      >
        RECENT PROJECTS
      </h2>
      <p class="font-body text-base mt-4 max-w-lg" style="color:rgba(255,255,255,0.5);">
        Real jobs. Real results. Drag the slider to see before and after.
      </p>
    </div>

    <!-- Carousel -->
    <div
      class="relative"
      aria-roledescription="carousel"
      aria-label="Recent projects before and after"
    >
      <!-- Slides -->
      <div id="project-carousel" class="overflow-hidden">
        <div
          id="project-track"
          class="flex transition-transform duration-500 ease-out"
          style={`width: ${business.projects.length * 100}%;`}
        >
          {business.projects.map((project, i) => (
            <div
              class="flex-shrink-0"
              style={`width: ${100 / business.projects.length}%;`}
              role="group"
              aria-roledescription="slide"
              aria-label={`Project ${i + 1} of ${business.projects.length}: ${project.title}`}
            >
              <!-- Before/After panel — industrial framing with corner marks -->
              <div class="relative" style="aspect-ratio: 16/9;">
                <!-- Outer frame with corner cross-hair marks -->
                <div class="absolute inset-0 z-20 pointer-events-none" aria-hidden="true">
                  <!-- TL -->
                  <div class="absolute top-3 left-3">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                      <path d="M0 12 L12 12 M12 0 L12 12" stroke="#f97316" stroke-width="2"/>
                    </svg>
                  </div>
                  <!-- TR -->
                  <div class="absolute top-3 right-3">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                      <path d="M24 12 L12 12 M12 0 L12 12" stroke="#f97316" stroke-width="2"/>
                    </svg>
                  </div>
                  <!-- BL -->
                  <div class="absolute bottom-3 left-3">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                      <path d="M0 12 L12 12 M12 24 L12 12" stroke="#f97316" stroke-width="2"/>
                    </svg>
                  </div>
                  <!-- BR -->
                  <div class="absolute bottom-3 right-3">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                      <path d="M24 12 L12 12 M12 24 L12 12" stroke="#f97316" stroke-width="2"/>
                    </svg>
                  </div>
                </div>

                <!-- BEFORE image -->
                <img
                  src={project.beforeImg}
                  alt={`Before: ${project.title} in ${project.location}`}
                  class="absolute inset-0 w-full h-full object-cover"
                  loading="lazy"
                />

                <!-- AFTER image (clipped by slider) -->
                <img
                  src={project.afterImg}
                  alt={`After: ${project.title} in ${project.location}`}
                  class="after-img absolute inset-0 w-full h-full object-cover"
                  style="clip-path: inset(0 50% 0 0);"
                  loading="lazy"
                />

                <!-- Range input transparent overlay -->
                <input
                  type="range"
                  min="0"
                  max="100"
                  value="50"
                  class="ba-slider absolute inset-0 w-full h-full opacity-0 cursor-col-resize z-10"
                  aria-label={`Before and after slider for ${project.title}`}
                />

                <!-- Divider line + handle — sharp square handle -->
                <div class="ba-divider absolute top-0 bottom-0 left-1/2 pointer-events-none z-20 -translate-x-1/2">
                  <div class="w-0.5 h-full" style="background:rgba(255,255,255,0.8);"></div>
                  <!-- Square drag handle -->
                  <div
                    class="absolute top-1/2 -translate-y-1/2 -translate-x-1/2 w-10 h-10 flex items-center justify-center gap-0.5 shadow-xl"
                    style="background:#f97316; border:2px solid white;"
                  >
                    <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l-3 3 3 3M16 9l3 3-3 3"/>
                    </svg>
                  </div>
                </div>

                <!-- BEFORE / AFTER labels — industrial tape style -->
                <div
                  class="absolute top-4 left-4 z-20 pointer-events-none font-display font-black uppercase text-white text-xs tracking-widest px-3 py-1.5"
                  style="background:rgba(0,0,0,0.75);"
                  aria-hidden="true"
                >BEFORE</div>
                <div
                  class="absolute top-4 right-4 z-20 pointer-events-none font-display font-black uppercase text-white text-xs tracking-widest px-3 py-1.5"
                  style="background:#f97316;"
                  aria-hidden="true"
                >AFTER</div>
              </div>

              <!-- Project info panel — sharp, left-border orange accent -->
              <div
                class="mt-0 px-5 py-5 flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4"
                style="background:rgba(255,255,255,0.04); border-left:4px solid #f97316; border-top:1px solid rgba(255,255,255,0.06);"
              >
                <div>
                  <h3
                    class="font-display font-black uppercase text-white leading-tight"
                    style="font-size:1.5rem; letter-spacing:0.02em;"
                  >
                    {project.title}
                  </h3>
                  <p class="font-body text-xs font-bold uppercase tracking-widest mt-1 mb-2" style="color:#f97316;">
                    <svg class="inline w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 1 1 9.9 9.9L10 18.9l-4.95-4.95a7 7 0 0 1 0-9.9ZM10 11a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" clip-rule="evenodd"/>
                    </svg>
                    {project.location}, San Diego County
                  </p>
                  <p class="font-body text-sm" style="color:rgba(255,255,255,0.5);">{project.description}</p>
                </div>
                <a
                  href="#quote"
                  class="inline-flex items-center gap-2 font-display font-black uppercase text-white text-xs tracking-widest px-4 py-2.5 flex-shrink-0 transition-opacity hover:opacity-90"
                  style="background:#f97316; border-radius:0;"
                >
                  GET ESTIMATE
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Controls row -->
      <div class="flex items-center justify-between mt-6">
        <div class="flex gap-2">
          <button
            id="prev-btn"
            class="w-12 h-12 flex items-center justify-center text-white transition-opacity hover:opacity-80 focus:outline-none"
            style="background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15); border-radius:0;"
            aria-label="Previous project"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/>
            </svg>
          </button>
          <button
            id="next-btn"
            class="w-12 h-12 flex items-center justify-center text-white transition-opacity hover:opacity-90 focus:outline-none"
            style="background:#f97316; border:1px solid #f97316; border-radius:0;"
            aria-label="Next project"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
            </svg>
          </button>
        </div>

        <!-- Dot indicators — square dots -->
        <div class="flex gap-1.5" role="tablist" aria-label="Project slides">
          {business.projects.map((_, i) => (
            <button
              class="dot focus:outline-none transition-all"
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-label={`Go to project ${i + 1}`}
              data-index={i}
              style={`
                width: ${i === 0 ? '2rem' : '0.5rem'};
                height: 0.5rem;
                background: ${i === 0 ? '#f97316' : 'rgba(255,255,255,0.2)'};
                border: none;
                border-radius: 0;
                cursor: pointer;
              `}
            />
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // ── Before/After sliders ────────────────────────────────────────────────────
  document.querySelectorAll<HTMLInputElement>('.ba-slider').forEach((slider) => {
    const container = slider.closest<HTMLDivElement>('.relative');
    if (!container) return;
    const afterImg = container.querySelector<HTMLImageElement>('.after-img');
    const divider = container.querySelector<HTMLDivElement>('.ba-divider');
    if (!afterImg || !divider) return;

    slider.addEventListener('input', () => {
      const val = Number(slider.value);
      afterImg.style.clipPath = `inset(0 ${100 - val}% 0 0)`;
      divider.style.left = `${val}%`;
    });
  });

  // ── Project carousel ────────────────────────────────────────────────────────
  const track = document.getElementById('project-track') as HTMLDivElement | null;
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const dots = document.querySelectorAll<HTMLButtonElement>('.dot');
  const total = dots.length;
  let current = 0;

  function goTo(index: number) {
    current = (index + total) % total;
    if (track) track.style.transform = `translateX(-${current * (100 / total)}%)`;
    dots.forEach((dot, i) => {
      const active = i === current;
      dot.style.width = active ? '2rem' : '0.5rem';
      dot.style.background = active ? '#f97316' : 'rgba(255,255,255,0.2)';
      dot.setAttribute('aria-selected', active ? 'true' : 'false');
    });
  }

  prevBtn?.addEventListener('click', () => goTo(current - 1));
  nextBtn?.addEventListener('click', () => goTo(current + 1));
  dots.forEach(dot => {
    dot.addEventListener('click', () => goTo(Number(dot.dataset.index)));
  });

  setInterval(() => goTo(current + 1), 6000);
</script>
