---
import { business } from '../../data/v1';

// Split cities into two columns
const half = Math.ceil(business.serviceArea.cities.length / 2);
const col1 = business.serviceArea.cities.slice(0, half);
const col2 = business.serviceArea.cities.slice(half);
---

<section
  id="service-area"
  class="relative py-20 lg:py-28"
  style="background:#f8fafc;"
  aria-labelledby="service-area-heading"
>
  <!-- Left orange accent strip -->
  <div
    class="absolute left-0 top-0 bottom-0 w-2"
    style="background:#f97316;"
    aria-hidden="true"
  ></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="mb-14">
      <div class="flex items-center gap-3 mb-3" aria-hidden="true">
        <div class="h-px w-12" style="background:#f97316;"></div>
        <span class="font-body font-bold text-xs uppercase tracking-widest" style="color:#f97316;">
          Where We Work
        </span>
      </div>
      <h2
        id="service-area-heading"
        class="font-display font-black uppercase leading-none"
        style="font-size: clamp(2.75rem, 6vw, 5rem); color:#0f2855; letter-spacing:-0.02em;"
      >
        {business.serviceArea.headline}
      </h2>
    </div>

    <!-- Two-column layout: map left, content right -->
    <div class="grid lg:grid-cols-[1fr_1fr] gap-12 lg:gap-16 items-start">

      <!-- LEFT: SVG map — industrial blueprint style -->
      <div aria-hidden="true">
        <svg
          viewBox="0 0 440 440"
          class="w-full"
          role="img"
          aria-label="Service coverage map for San Diego County"
          style="max-width: 480px;"
        >
          <!-- Blueprint background -->
          <rect width="440" height="440" fill="#0f2855"/>

          <!-- Blueprint grid -->
          {Array.from({ length: 11 }).map((_, i) => (
            <>
              <line x1={i * 44} y1="0" x2={i * 44} y2="440" stroke="rgba(249,115,22,0.08)" stroke-width="1"/>
              <line x1="0" y1={i * 44} x2="440" y2={i * 44} stroke="rgba(249,115,22,0.08)" stroke-width="1"/>
            </>
          ))}

          <!-- Outer county boundary — blocky polygon -->
          <polygon
            points="80,60 360,60 390,120 390,340 340,400 120,400 60,340 60,120"
            fill="rgba(249,115,22,0.06)"
            stroke="rgba(249,115,22,0.4)"
            stroke-width="2"
            stroke-dasharray="8 4"
          />

          <!-- Coverage zone fills (concentric, angular) -->
          <polygon
            points="120,100 320,100 360,160 360,320 300,380 140,380 80,320 80,160"
            fill="rgba(249,115,22,0.07)"
            stroke="rgba(249,115,22,0.25)"
            stroke-width="1.5"
          />
          <polygon
            points="155,140 285,140 320,190 320,285 270,340 170,340 120,285 120,190"
            fill="rgba(249,115,22,0.1)"
            stroke="rgba(249,115,22,0.35)"
            stroke-width="1.5"
          />
          <polygon
            points="185,175 255,175 285,215 285,255 245,295 195,295 155,255 155,215"
            fill="rgba(249,115,22,0.16)"
            stroke="rgba(249,115,22,0.5)"
            stroke-width="2"
          />

          <!-- Center marker — HQ cross-hair -->
          <line x1="215" y1="205" x2="215" y2="235" stroke="#f97316" stroke-width="2"/>
          <line x1="200" y1="220" x2="230" y2="220" stroke="#f97316" stroke-width="2"/>
          <circle cx="215" cy="220" r="10" fill="#f97316" opacity="0.9"/>
          <circle cx="215" cy="220" r="4" fill="white"/>

          <!-- City dots -->
          <circle cx="215" cy="230" r="5" fill="#f97316" opacity="0.85"/>
          <circle cx="220" cy="270" r="4" fill="#f97316" opacity="0.75"/>
          <circle cx="260" cy="225" r="4" fill="#f97316" opacity="0.75"/>
          <circle cx="258" cy="178" r="4" fill="#f97316" opacity="0.7"/>
          <circle cx="248" cy="235" r="3.5" fill="#f97316" opacity="0.7"/>
          <circle cx="212" cy="255" r="3.5" fill="#f97316" opacity="0.7"/>
          <circle cx="278" cy="215" r="3.5" fill="#f97316" opacity="0.65"/>
          <circle cx="242" cy="180" r="3.5" fill="#f97316" opacity="0.65"/>
          <circle cx="180" cy="150" r="3.5" fill="#f97316" opacity="0.65"/>
          <circle cx="168" cy="130" r="3.5" fill="#f97316" opacity="0.6"/>
          <circle cx="160" cy="108" r="3.5" fill="#f97316" opacity="0.55"/>
          <circle cx="196" cy="252" r="3" fill="#f97316" opacity="0.6"/>
          <circle cx="200" cy="298" r="3" fill="#f97316" opacity="0.55"/>
          <circle cx="248" cy="252" r="3" fill="#f97316" opacity="0.6"/>
          <circle cx="310" cy="235" r="3" fill="#f97316" opacity="0.5"/>

          <!-- Labels -->
          <text x="215" y="400" text-anchor="middle" font-family="'Barlow Condensed', sans-serif" font-weight="900" font-size="12" fill="rgba(249,115,22,0.7)" letter-spacing="3">SAN DIEGO COUNTY</text>
          <text x="215" y="48" text-anchor="middle" font-family="'Barlow Condensed', sans-serif" font-weight="900" font-size="11" fill="rgba(249,115,22,0.5)" letter-spacing="2">FULL COUNTY COVERAGE</text>

          <!-- Corner engineering marks -->
          <path d="M10 30 L10 10 L30 10" stroke="rgba(249,115,22,0.5)" stroke-width="2" fill="none"/>
          <path d="M410 10 L430 10 L430 30" stroke="rgba(249,115,22,0.5)" stroke-width="2" fill="none"/>
          <path d="M10 410 L10 430 L30 430" stroke="rgba(249,115,22,0.5)" stroke-width="2" fill="none"/>
          <path d="M430 410 L430 430 L410 430" stroke="rgba(249,115,22,0.5)" stroke-width="2" fill="none"/>

          <!-- Scale bar -->
          <line x1="100" y1="420" x2="340" y2="420" stroke="rgba(249,115,22,0.35)" stroke-width="1.5"/>
          <line x1="100" y1="415" x2="100" y2="425" stroke="rgba(249,115,22,0.35)" stroke-width="1.5"/>
          <line x1="340" y1="415" x2="340" y2="425" stroke="rgba(249,115,22,0.35)" stroke-width="1.5"/>
          <text x="220" y="418" text-anchor="middle" font-family="'DM Sans', sans-serif" font-size="8" fill="rgba(249,115,22,0.45)" letter-spacing="1">~70 MILES</text>
        </svg>

        <!-- Callout bar below map -->
        <div
          class="flex items-center justify-between px-5 py-3 mt-0"
          style="background:#f97316;"
        >
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-white flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
            <span class="font-display font-black uppercase text-white text-sm tracking-widest">
              60-MINUTE RESPONSE GUARANTEE
            </span>
          </div>
          <a
            href={business.phoneHref}
            class="font-display font-black uppercase text-white text-sm tracking-widest hover:opacity-80 transition-opacity"
            aria-label={`Call ${business.phone}`}
          >
            CALL NOW
          </a>
        </div>
      </div>

      <!-- RIGHT: City list + CTA -->
      <div>
        <p class="font-body text-lg mb-8 leading-relaxed" style="color:#475569;">
          {business.serviceArea.subheadline}. Our trucks are spread across the county — fast arrival, every time.
        </p>

        <!-- City grid — two columns, bold city names -->
        <div class="grid grid-cols-2 gap-0 mb-10" style="border:1px solid #e2e8f0;">
          {business.serviceArea.cities.map((city, i) => (
            <div
              class="flex items-center gap-2 px-4 py-3 transition-colors"
              style={`
                border-right:${i % 2 === 0 ? '1px solid #e2e8f0' : 'none'};
                border-bottom:${i < business.serviceArea.cities.length - 2 ? '1px solid #e2e8f0' : 'none'};
              `}
              onmouseover="this.style.background='rgba(249,115,22,0.05)'"
              onmouseout="this.style.background='transparent'"
            >
              <!-- Orange square bullet -->
              <div
                class="w-2 h-2 flex-shrink-0"
                style="background:#f97316;"
                aria-hidden="true"
              ></div>
              <span class="font-display font-black uppercase text-sm tracking-wide" style="color:#0f2855; letter-spacing:0.04em;">
                {city}
              </span>
            </div>
          ))}
        </div>

        <!-- "Don't see your city?" box — sharp-cornered, left-border accent -->
        <div
          class="p-6"
          style="background:#0f2855; border-left:4px solid #f97316;"
        >
          <p class="font-display font-black uppercase text-white text-xl mb-1 leading-tight">
            DON'T SEE YOUR CITY?
          </p>
          <p class="font-body text-sm mb-5" style="color:rgba(255,255,255,0.6);">
            We often serve surrounding areas. Give us a call and we'll get to you.
          </p>
          <a
            href={business.phoneHref}
            class="inline-flex items-center gap-2 font-display font-black uppercase text-white text-sm tracking-widest px-6 py-3 transition-opacity hover:opacity-90"
            style="background:#f97316; border-radius:0;"
            aria-label={`Call us at ${business.phone}`}
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
            </svg>
            {business.phone}
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
