---
import { business } from '../../data/v1';
---

<section
  id="service-area"
  class="relative bg-slate-50 py-20 lg:py-28"
  aria-labelledby="service-area-heading"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: SVG coverage map -->
      <div class="flex flex-col items-center" aria-hidden="true">
        <div class="relative w-full max-w-md">
          <!-- Concentric circles map -->
          <svg
            viewBox="0 0 400 400"
            class="w-full drop-shadow-2xl"
            role="img"
            aria-label="Service coverage map for San Diego County"
          >
            <!-- Background -->
            <rect width="400" height="400" rx="20" fill="#0f2855"/>

            <!-- Grid lines -->
            <line x1="0" y1="200" x2="400" y2="200" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
            <line x1="200" y1="0" x2="200" y2="400" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>

            <!-- Concentric coverage rings -->
            <circle cx="200" cy="200" r="160" fill="rgba(249,115,22,0.04)" stroke="rgba(249,115,22,0.15)" stroke-width="1" stroke-dasharray="6 4"/>
            <circle cx="200" cy="200" r="120" fill="rgba(249,115,22,0.06)" stroke="rgba(249,115,22,0.2)" stroke-width="1" stroke-dasharray="6 4"/>
            <circle cx="200" cy="200" r="80" fill="rgba(249,115,22,0.09)" stroke="rgba(249,115,22,0.3)" stroke-width="1.5"/>
            <circle cx="200" cy="200" r="40" fill="rgba(249,115,22,0.18)" stroke="rgba(249,115,22,0.5)" stroke-width="2"/>

            <!-- Center marker -->
            <circle cx="200" cy="200" r="12" fill="#f97316"/>
            <circle cx="200" cy="200" r="5" fill="white"/>

            <!-- City dots: approximate SD County geography -->
            <!-- San Diego (center-ish) -->
            <circle cx="195" cy="210" r="5" fill="#f97316" opacity="0.85"/>
            <!-- Chula Vista (south) -->
            <circle cx="200" cy="255" r="4" fill="#f97316" opacity="0.75"/>
            <!-- El Cajon (east) -->
            <circle cx="245" cy="205" r="4" fill="#f97316" opacity="0.75"/>
            <!-- Escondido (north-east) -->
            <circle cx="245" cy="155" r="4" fill="#f97316" opacity="0.7"/>
            <!-- La Mesa -->
            <circle cx="230" cy="215" r="3.5" fill="#f97316" opacity="0.7"/>
            <!-- National City -->
            <circle cx="192" cy="240" r="3.5" fill="#f97316" opacity="0.7"/>
            <!-- Santee (east) -->
            <circle cx="262" cy="195" r="3.5" fill="#f97316" opacity="0.65"/>
            <!-- Poway (north) -->
            <circle cx="225" cy="160" r="3.5" fill="#f97316" opacity="0.65"/>
            <!-- Encinitas (north coast) -->
            <circle cx="165" cy="130" r="3.5" fill="#f97316" opacity="0.65"/>
            <!-- Carlsbad -->
            <circle cx="155" cy="110" r="3.5" fill="#f97316" opacity="0.6"/>
            <!-- Oceanside (far north) -->
            <circle cx="148" cy="88" r="3.5" fill="#f97316" opacity="0.55"/>
            <!-- Coronado -->
            <circle cx="177" cy="235" r="3" fill="#f97316" opacity="0.6"/>
            <!-- Imperial Beach -->
            <circle cx="180" cy="282" r="3" fill="#f97316" opacity="0.55"/>
            <!-- Spring Valley -->
            <circle cx="228" cy="235" r="3" fill="#f97316" opacity="0.6"/>
            <!-- Alpine (far east) -->
            <circle cx="295" cy="215" r="3" fill="#f97316" opacity="0.5"/>
            <!-- Ramona (far north-east) -->
            <circle cx="285" cy="145" r="3" fill="#f97316" opacity="0.5"/>

            <!-- Label: San Diego County -->
            <text x="200" y="370" text-anchor="middle" fill="rgba(255,255,255,0.5)" font-size="11" font-family="'DM Sans', sans-serif" font-weight="500" letter-spacing="2">SAN DIEGO COUNTY</text>

            <!-- Radius label -->
            <text x="200" y="72" text-anchor="middle" fill="rgba(249,115,22,0.7)" font-size="10" font-family="'DM Sans', sans-serif" font-weight="600" letter-spacing="1">FULL COUNTY COVERAGE</text>

            <!-- Scale indicator -->
            <line x1="100" y1="355" x2="300" y2="355" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
            <line x1="100" y1="350" x2="100" y2="360" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
            <line x1="300" y1="350" x2="300" y2="360" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
            <text x="200" y="348" text-anchor="middle" fill="rgba(255,255,255,0.3)" font-size="9" font-family="'DM Sans', sans-serif">~70 miles</text>
          </svg>

          <!-- Callout pill -->
          <div class="absolute -bottom-4 left-1/2 -translate-x-1/2 whitespace-nowrap bg-orange-500 text-white font-body font-bold text-sm px-5 py-2 rounded-full shadow-lg">
            60-Minute Response Guarantee
          </div>
        </div>
      </div>

      <!-- Right: city list -->
      <div>
        <span class="inline-block text-orange-500 font-body font-semibold text-sm uppercase tracking-widest mb-3">
          Where We Work
        </span>
        <h2
          id="service-area-heading"
          class="font-display font-black uppercase text-navy-700 mb-4"
          style="font-size: clamp(2rem, 4vw, 3rem);"
        >
          {business.serviceArea.headline}
        </h2>
        <p class="text-slate-600 font-body text-lg mb-8">
          {business.serviceArea.subheadline}. Our trucks are spread across the county so we can reach you fast.
        </p>

        <!-- City grid -->
        <ul class="grid grid-cols-2 gap-x-6 gap-y-2.5 mb-10" role="list" aria-label="Cities we serve">
          {business.serviceArea.cities.map((city) => (
            <li class="flex items-center gap-2 text-slate-700 font-body font-medium">
              <svg class="w-4 h-4 text-orange-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 1 1 9.9 9.9L10 18.9l-4.95-4.95a7 7 0 0 1 0-9.9ZM10 11a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" clip-rule="evenodd"/>
              </svg>
              {city}
            </li>
          ))}
        </ul>

        <!-- Not seeing your city? -->
        <div class="bg-navy-700 rounded-2xl p-6 text-white">
          <p class="font-body font-semibold mb-1">Don't see your city?</p>
          <p class="text-slate-300 text-sm mb-4">Give us a call — we often serve surrounding areas too.</p>
          <a
            href={business.phoneHref}
            class="inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-600 text-white font-body font-bold px-5 py-2.5 rounded-lg transition-all"
            aria-label={`Call us at ${business.phone}`}
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
            </svg>
            {business.phone}
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
