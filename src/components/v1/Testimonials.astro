---
import { business } from '../../data/v1';
---

<section
  id="reviews"
  class="relative py-20 lg:py-28"
  style="background:#f1f5f9;"
  aria-labelledby="reviews-heading"
>
  <!-- Top heavy rule — orange + navy -->
  <div class="absolute top-0 left-0 right-0 flex" aria-hidden="true">
    <div class="h-2 flex-1" style="background:#f97316;"></div>
    <div class="h-2 flex-1" style="background:#0f2855;"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Header row -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-14">
      <div>
        <div class="flex items-center gap-3 mb-3" aria-hidden="true">
          <div class="h-px w-12" style="background:#f97316;"></div>
          <span class="font-body font-bold text-xs uppercase tracking-widest" style="color:#f97316;">
            Real Customers
          </span>
        </div>
        <h2
          id="reviews-heading"
          class="font-display font-black uppercase leading-none"
          style="font-size: clamp(2.5rem, 6vw, 4.5rem); color:#0f2855; letter-spacing:-0.02em;"
        >
          WHAT SAN DIEGO<br/>
          <span style="color:#f97316;">IS SAYING</span>
        </h2>
      </div>

      <!-- Aggregate rating block — bold box -->
      <div
        class="flex-shrink-0 flex items-center gap-4 p-5"
        style="background:#0f2855; border-left:4px solid #f97316;"
      >
        <div>
          <div
            class="font-display font-black text-white leading-none"
            style="font-size:3rem; color:#f97316;"
          >4.9</div>
          <div class="flex gap-0.5 mt-1" aria-label="4.9 out of 5 stars">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4" fill="#f97316" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
        </div>
        <div class="border-l border-white/20 pl-4">
          <p class="font-display font-black uppercase text-white text-sm leading-none">GOOGLE</p>
          <p class="font-body text-white/50 text-xs mt-0.5">200+ Reviews</p>
        </div>
      </div>
    </div>

    <!-- Carousel wrapper -->
    <div
      class="relative"
      aria-roledescription="carousel"
      aria-label="Customer testimonials"
    >
      <!-- Arrow buttons — left -->
      <button
        id="prev-review"
        class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 lg:-translate-x-8 z-10 w-12 h-12 flex items-center justify-center text-white transition-all hover:opacity-90 focus:outline-none"
        style="background:#0f2855; border-radius:0;"
        aria-label="Previous testimonial"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/>
        </svg>
      </button>

      <!-- Overflow container -->
      <div id="review-carousel" class="overflow-hidden">
        <div
          id="review-track"
          class="flex transition-transform duration-500 ease-out"
        >
          {business.testimonials.map((review, i) => (
            <div
              class="flex-shrink-0 px-3"
              style="width: calc(100% / 3);"
              role="group"
              aria-roledescription="slide"
              aria-label={`Testimonial ${i + 1} of ${business.testimonials.length}`}
            >
              <article
                class="h-full flex flex-col"
                style="background:#fff; border:1px solid #e2e8f0; border-top:3px solid #f97316;"
              >
                <!-- Star rating bar -->
                <div class="flex items-center gap-3 px-6 pt-5 pb-4" style="border-bottom:1px solid #f1f5f9;">
                  <div class="flex gap-0.5" role="img" aria-label={`${review.rating} stars`}>
                    {Array.from({ length: review.rating }).map(() => (
                      <svg class="w-5 h-5" fill="#f97316" viewBox="0 0 20 20" aria-hidden="true">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                      </svg>
                    ))}
                  </div>
                  <span class="font-display font-black text-sm uppercase tracking-wide" style="color:#0f2855;">
                    VERIFIED
                  </span>
                </div>

                <!-- Quote body -->
                <blockquote class="flex-1 px-6 py-5">
                  <!-- Big quote mark -->
                  <div
                    class="font-display font-black leading-none mb-2 select-none"
                    style="font-size:4rem; color:#f97316; line-height:0.8;"
                    aria-hidden="true"
                  >"</div>
                  <p class="font-body text-base leading-relaxed" style="color:#334155;">
                    {review.text}
                  </p>
                </blockquote>

                <!-- Author footer -->
                <footer
                  class="flex items-center gap-3 px-6 py-4"
                  style="background:#f8fafc; border-top:1px solid #e2e8f0;"
                >
                  <!-- Initial avatar — sharp square -->
                  <div
                    class="w-10 h-10 flex items-center justify-center font-display font-black text-white text-lg flex-shrink-0"
                    style="background:#0f2855;"
                    aria-hidden="true"
                  >
                    {review.name.charAt(0)}
                  </div>
                  <div class="flex-1 min-w-0">
                    <cite class="not-italic font-display font-black uppercase text-sm leading-none" style="color:#0f2855;">
                      {review.name}
                    </cite>
                    <p class="font-body text-xs mt-0.5" style="color:#64748b;">
                      {review.neighborhood}, San Diego County
                    </p>
                  </div>
                </footer>
              </article>
            </div>
          ))}
        </div>
      </div>

      <!-- Arrow button — right -->
      <button
        id="next-review"
        class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 lg:translate-x-8 z-10 w-12 h-12 flex items-center justify-center text-white transition-all hover:opacity-90 focus:outline-none"
        style="background:#f97316; border-radius:0;"
        aria-label="Next testimonial"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
        </svg>
      </button>
    </div>

    <!-- Dot indicators -->
    <div class="flex items-center justify-center gap-2 mt-8" role="tablist" aria-label="Testimonial pages">
      {business.testimonials.map((_, i) => (
        <button
          class="review-dot transition-all focus:outline-none"
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-label={`Go to testimonial ${i + 1}`}
          data-index={i}
          style={`
            width: ${i === 0 ? '2rem' : '0.5rem'};
            height: 0.5rem;
            background: ${i === 0 ? '#f97316' : 'rgba(15,40,85,0.2)'};
            border-radius: 0;
            border: none;
            cursor: pointer;
          `}
        />
      ))}
    </div>
  </div>
</section>

<style>
  /* Responsive: 1 column on mobile, 2 on sm, 3 on lg */
  #review-track > div {
    width: 100%;
  }
  @media (min-width: 640px) {
    #review-track > div {
      width: 50%;
    }
  }
  @media (min-width: 1024px) {
    #review-track > div {
      width: calc(100% / 3);
    }
  }
</style>

<script>
  const track = document.getElementById('review-track') as HTMLDivElement | null;
  const prevBtn = document.getElementById('prev-review');
  const nextBtn = document.getElementById('next-review');
  const dots = document.querySelectorAll<HTMLButtonElement>('.review-dot');
  const total = document.querySelectorAll('#review-track > div').length;

  // Determine visible count based on viewport
  function getVisible(): number {
    if (window.innerWidth >= 1024) return 3;
    if (window.innerWidth >= 640) return 2;
    return 1;
  }

  let current = 0;

  function goTo(index: number) {
    const vis = getVisible();
    const max = total - vis;
    current = Math.max(0, Math.min(index, max));
    const pct = (100 / total) * current;
    if (track) track.style.transform = `translateX(-${pct}%)`;

    dots.forEach((dot, i) => {
      const active = i === current;
      dot.style.width = active ? '2rem' : '0.5rem';
      dot.style.background = active ? '#f97316' : 'rgba(15,40,85,0.2)';
      dot.setAttribute('aria-selected', active ? 'true' : 'false');
    });
  }

  prevBtn?.addEventListener('click', () => goTo(current - 1));
  nextBtn?.addEventListener('click', () => goTo(current + 1));
  dots.forEach(dot => {
    dot.addEventListener('click', () => goTo(Number(dot.dataset.index)));
  });

  window.addEventListener('resize', () => goTo(current));

  // Auto-advance every 5s
  setInterval(() => {
    const vis = getVisible();
    goTo(current + 1 > total - vis ? 0 : current + 1);
  }, 5000);
</script>
