---
import { business } from '../../data/v1';
---

<section id="reviews" class="relative bg-slate-50 py-20 lg:py-28" aria-labelledby="reviews-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Section header -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-12">
      <div>
        <span class="inline-block text-orange-500 font-body font-semibold text-sm uppercase tracking-widest mb-3">
          Real Customers
        </span>
        <h2
          id="reviews-heading"
          class="font-display font-black uppercase text-navy-700"
          style="font-size: clamp(2rem, 4.5vw, 3.5rem);"
        >
          What San Diego Says
        </h2>
      </div>
      <!-- Google aggregate badge -->
      <div class="flex-shrink-0 flex items-center gap-3 bg-white border border-slate-200 rounded-xl px-5 py-3 shadow-sm">
        <svg class="w-6 h-6 flex-shrink-0" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        <div>
          <div class="text-navy-700 font-body font-bold text-sm leading-none">4.9 / 5.0</div>
          <div class="text-slate-500 text-xs leading-none mt-0.5">200+ Google Reviews</div>
        </div>
        <div class="flex gap-0.5" aria-label="4.9 out of 5 stars">
          {[1,2,3,4,5].map(() => (
            <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>
      </div>
    </div>

    <!-- Testimonial cards grid -->
    <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" role="list" aria-label="Customer testimonials">
      {business.testimonials.map((review) => (
        <li>
          <article class="h-full bg-white border border-slate-200 rounded-2xl p-6 hover:shadow-lg hover:border-orange-200 transition-all duration-300 flex flex-col">
            <!-- Stars -->
            <div class="flex gap-1 mb-4" role="img" aria-label={`${review.rating} out of 5 stars`}>
              {Array.from({ length: review.rating }).map(() => (
                <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>

            <!-- Quote -->
            <blockquote class="text-slate-700 font-body leading-relaxed text-[0.95rem] flex-1 mb-5">
              <span class="text-orange-500 text-3xl font-serif leading-none mr-1" aria-hidden="true">"</span>{review.text}<span class="text-orange-500 text-3xl font-serif leading-none ml-1" aria-hidden="true">"</span>
            </blockquote>

            <!-- Author -->
            <footer class="flex items-center gap-3 pt-4 border-t border-slate-100">
              <div
                class="w-10 h-10 rounded-full bg-navy-700 flex items-center justify-center text-orange-400 font-display font-black text-lg flex-shrink-0"
                aria-hidden="true"
              >
                {review.name.charAt(0)}
              </div>
              <div>
                <cite class="not-italic font-body font-bold text-navy-700 text-sm leading-none">{review.name}</cite>
                <p class="text-slate-500 text-xs mt-0.5">{review.neighborhood}, San Diego County</p>
              </div>
              <!-- Verified badge -->
              <div class="ml-auto flex-shrink-0">
                <span class="inline-flex items-center gap-1 text-xs text-emerald-600 font-body font-semibold bg-emerald-50 px-2 py-1 rounded-full">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  Verified
                </span>
              </div>
            </footer>
          </article>
        </li>
      ))}
    </ul>
  </div>
</section>
