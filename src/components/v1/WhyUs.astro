---
import { business } from '../../data/v1';

const pillarIcons = [
  // Dollar / upfront pricing
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v2M12 16v2M9 9.5A2.5 2.5 0 0 1 12 7a2.5 2.5 0 0 1 0 5 2.5 2.5 0 0 0 0 5 2.5 2.5 0 0 1-3-2.5"/></svg>`,
  // License / badge
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`,
  // Guarantee / shield-check
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>`,
  // Clock / same-day
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
];
---

<section id="why-us" class="relative bg-navy-700 py-20 lg:py-28" aria-labelledby="why-us-heading">
  <!-- Top accent line -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-orange-500/40 to-transparent" aria-hidden="true"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Section header -->
    <div class="text-center mb-14">
      <span class="inline-block text-orange-500 font-body font-semibold text-sm uppercase tracking-widest mb-3">
        Our Promise
      </span>
      <h2
        id="why-us-heading"
        class="font-display font-black uppercase text-white mb-4"
        style="font-size: clamp(2.25rem, 5vw, 3.75rem);"
      >
        Why San Diego Chooses Us
      </h2>
      <p class="text-slate-400 font-body max-w-xl mx-auto text-lg">
        Every plumber will fix your pipe. We fix it, explain it, price it fairly, and stand behind it.
      </p>
    </div>

    <!-- 4 pillars grid -->
    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6" role="list" aria-label="Why choose us">
      {business.whyUs.map((pillar, i) => (
        <li class="pillar-card group relative bg-navy-800 border border-white/8 rounded-2xl p-7 hover:border-orange-500/30 transition-all duration-300 overflow-hidden">
          <!-- Orange top border accent -->
          <div class="absolute top-0 left-6 right-6 h-0.5 bg-orange-500 rounded-full" aria-hidden="true"></div>

          <!-- Icon -->
          <div class="w-16 h-16 rounded-2xl bg-orange-500/15 border border-orange-500/25 flex items-center justify-center mb-5 text-orange-400 group-hover:bg-orange-500/25 group-hover:text-orange-300 transition-all">
            <span set:html={pillarIcons[i]} aria-hidden="true" />
          </div>

          <!-- Content -->
          <h3 class="font-display font-black uppercase text-white text-2xl leading-tight mb-1">
            {pillar.title}
          </h3>
          <p class="text-orange-400 font-body font-semibold text-sm mb-3">{pillar.subtitle}</p>
          <p class="text-slate-400 font-body text-sm leading-relaxed group-hover:text-slate-300 transition-colors">
            {pillar.description}
          </p>

          <!-- Subtle number watermark -->
          <div class="absolute bottom-4 right-5 font-display font-black text-6xl text-white/[0.04] select-none leading-none" aria-hidden="true">
            {i + 1}
          </div>
        </li>
      ))}
    </ul>

    <!-- Stat strip -->
    <div class="mt-14 grid grid-cols-2 lg:grid-cols-4 gap-4">
      {[
        { stat: '4,200+', label: 'Jobs Completed' },
        { stat: '17 yrs', label: 'In Business' },
        { stat: '4.9★', label: 'Average Rating' },
        { stat: '< 60 min', label: 'Response Time' },
      ].map(item => (
        <div class="text-center bg-white/5 border border-white/8 rounded-xl py-5 px-3">
          <div class="font-display font-black text-orange-500 leading-none mb-1"
            style="font-size: clamp(1.75rem, 3vw, 2.5rem);">{item.stat}</div>
          <div class="text-slate-400 font-body text-sm">{item.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom wave -->
  <div class="absolute bottom-0 left-0 right-0 overflow-hidden leading-none pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 1440 50" preserveAspectRatio="none" class="w-full h-[50px]">
      <path d="M0,50 L0,25 Q360,0 720,25 Q1080,50 1440,15 L1440,50 Z" fill="#f8fafc"/>
    </svg>
  </div>
</section>
