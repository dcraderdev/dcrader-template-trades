---
import { business } from '../../data/v1';

// Credentials — what a licensed San Diego plumber actually carries
const credentials = [
  {
    title: 'CA Contractors License',
    code: 'C-36 #1018442',
    note: 'Plumbing classification · active & verified',
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M3 7h18v12a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"/><path d="M3 7l2-4h14l2 4"/><path d="M9 12h6"/></svg>`,
  },
  {
    title: 'BBB Accredited · A+',
    code: 'Accredited 2011',
    note: 'San Diego chapter — zero unresolved complaints',
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M12 2l8 4v6c0 5-3.5 9-8 10-4.5-1-8-5-8-10V6l8-4z"/><path d="M9 12l2 2 4-4"/></svg>`,
  },
  {
    title: '$2M General Liability',
    code: 'Hartford · Policy 88142-CA',
    note: 'Plus $1M auto · proof faxed before any job',
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>`,
  },
  {
    title: 'IAPMO Certified',
    code: 'Member since 2009',
    note: 'Backflow prevention · gas piping endorsed',
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M12 2l3 5 5 1-4 4 1 5-5-3-5 3 1-5-4-4 5-1 3-5z"/></svg>`,
  },
  {
    title: 'Workers\' Comp on File',
    code: 'State Fund · current',
    note: 'Every tech covered · zero pass-through liability for you',
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M16 11V7a4 4 0 0 0-8 0v4"/><rect x="5" y="11" width="14" height="10" rx="2"/></svg>`,
  },
  {
    title: 'CSLB Verified',
    code: 'cslb.ca.gov · lookup #1018442',
    note: 'License lookup is public — please check before you hire anyone',
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><circle cx="11" cy="11" r="6"/><path d="m20 20-4.5-4.5"/></svg>`,
  },
];

const pillarIcons = [
  `<svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v2M12 16v2M9 9.5A2.5 2.5 0 0 1 12 7a2.5 2.5 0 0 1 0 5 2.5 2.5 0 0 0 0 5 2.5 2.5 0 0 1-3-2.5"/></svg>`,
  `<svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`,
  `<svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>`,
  `<svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
];
---

<section
  id="why-us"
  class="relative py-20 lg:py-28"
  style="background:#0f2855;"
  aria-labelledby="why-us-heading"
>
  <!-- Top rule -->
  <div class="absolute top-0 left-0 right-0 h-1" style="background:#f97316;" aria-hidden="true"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Section label -->
    <div class="mb-4 flex items-center gap-3" aria-hidden="true">
      <div class="h-px w-12" style="background:#f97316;"></div>
      <span class="font-body font-bold text-xs uppercase tracking-widest" style="color:#f97316;">
        Our Promise
      </span>
    </div>

    <h2
      id="why-us-heading"
      class="font-display font-black uppercase text-white leading-none mb-16"
      style="font-size: clamp(2.75rem, 7vw, 5.5rem); letter-spacing:-0.02em;"
    >
      WHY SAN DIEGO<br/>
      <span style="color:#f97316;">CHOOSES US</span>
    </h2>

    <!-- CREDENTIAL & LICENSE BOARD — what you can verify before we ever touch a pipe -->
    <div class="mb-16">
      <!-- Eyebrow row -->
      <div class="flex flex-wrap items-end justify-between gap-3 mb-5">
        <p
          class="font-display font-black uppercase text-white tracking-wide"
          style="font-size:1.35rem; letter-spacing:0.04em;"
        >
          Paperwork before the wrench
        </p>
        <p class="font-body text-xs uppercase tracking-widest" style="color:rgba(255,255,255,0.45); letter-spacing:0.18em;">
          Every credential below is verifiable by phone or web
        </p>
      </div>

      <ul
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3"
        style="border:1px solid rgba(249,115,22,0.25);"
        role="list"
        aria-label="Licenses, insurance, and credentials"
      >
        {credentials.map((c, i) => (
          <li
            class="relative flex gap-4 p-6"
            style={`
              border-right: ${(i % 3) !== 2 ? '1px solid rgba(249,115,22,0.15)' : 'none'};
              border-bottom: ${i < credentials.length - 3 ? '1px solid rgba(249,115,22,0.15)' : 'none'};
            `}
            role="listitem"
          >
            <!-- Credential icon stamp -->
            <div
              class="w-11 h-11 flex items-center justify-center flex-shrink-0 text-orange-400"
              style="background:rgba(249,115,22,0.10); border:1px solid rgba(249,115,22,0.35);"
            >
              <span set:html={c.svg} aria-hidden="true" />
            </div>

            <div class="flex-1 min-w-0">
              <p
                class="font-display font-black uppercase text-white leading-tight"
                style="font-size:0.95rem; letter-spacing:0.04em;"
              >
                {c.title}
              </p>
              <p class="font-body font-bold text-xs tracking-widest mt-1" style="color:#f97316; letter-spacing:0.15em;">
                {c.code}
              </p>
              <p class="font-body text-xs leading-relaxed mt-2" style="color:rgba(255,255,255,0.55);">
                {c.note}
              </p>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <!-- 4 Pillars — left-aligned horizontal layout, each with a left orange border -->
    <ul
      class="grid grid-cols-1 lg:grid-cols-2 gap-0"
      style="border:1px solid rgba(255,255,255,0.08);"
      role="list"
      aria-label="Why choose us"
    >
      {business.whyUs.map((pillar, i) => (
        <li
          class="relative flex gap-5 p-7 transition-colors"
          style={`
            border-right: ${i % 2 === 0 ? '1px solid rgba(255,255,255,0.08)' : 'none'};
            border-bottom: ${i < 2 ? '1px solid rgba(255,255,255,0.08)' : 'none'};
            border-left: 4px solid #f97316;
          `}
          onmouseover="this.style.background='rgba(249,115,22,0.04)'"
          onmouseout="this.style.background='transparent'"
        >
          <!-- Icon box -->
          <div
            class="w-12 h-12 flex items-center justify-center flex-shrink-0 text-orange-400"
            style="background:rgba(249,115,22,0.12); border:1px solid rgba(249,115,22,0.25);"
          >
            <span set:html={pillarIcons[i]} aria-hidden="true" />
          </div>

          <!-- Content -->
          <div class="flex-1 min-w-0">
            <h3
              class="font-display font-black uppercase text-white leading-tight mb-0.5"
              style="font-size:1.35rem; letter-spacing:0.02em;"
            >
              {pillar.title}
            </h3>
            <p class="font-body font-bold text-xs uppercase tracking-widest mb-2" style="color:#f97316;">
              {pillar.subtitle}
            </p>
            <p class="font-body text-sm leading-relaxed" style="color:rgba(255,255,255,0.55);">
              {pillar.description}
            </p>
          </div>
        </li>
      ))}
    </ul>

    <!-- Emergency CTA strip -->
    <div
      class="mt-12 flex flex-col sm:flex-row items-center justify-between gap-4 px-7 py-5"
      style="background:#f97316;"
    >
      <div>
        <p class="font-display font-black uppercase text-white text-2xl leading-none">
          PLUMBING EMERGENCY? DON'T WAIT.
        </p>
        <p class="font-body text-sm text-white/80 mt-0.5">
          We answer 24 hours a day, every day of the year.
        </p>
      </div>
      <a
        href={business.phoneHref}
        class="inline-flex items-center gap-3 font-display font-black uppercase text-white text-xl tracking-wide flex-shrink-0 px-6 py-3 transition-opacity hover:opacity-90"
        style="background:#0f2855; border-radius:0;"
        aria-label={`Call us at ${business.phone}`}
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
        </svg>
        {business.phone}
      </a>
    </div>
  </div>
</section>
