---
import { business } from '../../data/v2';
---

<section
  class="relative min-h-[100svh] flex flex-col justify-center overflow-hidden"
  aria-labelledby="hero-heading"
>
  <!-- Dot-grid background -->
  <div class="absolute inset-0 hero-bg" aria-hidden="true"></div>

  <!-- Teal radial glow top-right -->
  <div
    class="absolute top-0 right-0 w-[60vw] h-[60vh] pointer-events-none"
    style="background: radial-gradient(ellipse 70% 60% at 100% 0%, rgba(45,212,191,0.07) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <!-- Blue radial glow bottom-left -->
  <div
    class="absolute bottom-0 left-0 w-[40vw] h-[50vh] pointer-events-none"
    style="background: radial-gradient(ellipse 60% 50% at 0% 100%, rgba(59,130,246,0.05) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 w-full pt-28 pb-20">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">

      <!-- ── Left: content ──────────────────────────────────────────────── -->
      <div>
        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-2.5 mb-8 rounded-full px-4 py-1.5"
          style="background: rgba(45,212,191,0.08); border: 1px solid rgba(45,212,191,0.25);">
          <span class="w-2 h-2 rounded-full bg-[#2dd4bf] animate-pulse flex-shrink-0" aria-hidden="true"></span>
          <span class="font-mono text-[#2dd4bf] text-xs tracking-widest uppercase">{business.hero.eyebrow}</span>
        </div>

        <!-- Headline -->
        <h1 id="hero-heading" class="font-sora font-extrabold leading-[1.0] mb-5">
          <span class="block text-white" style="font-size: clamp(2.75rem, 7vw, 5.5rem);">
            {business.hero.headlineLine1}
          </span>
          <span class="block" style="font-size: clamp(2.75rem, 7vw, 5.5rem); background: linear-gradient(135deg, #2dd4bf 0%, #3b82f6 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
            {business.hero.headlineLine2}
          </span>
        </h1>

        <!-- Subheadline -->
        <p class="font-mono text-[#2dd4bf]/70 text-sm tracking-widest uppercase mb-4">
          {business.hero.subheadline}
        </p>
        <p class="font-sora text-slate-400 text-lg leading-relaxed mb-10 max-w-xl">
          {business.hero.description}
        </p>

        <!-- Phone — terminal style -->
        <a
          href={business.phoneHref}
          class="group inline-flex items-center gap-3 mb-10 p-1 -m-1 rounded-xl hover:bg-[#2dd4bf]/5 transition-colors"
          aria-label={`Call us at ${business.phone}`}
        >
          <span
            class="font-mono font-bold text-[#2dd4bf] group-hover:text-white transition-colors"
            style="font-size: clamp(1.75rem, 4.5vw, 3rem);"
          >
            &gt;_ {business.phone}
          </span>
          <span class="terminal-cursor" aria-hidden="true"></span>
        </a>

        <!-- CTA buttons -->
        <div class="flex flex-wrap gap-4 mb-12">
          <a
            href="#quote"
            class="inline-flex items-center gap-2 font-sora font-semibold rounded-xl transition-all hover:scale-[1.02] active:scale-100"
            style="font-size: clamp(0.95rem, 1.5vw, 1.1rem); padding: 0.875rem 2rem; background: #2dd4bf; color: #080e1a; box-shadow: 0 8px 32px rgba(45,212,191,0.3);"
          >
            {business.hero.cta}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
            </svg>
          </a>
          <a
            href="#services"
            class="inline-flex items-center gap-2 font-sora font-semibold text-slate-300 hover:text-[#2dd4bf] rounded-xl transition-all"
            style="font-size: clamp(0.95rem, 1.5vw, 1.1rem); padding: 0.875rem 2rem; border: 1px solid rgba(45,212,191,0.25); hover:border-color: rgba(45,212,191,0.5);"
          >
            {business.hero.ctaSecondary}
          </a>
        </div>

        <!-- Stat line -->
        <p class="font-mono text-xs text-slate-500 tracking-widest uppercase border-l-2 border-[#2dd4bf]/30 pl-4">
          {business.hero.statLine}
        </p>

        <!-- Trust badges -->
        <div class="flex flex-wrap gap-3 mt-8" role="list" aria-label="Trust certifications">
          {business.badges.map((badge) => (
            <div
              class="flex items-center gap-2.5 rounded-lg px-3.5 py-2.5"
              style="background: rgba(13,21,39,0.8); border: 1px solid rgba(45,212,191,0.15);"
              role="listitem"
            >
              <svg class="w-3.5 h-3.5 text-[#2dd4bf] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
              </svg>
              <div>
                <div class="font-sora font-semibold text-white text-xs leading-none">{badge.label}</div>
                <div class="font-mono text-[10px] text-slate-500 leading-none mt-0.5 tracking-wider">{badge.sublabel}</div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- ── Right: circuit SVG decoration ─────────────────────────────── -->
      <div class="hidden lg:flex items-center justify-center relative" aria-hidden="true">
        <!-- Outer glow ring -->
        <div
          class="absolute w-[420px] h-[420px] rounded-full"
          style="background: radial-gradient(circle, rgba(45,212,191,0.06) 0%, transparent 70%); border: 1px solid rgba(45,212,191,0.06);"
        ></div>

        <svg
          viewBox="0 0 480 480"
          class="w-[440px] h-[440px] relative z-10"
          role="img"
          aria-label="Circuit board diagram representing smart home technology"
          fill="none"
          stroke="#2dd4bf"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <!-- Background subtle grid -->
          <defs>
            <pattern id="microgrid" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
              <circle cx="20" cy="20" r="1" fill="rgba(45,212,191,0.12)"/>
            </pattern>
            <filter id="glow-filter">
              <feGaussianBlur stdDeviation="2" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <filter id="glow-strong">
              <feGaussianBlur stdDeviation="3" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>

          <rect width="480" height="480" fill="url(#microgrid)" stroke="none"/>

          <!-- ── Main circuit traces ─────────────────────────────────── -->

          <!-- Horizontal backbone, upper -->
          <line x1="60" y1="120" x2="420" y2="120" stroke="#2dd4bf" stroke-width="1.5" stroke-opacity="0.3"/>
          <!-- Vertical left spine -->
          <line x1="60" y1="80" x2="60" y2="400" stroke="#2dd4bf" stroke-width="1.5" stroke-opacity="0.3"/>
          <!-- Vertical right spine -->
          <line x1="420" y1="80" x2="420" y2="400" stroke="#2dd4bf" stroke-width="1.5" stroke-opacity="0.3"/>
          <!-- Horizontal backbone, lower -->
          <line x1="60" y1="360" x2="420" y2="360" stroke="#2dd4bf" stroke-width="1.5" stroke-opacity="0.3"/>

          <!-- ── Bright active traces ─────────────────────────────── -->

          <!-- Top-left L-trace -->
          <polyline points="60,120 60,80 140,80" stroke="#2dd4bf" stroke-width="2" stroke-opacity="0.8" filter="url(#glow-filter)"/>

          <!-- Right L-trace upper -->
          <polyline points="420,120 420,80 340,80" stroke="#2dd4bf" stroke-width="2" stroke-opacity="0.8" filter="url(#glow-filter)"/>

          <!-- Center horizontal through core -->
          <line x1="140" y1="240" x2="340" y2="240" stroke="#2dd4bf" stroke-width="2.5" stroke-opacity="0.9" filter="url(#glow-filter)"/>

          <!-- Left side vertical to center -->
          <polyline points="60,200 100,200 100,240" stroke="#2dd4bf" stroke-width="2" stroke-opacity="0.7"/>
          <!-- Left side branch down -->
          <polyline points="60,280 100,280 100,240" stroke="#2dd4bf" stroke-width="2" stroke-opacity="0.7"/>

          <!-- Right side vertical to center -->
          <polyline points="420,200 380,200 380,240" stroke="#2dd4bf" stroke-width="2" stroke-opacity="0.7"/>
          <!-- Right side branch down -->
          <polyline points="420,280 380,280 380,240" stroke="#2dd4bf" stroke-width="2" stroke-opacity="0.7"/>

          <!-- Diagonal data paths upper -->
          <polyline points="160,80 160,160 240,160 240,240" stroke="#3b82f6" stroke-width="1.75" stroke-opacity="0.7" filter="url(#glow-filter)"/>
          <polyline points="320,80 320,160 240,160" stroke="#3b82f6" stroke-width="1.75" stroke-opacity="0.7" filter="url(#glow-filter)"/>

          <!-- Diagonal data paths lower -->
          <polyline points="160,400 160,320 240,320 240,240" stroke="#3b82f6" stroke-width="1.75" stroke-opacity="0.6" filter="url(#glow-filter)"/>
          <polyline points="320,400 320,320 240,320" stroke="#3b82f6" stroke-width="1.75" stroke-opacity="0.6" filter="url(#glow-filter)"/>

          <!-- Bottom left L -->
          <polyline points="60,360 60,400 140,400" stroke="#2dd4bf" stroke-width="2" stroke-opacity="0.8" filter="url(#glow-filter)"/>
          <!-- Bottom right L -->
          <polyline points="420,360 420,400 340,400" stroke="#2dd4bf" stroke-width="2" stroke-opacity="0.8" filter="url(#glow-filter)"/>

          <!-- Mid-horizontal branches -->
          <line x1="60" y1="200" x2="60" y2="280" stroke="#2dd4bf" stroke-width="1.5" stroke-opacity="0.4"/>
          <line x1="420" y1="200" x2="420" y2="280" stroke="#2dd4bf" stroke-width="1.5" stroke-opacity="0.4"/>

          <!-- Smaller internal traces -->
          <polyline points="180,160 180,200 140,200 140,240" stroke="#2dd4bf" stroke-width="1.25" stroke-opacity="0.4"/>
          <polyline points="300,160 300,200 340,200 340,240" stroke="#2dd4bf" stroke-width="1.25" stroke-opacity="0.4"/>
          <polyline points="180,320 180,280 140,280 140,240" stroke="#2dd4bf" stroke-width="1.25" stroke-opacity="0.4"/>
          <polyline points="300,320 300,280 340,280 340,240" stroke="#2dd4bf" stroke-width="1.25" stroke-opacity="0.4"/>

          <!-- Tick marks on backbone lines (resistor-like) -->
          <line x1="200" y1="114" x2="200" y2="126" stroke="#2dd4bf" stroke-width="1.5" stroke-opacity="0.5"/>
          <line x1="280" y1="114" x2="280" y2="126" stroke="#2dd4bf" stroke-width="1.5" stroke-opacity="0.5"/>
          <line x1="200" y1="354" x2="200" y2="366" stroke="#2dd4bf" stroke-width="1.5" stroke-opacity="0.5"/>
          <line x1="280" y1="354" x2="280" y2="366" stroke="#2dd4bf" stroke-width="1.5" stroke-opacity="0.5"/>

          <!-- ── Node circles ─────────────────────────────────────── -->

          <!-- Corner nodes -->
          <circle cx="60" cy="80" r="5" fill="#0d1527" stroke="#2dd4bf" stroke-width="2" filter="url(#glow-filter)"/>
          <circle cx="420" cy="80" r="5" fill="#0d1527" stroke="#2dd4bf" stroke-width="2" filter="url(#glow-filter)"/>
          <circle cx="60" cy="400" r="5" fill="#0d1527" stroke="#2dd4bf" stroke-width="2" filter="url(#glow-filter)"/>
          <circle cx="420" cy="400" r="5" fill="#0d1527" stroke="#2dd4bf" stroke-width="2" filter="url(#glow-filter)"/>

          <!-- Intersection nodes on backbone -->
          <circle cx="60" cy="120" r="3.5" fill="#2dd4bf" stroke-opacity="0"/>
          <circle cx="420" cy="120" r="3.5" fill="#2dd4bf" stroke-opacity="0"/>
          <circle cx="60" cy="360" r="3.5" fill="#2dd4bf" stroke-opacity="0"/>
          <circle cx="420" cy="360" r="3.5" fill="#2dd4bf" stroke-opacity="0"/>

          <!-- Mid-spine nodes -->
          <circle cx="60" cy="200" r="3" fill="#0d1527" stroke="#2dd4bf" stroke-width="1.5"/>
          <circle cx="60" cy="280" r="3" fill="#0d1527" stroke="#2dd4bf" stroke-width="1.5"/>
          <circle cx="420" cy="200" r="3" fill="#0d1527" stroke="#2dd4bf" stroke-width="1.5"/>
          <circle cx="420" cy="280" r="3" fill="#0d1527" stroke="#2dd4bf" stroke-width="1.5"/>

          <!-- Junction nodes on data paths -->
          <circle cx="160" cy="80" r="3.5" fill="#3b82f6" stroke-opacity="0" filter="url(#glow-filter)"/>
          <circle cx="320" cy="80" r="3.5" fill="#3b82f6" stroke-opacity="0" filter="url(#glow-filter)"/>
          <circle cx="160" cy="400" r="3.5" fill="#3b82f6" stroke-opacity="0"/>
          <circle cx="320" cy="400" r="3.5" fill="#3b82f6" stroke-opacity="0"/>
          <circle cx="240" cy="160" r="4" fill="#0d1527" stroke="#3b82f6" stroke-width="1.5" filter="url(#glow-filter)"/>
          <circle cx="240" cy="320" r="4" fill="#0d1527" stroke="#3b82f6" stroke-width="1.5"/>
          <circle cx="140" cy="80" r="3" fill="#2dd4bf" stroke-opacity="0"/>
          <circle cx="340" cy="80" r="3" fill="#2dd4bf" stroke-opacity="0"/>
          <circle cx="140" cy="400" r="3" fill="#2dd4bf" stroke-opacity="0"/>
          <circle cx="340" cy="400" r="3" fill="#2dd4bf" stroke-opacity="0"/>

          <!-- Bus junction nodes on H/V -->
          <circle cx="100" cy="240" r="3" fill="#2dd4bf" stroke-opacity="0"/>
          <circle cx="380" cy="240" r="3" fill="#2dd4bf" stroke-opacity="0"/>
          <circle cx="140" cy="240" r="3.5" fill="#0d1527" stroke="#2dd4bf" stroke-width="1.5"/>
          <circle cx="340" cy="240" r="3.5" fill="#0d1527" stroke="#2dd4bf" stroke-width="1.5"/>

          <!-- ── Central core (main chip) ────────────────────────── -->
          <rect x="196" y="196" width="88" height="88" rx="8" fill="#0d1527" stroke="#2dd4bf" stroke-width="2" filter="url(#glow-strong)"/>

          <!-- Chip pin marks -->
          <line x1="215" y1="196" x2="215" y2="188" stroke="#2dd4bf" stroke-width="1.5" stroke-opacity="0.7"/>
          <line x1="240" y1="196" x2="240" y2="188" stroke="#2dd4bf" stroke-width="1.5" stroke-opacity="0.7"/>
          <line x1="265" y1="196" x2="265" y2="188" stroke="#2dd4bf" stroke-width="1.5" stroke-opacity="0.7"/>
          <line x1="215" y1="284" x2="215" y2="292" stroke="#2dd4bf" stroke-width="1.5" stroke-opacity="0.7"/>
          <line x1="240" y1="284" x2="240" y2="292" stroke="#2dd4bf" stroke-width="1.5" stroke-opacity="0.7"/>
          <line x1="265" y1="284" x2="265" y2="292" stroke="#2dd4bf" stroke-width="1.5" stroke-opacity="0.7"/>
          <line x1="196" y1="215" x2="188" y2="215" stroke="#2dd4bf" stroke-width="1.5" stroke-opacity="0.7"/>
          <line x1="196" y1="240" x2="188" y2="240" stroke="#2dd4bf" stroke-width="1.5" stroke-opacity="0.7"/>
          <line x1="196" y1="265" x2="188" y2="265" stroke="#2dd4bf" stroke-width="1.5" stroke-opacity="0.7"/>
          <line x1="284" y1="215" x2="292" y2="215" stroke="#2dd4bf" stroke-width="1.5" stroke-opacity="0.7"/>
          <line x1="284" y1="240" x2="292" y2="240" stroke="#2dd4bf" stroke-width="1.5" stroke-opacity="0.7"/>
          <line x1="284" y1="265" x2="292" y2="265" stroke="#2dd4bf" stroke-width="1.5" stroke-opacity="0.7"/>

          <!-- Chip center bolt icon -->
          <path d="M232 228l8-12h6l-4 8h8l-10 16h-6l4-8h-6z" fill="#2dd4bf" stroke="none" opacity="0.9"/>

          <!-- Corner chip marks -->
          <path d="M200 200 l8 0 l0 8" fill="none" stroke="#2dd4bf" stroke-width="1" stroke-opacity="0.5"/>
          <path d="M280 200 l-8 0 l0 8" fill="none" stroke="#2dd4bf" stroke-width="1" stroke-opacity="0.5"/>
          <path d="M200 280 l8 0 l0 -8" fill="none" stroke="#2dd4bf" stroke-width="1" stroke-opacity="0.5"/>
          <path d="M280 280 l-8 0 l0 -8" fill="none" stroke="#2dd4bf" stroke-width="1" stroke-opacity="0.5"/>

          <!-- ── Animated pulse rings (CSS animation) ──────────────── -->
          <circle cx="240" cy="240" r="60" fill="none" stroke="#2dd4bf" stroke-width="0.75" stroke-opacity="0.15" class="pulse-ring-1"/>
          <circle cx="240" cy="240" r="90" fill="none" stroke="#2dd4bf" stroke-width="0.5" stroke-opacity="0.08" class="pulse-ring-2"/>

          <!-- Small satellite nodes -->
          <circle cx="160" cy="200" r="4" fill="#0d1527" stroke="#2dd4bf" stroke-width="1.5"/>
          <circle cx="160" cy="280" r="4" fill="#0d1527" stroke="#2dd4bf" stroke-width="1.5"/>
          <circle cx="320" cy="200" r="4" fill="#0d1527" stroke="#2dd4bf" stroke-width="1.5"/>
          <circle cx="320" cy="280" r="4" fill="#0d1527" stroke="#2dd4bf" stroke-width="1.5"/>
        </svg>

        <!-- Status indicators overlaid -->
        <div class="absolute top-10 right-8 flex flex-col gap-2 font-mono text-[10px] text-[#2dd4bf]/60 tracking-widest" aria-hidden="true">
          <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-[#2dd4bf] animate-pulse"></span>SYS ONLINE</span>
          <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-[#3b82f6] animate-pulse" style="animation-delay:0.5s"></span>EV NET ACTIVE</span>
          <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-[#2dd4bf] animate-pulse" style="animation-delay:1s"></span>GRID SYNC</span>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom fade -->
  <div
    class="absolute bottom-0 left-0 right-0 h-24 pointer-events-none"
    style="background: linear-gradient(to bottom, transparent, #080e1a);"
    aria-hidden="true"
  ></div>
</section>

<style>
  .hero-bg {
    background-color: #080e1a;
    background-image:
      radial-gradient(circle at 30px 30px, rgba(45,212,191,0.04) 1px, transparent 0),
      radial-gradient(circle at 30px 30px, rgba(59,130,246,0.02) 1px, transparent 0);
    background-size: 60px 60px, 30px 30px;
  }

  .terminal-cursor {
    display: inline-block;
    width: 3px;
    height: 1.2em;
    background: #2dd4bf;
    border-radius: 1px;
    animation: blink 1.1s step-end infinite;
    vertical-align: text-bottom;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .pulse-ring-1 {
    animation: ringExpand 3s ease-out infinite;
  }
  .pulse-ring-2 {
    animation: ringExpand 3s ease-out infinite 1.5s;
  }

  @keyframes ringExpand {
    0% { stroke-opacity: 0.2; transform-origin: center; transform: scale(0.85); }
    100% { stroke-opacity: 0; transform-origin: center; transform: scale(1.2); }
  }
</style>
