---
import { business } from '../../data/v2';
---

<!-- Mobile bottom call strip -->
<div
  class="fixed bottom-0 left-0 right-0 z-50 md:hidden"
  style="background: rgba(8,14,26,0.98); border-top: 1px solid rgba(45,212,191,0.18); backdrop-filter: blur(16px);"
  role="complementary"
  aria-label="Quick contact bar"
>
  <a
    href={business.phoneHref}
    class="flex items-center justify-center gap-2.5 py-3.5 active:bg-[#2dd4bf]/10 transition-colors"
    aria-label={`Call ${business.phone}`}
  >
    <span class="font-mono text-[10px] text-[#2dd4bf]/50 tracking-[0.2em] uppercase" aria-hidden="true">call now</span>
    <span class="font-mono font-bold text-[#2dd4bf] text-base tracking-tight">{business.phone}</span>
  </a>
</div>

<!-- Floating pill nav wrapper — centered, NOT full width -->
<div
  class="fixed top-0 left-0 right-0 z-40 flex justify-center pt-4 px-4 pointer-events-none"
  aria-label="Site header"
>
  <header
    id="v2-pill-nav"
    class="pointer-events-auto w-full transition-all duration-400"
    style="max-width: 900px;"
    role="banner"
  >
    <nav
      class="flex items-center justify-between gap-4 px-3 py-2.5"
      style="
        background: rgba(8,14,26,0.72);
        border: 1px solid rgba(45,212,191,0.22);
        border-radius: 999px;
        backdrop-filter: blur(20px) saturate(1.4);
        box-shadow: 0 4px 32px rgba(0,0,0,0.45), inset 0 1px 0 rgba(45,212,191,0.08);
      "
      aria-label="Primary navigation"
    >

      <!-- Logo -->
      <a
        href="/"
        class="flex items-center gap-2.5 flex-shrink-0 group pl-1"
        aria-label={`${business.name} — home`}
      >
        <div
          class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 transition-all duration-300 group-hover:shadow-[0_0_14px_rgba(45,212,191,0.5)]"
          style="background: linear-gradient(135deg, rgba(45,212,191,0.18), rgba(59,130,246,0.12)); border: 1px solid rgba(45,212,191,0.4);"
          aria-hidden="true"
        >
          <svg class="w-4 h-4 text-[#2dd4bf]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
          </svg>
        </div>
        <div class="hidden sm:block leading-none">
          <span class="block font-sora font-black text-white text-sm tracking-tight leading-none">{business.shortName}</span>
          <span class="block font-mono text-[9px] text-[#2dd4bf]/55 tracking-[0.18em] uppercase leading-none mt-0.5">Electric</span>
        </div>
      </a>

      <!-- Center nav links -->
      <ul class="hidden lg:flex items-center gap-0.5 list-none m-0 p-0 flex-1 justify-center" role="list">
        {[
          { label: 'Services', href: '/v2-modern-tech#services' },
          { label: 'Financing', href: '/v2-financing' },
          { label: 'Why Us', href: '/v2-modern-tech#why-us' },
          { label: 'Reviews', href: '/v2-modern-tech#reviews' },
          { label: 'Projects', href: '/v2-modern-tech#projects' },
        ].map(link => (
          <li>
            <a
              href={link.href}
              class="px-3.5 py-1.5 font-mono text-[11px] text-slate-400 hover:text-[#2dd4bf] rounded-full hover:bg-[#2dd4bf]/8 transition-all duration-200 tracking-widest uppercase"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Right: phone + CTA -->
      <div class="flex items-center gap-2 flex-shrink-0 pr-1">
        <a
          href={business.phoneHref}
          class="hidden md:block font-mono text-[11px] font-bold text-[#2dd4bf]/70 hover:text-[#2dd4bf] transition-colors tracking-tight whitespace-nowrap pr-1"
          aria-label={`Call us at ${business.phone}`}
        >
          {business.phone}
        </a>
        <a
          href="#quote"
          class="inline-flex items-center gap-1.5 font-mono font-bold text-[10px] text-[#080e1a] px-4 py-2 rounded-full transition-all duration-200 hover:shadow-[0_0_18px_rgba(45,212,191,0.45)] tracking-widest uppercase whitespace-nowrap"
          style="background: #2dd4bf;"
        >
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
          </svg>
          Get Quote
        </a>
      </div>
    </nav>
  </header>
</div>

<script>
  const nav = document.getElementById('v2-pill-nav');

  function syncNav() {
    const scrolled = window.scrollY > 20;
    if (!nav) return;
    const inner = nav.querySelector('nav') as HTMLElement | null;
    if (!inner) return;
    if (scrolled) {
      inner.style.background = 'rgba(8,14,26,0.92)';
      inner.style.boxShadow = '0 8px 48px rgba(0,0,0,0.65), inset 0 1px 0 rgba(45,212,191,0.12)';
    } else {
      inner.style.background = 'rgba(8,14,26,0.72)';
      inner.style.boxShadow = '0 4px 32px rgba(0,0,0,0.45), inset 0 1px 0 rgba(45,212,191,0.08)';
    }
  }

  window.addEventListener('scroll', syncNav, { passive: true });
  syncNav();
</script>
