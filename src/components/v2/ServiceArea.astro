---
import { business } from '../../data/v2';

const cities = business.serviceArea.cities;
const half = Math.ceil(cities.length / 2);
const col1 = cities.slice(0, half);
const col2 = cities.slice(half);
---

<section
  id="service-area"
  class="relative py-24 lg:py-32"
  style="background: #080e1a;"
  aria-labelledby="service-area-heading"
>
  <!-- Top accent -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#3b82f6]/20 to-transparent" aria-hidden="true"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-start">

      <!-- ── Left: headline + city grid ────────────────────────────────── -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <span class="font-mono text-[#2dd4bf] text-xs tracking-[0.2em] uppercase">// coverage</span>
          <div class="flex-1 h-px bg-[#2dd4bf]/15"></div>
        </div>

        <h2
          id="service-area-heading"
          class="font-sora font-extrabold text-white mb-3"
          style="font-size: clamp(2rem, 5vw, 3.25rem); line-height: 1.1;"
        >
          {business.serviceArea.headline}
        </h2>
        <p class="font-sora text-slate-400 text-lg mb-10">
          {business.serviceArea.subheadline}. Our crews are positioned across the Valley for fast dispatch.
        </p>

        <!-- City list: tech-grid style -->
        <div class="grid grid-cols-2 gap-0" role="list" aria-label="Cities we serve">
          <!-- Column 1 -->
          <ul class="list-none m-0 p-0 border-r border-[#111e3a]">
            {col1.map((city, i) => (
              <li
                class="flex items-center gap-3 py-3 px-4 border-b border-[#111e3a] group hover:bg-[#2dd4bf]/5 transition-colors"
                role="listitem"
              >
                <span class="font-mono text-[#2dd4bf]/30 text-[10px] w-4 flex-shrink-0 select-none" aria-hidden="true">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <svg class="w-3 h-3 text-[#2dd4bf]/50 flex-shrink-0 group-hover:text-[#2dd4bf] transition-colors" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 1 1 9.9 9.9L10 18.9l-4.95-4.95a7 7 0 0 1 0-9.9ZM10 11a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" clip-rule="evenodd"/>
                </svg>
                <span class="font-sora text-slate-300 text-sm group-hover:text-white transition-colors">{city}</span>
              </li>
            ))}
          </ul>
          <!-- Column 2 -->
          <ul class="list-none m-0 p-0">
            {col2.map((city, i) => (
              <li
                class="flex items-center gap-3 py-3 px-4 border-b border-[#111e3a] group hover:bg-[#2dd4bf]/5 transition-colors"
                role="listitem"
              >
                <span class="font-mono text-[#2dd4bf]/30 text-[10px] w-4 flex-shrink-0 select-none" aria-hidden="true">
                  {String(i + half + 1).padStart(2, '0')}
                </span>
                <svg class="w-3 h-3 text-[#2dd4bf]/50 flex-shrink-0 group-hover:text-[#2dd4bf] transition-colors" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 1 1 9.9 9.9L10 18.9l-4.95-4.95a7 7 0 0 1 0-9.9ZM10 11a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" clip-rule="evenodd"/>
                </svg>
                <span class="font-sora text-slate-300 text-sm group-hover:text-white transition-colors">{city}</span>
              </li>
            ))}
          </ul>
        </div>

        <p class="font-mono text-[10px] text-slate-600 tracking-widest mt-4 uppercase">
          {cities.length} cities · growing
        </p>
      </div>

      <!-- ── Right: tech-themed coverage display ──────────────────────── -->
      <div class="flex flex-col gap-6">
        <!-- Terminal-style header -->
        <div class="rounded-2xl overflow-hidden" style="border: 1px solid rgba(45,212,191,0.2); background: #0d1527;">
          <!-- Terminal title bar -->
          <div class="flex items-center gap-2 px-4 py-3 border-b border-[#111e3a]" aria-hidden="true">
            <span class="w-3 h-3 rounded-full bg-red-500/60"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-500/60"></span>
            <span class="w-3 h-3 rounded-full bg-[#2dd4bf]/60"></span>
            <span class="font-mono text-[11px] text-slate-600 ml-3 tracking-wider">coverage-map.sys</span>
          </div>

          <!-- Terminal content -->
          <div class="p-6 font-mono text-sm">
            <div class="text-[#2dd4bf] mb-1">&gt; query --region "Phoenix Metro" --status active</div>
            <div class="text-slate-500 mb-4 text-xs">Scanning coverage nodes...</div>

            <!-- Coverage stats -->
            <div class="grid grid-cols-2 gap-4 mb-6">
              {[
                { value: '16', label: 'cities covered' },
                { value: '~50mi', label: 'service radius' },
                { value: '< 24h', label: 'dispatch time' },
                { value: '7 days', label: 'scheduling' },
              ].map(stat => (
                <div class="p-3 rounded-lg" style="background: #080e1a; border: 1px solid rgba(45,212,191,0.1);">
                  <div class="text-[#2dd4bf] text-lg font-bold leading-none mb-1">{stat.value}</div>
                  <div class="text-slate-500 text-[11px] tracking-wider uppercase">{stat.label}</div>
                </div>
              ))}
            </div>

            <!-- Status line -->
            <div class="flex items-center gap-2 text-xs">
              <span class="w-2 h-2 rounded-full bg-[#2dd4bf] animate-pulse flex-shrink-0" aria-hidden="true"></span>
              <span class="text-[#2dd4bf]/70">All crews online · Same-week availability confirmed</span>
            </div>
          </div>
        </div>

        <!-- Coverage callout -->
        <div class="rounded-2xl p-6" style="background: rgba(45,212,191,0.06); border: 1px solid rgba(45,212,191,0.2);">
          <h3 class="font-sora font-bold text-white mb-2">Don't see your city?</h3>
          <p class="font-sora text-slate-400 text-sm mb-5 leading-relaxed">
            We frequently serve surrounding areas. Give us a call — if we can get there this week, we will.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href={business.phoneHref}
              class="flex items-center justify-center gap-2 font-mono font-bold text-[#080e1a] text-sm px-5 py-3 rounded-lg transition-all hover:shadow-[0_0_16px_rgba(45,212,191,0.4)] hover:scale-[1.02]"
              style="background: #2dd4bf;"
              aria-label={`Call us at ${business.phone}`}
            >
              &gt;_ {business.phone}
            </a>
            <a
              href="#quote"
              class="flex items-center justify-center gap-2 font-sora font-semibold text-[#2dd4bf] text-sm px-5 py-3 rounded-lg transition-all hover:bg-[#2dd4bf]/10"
              style="border: 1px solid rgba(45,212,191,0.3);"
            >
              Request Availability Check
            </a>
          </div>
        </div>

        <!-- Emergency note -->
        <div class="flex items-center gap-3 px-5 py-4 rounded-xl" style="background: rgba(59,130,246,0.06); border: 1px solid rgba(59,130,246,0.2);">
          <svg class="w-5 h-5 text-[#3b82f6] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
          </svg>
          <div>
            <p class="font-sora font-semibold text-white text-sm">{business.emergencyNote}</p>
            <p class="font-mono text-[#3b82f6]/70 text-[11px] tracking-wider mt-0.5">Emergency dispatch available throughout metro area</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
