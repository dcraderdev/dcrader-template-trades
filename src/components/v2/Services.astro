---
import { business } from '../../data/v2';

const serviceIcons: Record<string, string> = {
  'ev-charging': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17h10M7 17V7a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v10M7 17l-2 4M17 17l2 4"/><path d="M11 11v-3l-2 3h4l-2 3"/></svg>`,
  'smart-home': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/><circle cx="12" cy="9" r="1" fill="currentColor"/></svg>`,
  'panel-upgrade': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="3" y1="9" x2="9" y2="9"/><line x1="3" y1="15" x2="9" y2="15"/><path d="M13 8l3 4-3 4"/></svg>`,
  'generator': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><circle cx="12" cy="14" r="3"/><path d="M12 11v-2M12 19v-2M9.17 11.83l-1.41-1.41M16.24 14.24l-1.41-1.41M7 14H5M19 14h-2M9.17 16.17l-1.41 1.41M16.24 11.76l-1.41 1.41"/></svg>`,
  'led-lighting': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6M10 22h4M12 2a7 7 0 0 1 7 7c0 2.38-1.19 4.47-3 5.74V17H8v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 0 1 7-7z"/></svg>`,
  'solar-prep': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v2M12 19v2M3 12H1M23 12h-2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/><path d="M8 12a4 4 0 1 1 8 0 4 4 0 0 1-8 0z"/></svg>`,
  'security': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>`,
  'commercial': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><rect x="9" y="12" width="6" height="9"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="12" y1="12" x2="12" y2="21"/></svg>`,
};
---

<section id="services" class="relative py-24 lg:py-32" style="background: #0d1527;" aria-labelledby="services-heading">
  <!-- Top separator -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#2dd4bf]/20 to-transparent" aria-hidden="true"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Section header -->
    <div class="max-w-2xl mb-16">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-[#2dd4bf] text-xs tracking-[0.2em] uppercase">// services</span>
        <div class="flex-1 h-px bg-[#2dd4bf]/15"></div>
      </div>
      <h2 id="services-heading" class="font-sora font-extrabold text-white mb-4" style="font-size: clamp(2rem, 5vw, 3.25rem); line-height: 1.1;">
        Everything Your Home Needs. One Crew.
      </h2>
      <p class="font-sora text-slate-400 text-lg leading-relaxed">
        From EV fast chargers to full Control4 automation — we do it all under one license, one warranty, one call.
      </p>
    </div>

    <!-- Services grid: 3 columns -->
    <ul
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4"
      role="list"
      aria-label="Electrical services"
    >
      {business.services.map((service) => (
        <li>
          <div class="service-card group h-full relative rounded-2xl p-6 cursor-default transition-all duration-300"
            style="background: #080e1a; border: 1px solid rgba(45,212,191,0.1);">
            <!-- Hover glow overlay -->
            <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"
              style="box-shadow: inset 0 0 0 1px rgba(45,212,191,0.4), 0 0 30px rgba(45,212,191,0.1);"></div>

            <!-- Badge chip -->
            {service.badge && (
              <div class="absolute top-5 right-5">
                <span class="font-mono text-[10px] font-bold tracking-widest uppercase px-2.5 py-1 rounded-full"
                  style="background: rgba(45,212,191,0.12); color: #2dd4bf; border: 1px solid rgba(45,212,191,0.3);">
                  {service.badge}
                </span>
              </div>
            )}

            <!-- Icon -->
            <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5 text-[#2dd4bf] transition-all duration-300 group-hover:scale-110"
              style="background: rgba(45,212,191,0.08); border: 1px solid rgba(45,212,191,0.15);">
              <span class="w-6 h-6" set:html={serviceIcons[service.slug]} aria-hidden="true" />
            </div>

            <!-- Content -->
            <h3 class="font-sora font-bold text-white text-lg mb-2 leading-tight group-hover:text-[#2dd4bf] transition-colors duration-300">
              {service.title}
            </h3>
            <p class="font-sora text-slate-500 text-sm leading-relaxed group-hover:text-slate-400 transition-colors duration-300">
              {service.description}
            </p>

            <!-- Arrow indicator -->
            <div class="mt-4 flex items-center gap-1.5 font-mono text-[11px] text-[#2dd4bf]/0 group-hover:text-[#2dd4bf]/70 transition-all duration-300">
              <span>learn more</span>
              <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
              </svg>
            </div>
          </div>
        </li>
      ))}
    </ul>

    <!-- Bottom CTA -->
    <div class="mt-14 flex flex-col sm:flex-row items-center justify-between gap-6 p-6 rounded-2xl"
      style="background: rgba(45,212,191,0.04); border: 1px solid rgba(45,212,191,0.15);">
      <div>
        <p class="font-sora font-semibold text-white mb-1">Not sure which service you need?</p>
        <p class="font-sora text-slate-400 text-sm">Call us and describe the project — we'll tell you exactly what's needed.</p>
      </div>
      <div class="flex gap-3 flex-shrink-0">
        <a
          href={business.phoneHref}
          class="font-mono font-bold text-[#2dd4bf] text-sm hover:text-white transition-colors whitespace-nowrap"
          aria-label={`Call ${business.phone}`}
        >
          &gt;_ {business.phone}
        </a>
        <a
          href="#quote"
          class="font-sora font-semibold text-sm text-[#080e1a] px-5 py-2.5 rounded-lg transition-all hover:shadow-[0_0_16px_rgba(45,212,191,0.4)] whitespace-nowrap"
          style="background: #2dd4bf;"
        >
          Get a Quote
        </a>
      </div>
    </div>
  </div>
</section>
