---
import { business } from '../../data/v2';

const priorityMap: Record<string, string> = {
  'ev-charging': 'CRITICAL',
  'smart-home': 'HIGH',
  'panel-upgrade': 'HIGH',
  'generator': 'MEDIUM',
  'led-lighting': 'MEDIUM',
  'solar-prep': 'HIGH',
  'security': 'MEDIUM',
  'commercial': 'LOW',
};

const typeMap: Record<string, string> = {
  'ev-charging': 'POWER',
  'smart-home': 'AUTOMATION',
  'panel-upgrade': 'INFRASTRUCTURE',
  'generator': 'BACKUP',
  'led-lighting': 'LIGHTING',
  'solar-prep': 'SOLAR',
  'security': 'SECURITY',
  'commercial': 'COMMERCIAL',
};
---

<section id="services" class="relative py-24 lg:py-32" style="background: #060c17;" aria-labelledby="services-heading">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#2dd4bf]/15 to-transparent" aria-hidden="true"></div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="mb-12">
      <p class="font-mono text-[10px] text-[#2dd4bf]/50 tracking-[0.22em] uppercase mb-3">// services --list --status active</p>
      <h2 id="services-heading" class="font-sora font-black text-white mb-3" style="font-size: clamp(1.9rem, 5vw, 3rem); line-height: 1.1;">
        Everything Your Home Needs. One Crew.
      </h2>
      <p class="font-sora text-slate-500 text-base max-w-xl">
        From EV fast chargers to full Control4 automation — one license, one warranty, one call.
      </p>
    </div>

    <!-- Terminal window -->
    <div class="rounded-2xl overflow-hidden" style="background: #08111f; border: 1px solid rgba(45,212,191,0.16);">

      <!-- Title bar -->
      <div
        class="flex items-center gap-2 px-5 py-3"
        style="background: rgba(45,212,191,0.04); border-bottom: 1px solid rgba(45,212,191,0.1);"
        aria-hidden="true"
      >
        <span class="w-3 h-3 rounded-full bg-red-500/50"></span>
        <span class="w-3 h-3 rounded-full bg-yellow-500/50"></span>
        <span class="w-3 h-3 rounded-full bg-[#2dd4bf]/60"></span>
        <span class="font-mono text-[10px] text-slate-600 ml-3 tracking-wider flex-1">services.list — BrightWatt Electric</span>
        <span class="font-mono text-[10px] text-[#2dd4bf]/40 tracking-widest">{business.services.length} results</span>
      </div>

      <!-- Column headers -->
      <div
        class="grid items-center gap-3 px-5 py-2.5 font-mono text-[9px] text-slate-700 tracking-[0.18em] uppercase"
        style="grid-template-columns: 2rem 1fr 8rem 7rem 6rem; border-bottom: 1px solid rgba(45,212,191,0.06);"
        aria-hidden="true"
      >
        <span>#</span>
        <span>service_name</span>
        <span class="hidden sm:block">type</span>
        <span class="hidden md:block">priority</span>
        <span class="hidden lg:block">status</span>
      </div>

      <!-- Service rows -->
      <ul class="list-none m-0 p-0 divide-y" style="divide-color: rgba(45,212,191,0.05);" role="list" aria-label="Available services">
        {business.services.map((service, i) => {
          const priority = priorityMap[service.slug] ?? 'MEDIUM';
          const type = typeMap[service.slug] ?? 'GENERAL';
          const priorityColor = priority === 'CRITICAL' ? '#f87171' : priority === 'HIGH' ? '#2dd4bf' : priority === 'MEDIUM' ? '#3b82f6' : '#64748b';
          return (
            <li>
              <div
                class="service-row group grid items-center gap-3 px-5 py-4 cursor-default transition-all duration-200 hover:bg-[#2dd4bf]/4"
                style={`grid-template-columns: 2rem 1fr 8rem 7rem 6rem; border-left: 2px solid transparent;`}
                tabindex="0"
                role="listitem"
                aria-label={`${service.title}: ${service.description}`}
              >
                <!-- Index -->
                <span class="font-mono text-[10px] text-slate-700 group-hover:text-[#2dd4bf]/50 transition-colors select-none" aria-hidden="true">
                  {String(i).padStart(2, '0')}
                </span>

                <!-- Name + description -->
                <div class="min-w-0">
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class="font-mono text-sm text-slate-300 group-hover:text-white transition-colors font-medium">
                      $ service --name <span class="text-[#2dd4bf]">"{service.title}"</span>
                    </span>
                    {service.badge && (
                      <span
                        class="font-mono text-[9px] font-bold tracking-widest uppercase px-2 py-0.5 rounded-full flex-shrink-0"
                        style="background: rgba(45,212,191,0.1); color: #2dd4bf; border: 1px solid rgba(45,212,191,0.25);"
                      >
                        {service.badge}
                      </span>
                    )}
                  </div>
                  <p class="font-sora text-xs text-slate-600 group-hover:text-slate-400 transition-colors mt-0.5 truncate">
                    // {service.description}
                  </p>
                </div>

                <!-- Type badge -->
                <div class="hidden sm:block">
                  <span
                    class="font-mono text-[9px] font-bold tracking-widest uppercase px-2.5 py-1 rounded"
                    style="background: rgba(59,130,246,0.1); color: #3b82f6; border: 1px solid rgba(59,130,246,0.2);"
                  >
                    {type}
                  </span>
                </div>

                <!-- Priority -->
                <div class="hidden md:flex items-center gap-1.5">
                  <span
                    class="w-1.5 h-1.5 rounded-full flex-shrink-0"
                    style={`background: ${priorityColor};`}
                    aria-hidden="true"
                  ></span>
                  <span class="font-mono text-[10px] tracking-widest" style={`color: ${priorityColor};`}>
                    {priority}
                  </span>
                </div>

                <!-- Status -->
                <div class="hidden lg:flex items-center gap-1.5">
                  <span class="w-1.5 h-1.5 rounded-full bg-[#2dd4bf] flex-shrink-0" style="animation: pulse 2s ease-in-out infinite;" aria-hidden="true"></span>
                  <span class="font-mono text-[10px] text-[#2dd4bf]/60 tracking-widest">ONLINE</span>
                </div>
              </div>

              <!-- Expanded description on hover (CSS-only, visible on focus too) -->
              <div
                class="service-detail overflow-hidden max-h-0 group-hover:max-h-0 px-5"
                style="border-top: 1px solid transparent; transition: max-height 0.3s ease, border-color 0.3s;"
                aria-hidden="true"
              ></div>
            </li>
          );
        })}
      </ul>

      <!-- Footer bar -->
      <div
        class="flex items-center justify-between gap-4 px-5 py-3.5"
        style="background: rgba(45,212,191,0.03); border-top: 1px solid rgba(45,212,191,0.08);"
      >
        <span class="font-mono text-[10px] text-slate-700 tracking-widest">
          {business.services.length} services · all available · Phoenix Metro
        </span>
        <div class="flex items-center gap-3">
          <a
            href={business.phoneHref}
            class="font-mono text-[10px] text-[#2dd4bf]/60 hover:text-[#2dd4bf] transition-colors tracking-widest"
            aria-label={`Call us at ${business.phone}`}
          >
            &gt;_ {business.phone}
          </a>
          <a
            href="#quote"
            class="font-mono font-bold text-[9px] tracking-widest uppercase text-[#080e1a] px-4 py-2 rounded-full transition-all hover:shadow-[0_0_14px_rgba(45,212,191,0.4)]"
            style="background: #2dd4bf;"
          >
            Schedule Install
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom callout -->
    <div class="mt-8 flex flex-col sm:flex-row items-start sm:items-center gap-4 p-5 rounded-xl" style="background: rgba(45,212,191,0.04); border: 1px solid rgba(45,212,191,0.12);">
      <svg class="w-5 h-5 text-[#2dd4bf] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z"/>
      </svg>
      <div>
        <p class="font-sora font-semibold text-white text-sm mb-0.5">Not sure which service applies?</p>
        <p class="font-sora text-slate-500 text-xs">Describe your project and we'll scope it. No commitment required.</p>
      </div>
      <a
        href="#quote"
        class="sm:ml-auto font-mono font-bold text-[10px] tracking-widest uppercase text-[#2dd4bf] hover:text-white transition-colors whitespace-nowrap"
      >
        &gt;_ ask us
      </a>
    </div>
  </div>
</section>

<style>
  .service-row {
    border-left: 2px solid transparent;
  }
  .service-row:hover,
  .service-row:focus-visible {
    border-left-color: rgba(45,212,191,0.4);
    outline: none;
  }
  .service-row:focus-visible {
    background: rgba(45,212,191,0.05);
  }
</style>
