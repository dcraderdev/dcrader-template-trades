---
import { business } from '../../data/v2';

// Assign fake timestamps and avatar colors for visual variety
const chatMeta = [
  { time: '2:14 PM', color: '#2dd4bf', align: 'left' },
  { time: '3:47 PM', color: '#3b82f6', align: 'right' },
  { time: 'Yesterday', color: '#2dd4bf', align: 'left' },
  { time: 'Mon 11:22 AM', color: '#8b5cf6', align: 'right' },
  { time: 'Fri 9:08 AM', color: '#2dd4bf', align: 'left' },
  { time: 'Wed 4:33 PM', color: '#3b82f6', align: 'right' },
];
---

<section id="reviews" class="relative py-24 lg:py-32" style="background: #080e1a;" aria-labelledby="reviews-heading">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#2dd4bf]/12 to-transparent" aria-hidden="true"></div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-14">
      <div>
        <p class="font-mono text-[10px] text-[#2dd4bf]/50 tracking-[0.22em] uppercase mb-3">// customer_messages</p>
        <h2 id="reviews-heading" class="font-sora font-black text-white" style="font-size: clamp(1.9rem, 5vw, 3rem); line-height: 1.1;">
          What Phoenix Homeowners Say
        </h2>
      </div>

      <!-- Rating chip -->
      <div
        class="flex-shrink-0 flex items-center gap-3 px-4 py-3 rounded-2xl"
        style="background: rgba(13,21,39,0.8); border: 1px solid rgba(45,212,191,0.15);"
        aria-label="Google rating: 4.9 out of 5, over 200 reviews"
      >
        <div class="text-center">
          <div class="font-mono font-black text-[#2dd4bf] text-2xl leading-none">4.9</div>
          <div class="font-mono text-[9px] text-slate-600 tracking-widest uppercase mt-0.5">/ 5.0</div>
        </div>
        <div>
          <div class="flex gap-0.5 mb-1" aria-hidden="true">
            {[1,2,3,4,5].map(() => (
              <svg class="w-3.5 h-3.5 text-[#2dd4bf]" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <p class="font-sora text-slate-600 text-xs">200+ Google Reviews</p>
        </div>
      </div>
    </div>

    <!-- Chat-app frame -->
    <div
      class="rounded-2xl overflow-hidden"
      style="background: #06101a; border: 1px solid rgba(45,212,191,0.14);"
      role="list"
      aria-label="Customer testimonials displayed as chat messages"
    >
      <!-- App header bar -->
      <div
        class="flex items-center gap-3 px-5 py-3.5"
        style="background: rgba(45,212,191,0.04); border-bottom: 1px solid rgba(45,212,191,0.1);"
        aria-hidden="true"
      >
        <div class="w-2 h-2 rounded-full bg-[#2dd4bf] animate-pulse flex-shrink-0"></div>
        <span class="font-mono text-[10px] text-slate-600 tracking-widest">BrightWatt Customer Reviews · {business.testimonials.length} messages</span>
      </div>

      <!-- Messages -->
      <div class="p-5 sm:p-8 space-y-6" role="list">
        {business.testimonials.map((review, i) => {
          const meta = chatMeta[i % chatMeta.length];
          const isRight = meta.align === 'right';
          return (
            <article
              class={`flex gap-3 items-end ${isRight ? 'flex-row-reverse' : ''}`}
              role="listitem"
              aria-label={`Review by ${review.name} from ${review.neighborhood}`}
            >
              <!-- Avatar -->
              <div
                class="w-9 h-9 rounded-full flex items-center justify-center font-mono font-black text-sm flex-shrink-0"
                style={`background: ${meta.color}18; border: 1.5px solid ${meta.color}50; color: ${meta.color};`}
                aria-hidden="true"
              >
                {review.name.charAt(0)}
              </div>

              <!-- Bubble + meta -->
              <div class={`flex flex-col gap-1.5 max-w-[78%] ${isRight ? 'items-end' : 'items-start'}`}>
                <!-- Name + time -->
                <div class={`flex items-baseline gap-2 ${isRight ? 'flex-row-reverse' : ''}`} aria-hidden="true">
                  <span class="font-sora font-semibold text-slate-300 text-xs">{review.name}</span>
                  <span class="font-mono text-[9px] text-slate-700 tracking-wide">{meta.time}</span>
                  <span
                    class="font-mono text-[9px] tracking-widest px-1.5 py-0.5 rounded"
                    style={`background: ${meta.color}12; color: ${meta.color}90; border: 1px solid ${meta.color}25;`}
                  >
                    {review.neighborhood}, AZ
                  </span>
                </div>

                <!-- Bubble -->
                <div
                  class="chat-bubble rounded-2xl px-4 py-3 relative"
                  style={isRight
                    ? `background: rgba(45,212,191,0.09); border: 1px solid rgba(45,212,191,0.2); border-bottom-right-radius: 4px;`
                    : `background: #0d1a2e; border: 1px solid rgba(255,255,255,0.06); border-bottom-left-radius: 4px;`
                  }
                >
                  <blockquote>
                    <p class="font-sora text-slate-300 text-sm leading-relaxed">
                      {review.text}
                    </p>
                  </blockquote>
                </div>

                <!-- Stars row -->
                <div class={`flex items-center gap-1 ${isRight ? 'flex-row-reverse' : ''}`} aria-label={`${review.rating} out of 5 stars`}>
                  {Array.from({ length: review.rating }).map(() => (
                    <svg class="w-3 h-3 text-[#2dd4bf]" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                  ))}
                  <span
                    class="font-mono text-[9px] tracking-widest ml-1"
                    style="color: rgba(45,212,191,0.5);"
                    aria-hidden="true"
                  >
                    verified
                  </span>
                </div>
              </div>
            </article>
          );
        })}
      </div>

      <!-- Input bar (decorative) -->
      <div
        class="flex items-center gap-3 px-5 py-4"
        style="background: rgba(45,212,191,0.03); border-top: 1px solid rgba(45,212,191,0.08);"
        aria-hidden="true"
      >
        <div class="flex-1 rounded-full px-4 py-2.5 font-mono text-xs text-slate-700 tracking-wide"
          style="background: #080e1a; border: 1px solid rgba(45,212,191,0.1);">
          Share your experience...
        </div>
        <a
          href={business.social.google}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 font-mono text-[10px] font-bold text-[#080e1a] px-4 py-2.5 rounded-full transition-all hover:shadow-[0_0_14px_rgba(45,212,191,0.4)] flex-shrink-0"
          style="background: #2dd4bf;"
          aria-label="Leave a Google review for BrightWatt Electric (opens new tab)"
        >
          Leave a Review
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
