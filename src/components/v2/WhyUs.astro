---
import { business } from '../../data/v2';

// Signature install pipeline — the actual sequence BrightWatt runs on every smart-home / EV job
const pipeline = [
  {
    step: '01',
    handle: 'site_survey',
    title: 'Site survey + load study',
    detail: 'A licensed master electrician walks the home, photographs the panel, and runs a NEC 220 load calc before quoting. No drive-by estimates.',
    duration: '~ 45 min',
    badge: 'on-site',
  },
  {
    step: '02',
    handle: 'quote_review',
    title: 'Line-itemized quote',
    detail: 'You get a PDF with material part numbers, breaker amperage, and labor hours broken out. Sign electronically — no pressure.',
    duration: '< 24 hrs',
    badge: 'emailed',
  },
  {
    step: '03',
    handle: 'permit_pull',
    title: 'We pull the permits',
    detail: 'Phoenix / Scottsdale / Tempe permits filed under our license — never yours. Inspector coordination is on us.',
    duration: '2–4 days',
    badge: 'filed',
  },
  {
    step: '04',
    handle: 'install_day',
    title: 'Install + smart commissioning',
    detail: 'Wall Connector, Powerwall, Lutron, panel — installed, labeled, and commissioned in the app while the crew is still on site.',
    duration: 'same day',
    badge: 'live',
  },
  {
    step: '05',
    handle: 'cloud_monitor',
    title: 'We watch it for 90 days',
    detail: 'Every panel we install is monitored from our shop. If a breaker trips at 2am, we see it before you do.',
    duration: '24/7',
    badge: 'monitored',
  },
];
---

<section id="why-us" class="relative py-24 lg:py-32" style="background: #060c17;" aria-labelledby="why-us-heading">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#3b82f6]/15 to-transparent" aria-hidden="true"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Section label -->
    <div class="flex items-center gap-3 mb-3">
      <span class="font-mono text-[10px] text-[#2dd4bf]/50 tracking-[0.22em] uppercase">// install_pipeline --trace verbose</span>
      <div class="flex-1 h-px bg-[#2dd4bf]/8 max-w-[120px]" aria-hidden="true"></div>
    </div>
    <h2 id="why-us-heading" class="font-sora font-black text-white mb-3" style="font-size: clamp(1.9rem, 5vw, 3rem); line-height: 1.1;">
      The BrightWatt install pipeline
    </h2>
    <p class="font-sora text-slate-500 text-base mb-14 max-w-lg">
      Every Phoenix job runs through the same five stages — surveyed, quoted, permitted, installed, monitored.
    </p>

    <!-- Signature 5-step pipeline -->
    <ol
      class="relative grid gap-3 mb-16"
      style="grid-template-columns: 1fr;"
      role="list"
      aria-label="Our install pipeline"
    >
      {pipeline.map((p, i) => (
        <li
          class="pipeline-row relative grid items-start gap-5 rounded-2xl p-5 sm:p-6 overflow-hidden"
          style="grid-template-columns: 3.25rem 1fr auto; background: #08111f; border: 1px solid rgba(45,212,191,0.12);"
        >
          <!-- Step ring -->
          <div class="relative flex items-center justify-center w-12 h-12 rounded-full" style="border: 1px solid rgba(45,212,191,0.35); background: rgba(45,212,191,0.06);">
            <span class="font-mono font-black text-[#2dd4bf] text-sm" aria-hidden="true">{p.step}</span>
            <!-- Pulse dot -->
            <span class="absolute -right-0.5 -top-0.5 w-2 h-2 rounded-full bg-[#2dd4bf]" style="animation: pulse 2s ease-in-out infinite;" aria-hidden="true"></span>
          </div>

          <!-- Title + handle + detail -->
          <div class="min-w-0">
            <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-1.5">
              <h3 class="font-sora font-bold text-white text-base sm:text-lg leading-tight">{p.title}</h3>
              <span class="font-mono text-[10px] text-[#2dd4bf]/60 tracking-wider lowercase">// {p.handle}</span>
            </div>
            <p class="font-sora text-slate-400 text-xs sm:text-sm leading-relaxed max-w-2xl">{p.detail}</p>
          </div>

          <!-- Duration + status -->
          <div class="hidden sm:flex flex-col items-end gap-1.5 flex-shrink-0 pt-1">
            <span class="font-mono text-[10px] text-slate-500 tracking-widest uppercase">{p.duration}</span>
            <span class="inline-flex items-center gap-1 font-mono text-[9px] text-[#2dd4bf]/70 tracking-wider px-2 py-0.5 rounded"
              style="background: rgba(45,212,191,0.06); border: 1px solid rgba(45,212,191,0.18);">
              {p.badge}
            </span>
          </div>

          <!-- Connector line between rows (decorative) -->
          {i < pipeline.length - 1 && (
            <span
              class="hidden sm:block absolute left-[2.25rem] -bottom-3 w-px h-3"
              style="background: linear-gradient(to bottom, rgba(45,212,191,0.5), transparent); z-index:1;"
              aria-hidden="true"
            ></span>
          )}
        </li>
      ))}
    </ol>

    <!-- Feature spec table -->
    <div class="rounded-2xl overflow-hidden" style="border: 1px solid rgba(45,212,191,0.12);">

      <!-- Table header -->
      <div
        class="grid gap-4 px-6 py-3 font-mono text-[9px] text-slate-700 tracking-[0.18em] uppercase"
        style="grid-template-columns: 2.5rem 1fr 1fr 7rem; background: rgba(45,212,191,0.03); border-bottom: 1px solid rgba(45,212,191,0.08);"
        aria-hidden="true"
      >
        <span>#</span>
        <span>feature</span>
        <span class="hidden md:block">detail</span>
        <span class="hidden sm:block">status</span>
      </div>

      <!-- Rows -->
      <ul class="list-none m-0 p-0 divide-y" style="divide-color: rgba(45,212,191,0.05); background: #08111f;" role="list" aria-label="Why choose BrightWatt">
        {business.whyUs.map((item, i) => (
          <li>
            <div
              class="why-row group grid items-start gap-4 px-6 py-5 transition-all duration-200 hover:bg-[#2dd4bf]/4"
              style="grid-template-columns: 2.5rem 1fr 1fr 7rem;"
              aria-label={`${item.title}: ${item.description}`}
            >
              <!-- Index -->
              <span class="font-mono text-[10px] text-slate-700 pt-0.5 select-none group-hover:text-[#2dd4bf]/40 transition-colors" aria-hidden="true">
                {String(i + 1).padStart(2, '0')}
              </span>

              <!-- Feature -->
              <div>
                <h3 class="font-sora font-bold text-white text-sm leading-tight mb-1 group-hover:text-[#2dd4bf] transition-colors">
                  {item.title}
                </h3>
                <p class="font-mono text-[10px] text-slate-600 tracking-wide">{item.subtitle}</p>
              </div>

              <!-- Detail description -->
              <p class="hidden md:block font-sora text-slate-500 text-xs leading-relaxed group-hover:text-slate-400 transition-colors pt-0.5">
                {item.description}
              </p>

              <!-- Status -->
              <div class="hidden sm:flex items-center gap-2 pt-0.5">
                <span class="w-1.5 h-1.5 rounded-full bg-[#2dd4bf] flex-shrink-0" style="animation: pulse 2s ease-in-out infinite;" aria-hidden="true"></span>
                <span class="font-mono text-[9px] text-[#2dd4bf]/60 tracking-widest uppercase">VERIFIED</span>
              </div>
            </div>
          </li>
        ))}
      </ul>

      <!-- Table footer CTA -->
      <div
        class="flex items-center justify-between gap-4 px-6 py-4"
        style="background: rgba(45,212,191,0.03); border-top: 1px solid rgba(45,212,191,0.08);"
      >
        <span class="font-mono text-[10px] text-slate-700 tracking-widest">&gt; all_checks_passed · ready_to_schedule</span>
        <a
          href="#quote"
          class="inline-flex items-center gap-2 font-mono font-bold text-[9px] tracking-widest uppercase text-[#080e1a] px-5 py-2.5 rounded-full transition-all hover:shadow-[0_0_18px_rgba(45,212,191,0.4)] hover:scale-[1.02] flex-shrink-0"
          style="background: #2dd4bf;"
        >
          Schedule This Week
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .why-row {
    border-left: 2px solid transparent;
    transition: border-color 0.2s, background 0.2s;
  }
  .why-row:hover {
    border-left-color: rgba(45,212,191,0.35);
  }
</style>
