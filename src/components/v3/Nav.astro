---
import { business } from '../../data/v3';
---

<!-- Mobile sticky phone bar (bottom) -->
<div
  class="fixed bottom-0 left-0 right-0 z-50 md:hidden shadow-[0_-4px_24px_rgba(0,0,0,0.15)]"
  style="background:#2d5a27;"
  role="banner"
  aria-label="Quick call banner"
>
  <a
    href={business.phoneHref}
    class="flex items-center justify-center gap-3 py-4 font-nunito font-bold text-lg text-white active:opacity-90 transition-opacity"
    aria-label={`Call us now at ${business.phone}`}
  >
    <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
    </svg>
    Tap to Call — {business.phone}
  </a>
</div>

<!-- Main navigation -->
<header
  id="v3-nav"
  class="fixed top-0 left-0 right-0 z-40 transition-all duration-300"
  style="background:#fef8f0; border-bottom: 1px solid transparent;"
>
  <nav
    class="max-w-7xl mx-auto px-4 sm:px-6 h-[72px] flex items-center justify-between gap-4"
    aria-label="Main navigation"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 flex-shrink-0 group" aria-label={`${business.name} home`}>
      <!-- Leaf/flame icon in warm green -->
      <div
        class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 transition-colors"
        style="background:#2d5a27;"
        aria-hidden="true"
      >
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c0 0-7 5-7 11a7 7 0 0014 0c0-6-7-11-7-11z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v18M9 10c1.5 1.5 4.5 1.5 6 0"/>
        </svg>
      </div>
      <div class="hidden sm:block">
        <span class="block font-playfair font-bold leading-none" style="color:#2d5a27; font-size:1.05rem;">
          {business.shortName}
        </span>
        <span class="block font-nunito text-xs font-semibold leading-none mt-0.5" style="color:#8b7355;">
          Est. {business.founded} · Columbus, OH
        </span>
      </div>
    </a>

    <!-- Desktop nav links -->
    <ul class="hidden lg:flex items-center gap-1 list-none m-0 p-0" role="list">
      {[
        { label: 'Services', href: '#services' },
        { label: 'Service Area', href: '#service-area' },
        { label: 'Our Promise', href: '#why-us' },
        { label: 'Reviews', href: '#reviews' },
      ].map(link => (
        <li>
          <a
            href={link.href}
            class="px-4 py-2 font-nunito font-semibold text-sm rounded-lg transition-all"
            style="color:#2c2318;"
            onmouseover="this.style.background='#f5ead8'; this.style.color='#2d5a27';"
            onmouseout="this.style.background='transparent'; this.style.color='#2c2318';"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Desktop CTA group -->
    <div class="flex items-center gap-3 flex-shrink-0">
      <a
        href={business.phoneHref}
        class="hidden md:flex items-center gap-2 font-nunito font-bold transition-colors"
        style="color:#2c2318; font-size:1.05rem;"
        aria-label={`Call ${business.phone}`}
        onmouseover="this.style.color='#2d5a27';"
        onmouseout="this.style.color='#2c2318';"
      >
        <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true" style="color:#c4622d;">
          <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
        </svg>
        {business.phone}
      </a>
      <a
        href="#quote"
        class="hidden sm:block font-nunito font-bold text-sm px-5 py-2.5 rounded-lg text-white transition-all hover:opacity-90"
        style="background:#c4622d;"
      >
        Schedule Service
      </a>
    </div>
  </nav>
</header>

<script>
  const nav = document.getElementById('v3-nav');

  function updateNav() {
    const scrolled = window.scrollY > 40;
    if (scrolled) {
      nav?.style.setProperty('background', 'rgba(254,248,240,0.97)');
      nav?.style.setProperty('box-shadow', '0 2px 20px rgba(44,35,24,0.08)');
      nav?.style.setProperty('border-bottom-color', '#f5ead8');
      nav?.style.setProperty('backdrop-filter', 'blur(8px)');
    } else {
      nav?.style.setProperty('background', '#fef8f0');
      nav?.style.setProperty('box-shadow', 'none');
      nav?.style.setProperty('border-bottom-color', 'transparent');
      nav?.style.setProperty('backdrop-filter', 'none');
    }
  }

  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();
</script>
