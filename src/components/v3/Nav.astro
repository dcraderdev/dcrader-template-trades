---
import { business } from '../../data/v3';
---

<!-- Announcement bar — slim, warm green -->
<div
  role="banner"
  aria-label="Service announcement"
  style="background:#2d5a27; color:#fef8f0;"
  class="w-full text-center py-2 px-4"
>
  <p class="font-nunito text-xs sm:text-sm" style="color:rgba(254,248,240,0.9); letter-spacing:0.02em;">
    Serving Columbus, OH since 1981 &nbsp;·&nbsp; Family owned &amp; operated
  </p>
</div>

<!-- Main header — static, not sticky -->
<header
  style="background:#fef8f0; border-bottom: 1px solid #ecdcc8; position:relative;"
  aria-label="Site header"
>
  <div class="max-w-7xl mx-auto px-6 sm:px-8 py-5 flex items-center justify-between gap-6">

    <!-- Left: nav links (desktop) -->
    <nav aria-label="Main navigation" class="hidden lg:block flex-1">
      <ul class="flex items-center gap-1 list-none m-0 p-0" role="list">
        {[
          { label: 'Services', href: '/v3-family-warm#services' },
          { label: 'Case studies', href: '/v3-case-studies' },
          { label: 'Service area', href: '/v3-family-warm#service-area' },
          { label: 'Reviews', href: '/v3-family-warm#reviews' },
        ].map(link => (
          <li>
            <a
              href={link.href}
              class="px-4 py-2 font-nunito text-sm rounded-lg transition-colors block"
              style="color:#5a4a38;"
              onmouseover="this.style.color='#2d5a27'; this.style.background='#f5ead8';"
              onmouseout="this.style.color='#5a4a38'; this.style.background='transparent';"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Center: logotype -->
    <a
      href="/"
      class="flex-shrink-0 text-center"
      aria-label={`${business.name} home`}
      style="text-decoration:none;"
    >
      <span
        class="block font-playfair"
        style="font-style:italic; font-size:clamp(1.25rem, 2.5vw, 1.75rem); color:#2d5a27; line-height:1.1; letter-spacing:-0.01em;"
      >
        {business.shortName}
      </span>
      <span
        class="block font-nunito text-xs mt-0.5"
        style="color:#a08060; letter-spacing:0.08em;"
      >
        heating &amp; cooling · est. {business.founded}
      </span>
    </a>

    <!-- Right: phone number -->
    <div class="flex-1 flex justify-end items-center gap-4">
      <a
        href={business.phoneHref}
        class="hidden md:flex items-center gap-2 transition-opacity hover:opacity-70"
        style="color:#2c2318; text-decoration:none;"
        aria-label={`Call us at ${business.phone}`}
      >
        <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true" style="color:#c4622d;">
          <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
        </svg>
        <span class="font-nunito font-semibold text-sm" style="color:#2c2318;">{business.phone}</span>
      </a>

      <!-- Mobile hamburger (no JS menu — just links to top anchor) -->
      <a
        href="/v3-family-warm#quote"
        class="lg:hidden font-nunito font-semibold text-sm px-4 py-2 rounded-lg text-white"
        style="background:#c4622d;"
      >
        Schedule
      </a>

      <a
        href="/v3-family-warm#quote"
        class="hidden lg:block font-nunito text-sm px-5 py-2.5 rounded-lg text-white transition-opacity hover:opacity-90"
        style="background:#c4622d; font-weight:600;"
      >
        Schedule a visit
      </a>
    </div>

  </div>
</header>

<!-- Mobile sticky call bar -->
<div
  class="fixed bottom-0 left-0 right-0 z-50 md:hidden"
  style="background:#2d5a27;"
  role="complementary"
  aria-label="Quick call"
>
  <a
    href={business.phoneHref}
    class="flex items-center justify-center gap-3 py-4 font-nunito font-bold text-base text-white"
    aria-label={`Call us now at ${business.phone}`}
  >
    <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
    </svg>
    Tap to call — {business.phone}
  </a>
</div>
