---
import { business } from '../../data/v3';
---

<section id="projects" class="py-20 lg:py-28" style="background:#f5ead8;" aria-labelledby="projects-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Section header -->
    <div class="text-center mb-14">
      <span class="inline-block font-nunito font-semibold text-sm uppercase tracking-widest mb-3" style="color:#c4622d;">
        Our Work
      </span>
      <h2
        id="projects-heading"
        class="font-playfair font-bold mb-4 leading-tight"
        style="font-size: clamp(2rem, 4.5vw, 3.25rem); color:#2d5a27;"
      >
        Recent Projects
      </h2>
      <p class="font-nunito max-w-xl mx-auto" style="color:#8b7355; font-size:1.05rem;">
        Every job — large or small — gets the same care we'd give our own home. Drag the divider to compare.
      </p>
    </div>

    <!-- Carousel with warm-wooden-frame aesthetic -->
    <div class="relative" aria-roledescription="carousel" aria-label="Recent projects before and after">

      <!-- Slides wrapper — warm wooden frame border effect -->
      <div id="v3-project-carousel" class="overflow-hidden rounded-2xl shadow-xl" style="border: 4px solid #d4b896; box-shadow: 0 12px 40px rgba(44,35,24,0.15);">
        <div id="v3-project-track" class="flex transition-transform duration-500 ease-out" style="width: 300%;">
          {business.projects.map((project, i) => (
            <div
              class="w-full flex-shrink-0"
              style="width: 33.333%;"
              role="group"
              aria-roledescription="slide"
              aria-label={`Project ${i + 1} of ${business.projects.length}: ${project.title}`}
            >
              <!-- Before/After image container -->
              <div class="relative overflow-hidden" style="aspect-ratio: 16/9; background:#e8d5b8;">
                <!-- BEFORE image -->
                <img
                  src={project.beforeImg}
                  alt={`Before: ${project.title} in ${project.location}`}
                  class="absolute inset-0 w-full h-full object-cover"
                  loading="lazy"
                />

                <!-- AFTER image (clipped) -->
                <img
                  src={project.afterImg}
                  alt={`After: ${project.title} in ${project.location}`}
                  class="v3-after-img absolute inset-0 w-full h-full object-cover"
                  style="clip-path: inset(0 50% 0 0);"
                  loading="lazy"
                />

                <!-- Range input (transparent overlay) -->
                <input
                  type="range"
                  min="0"
                  max="100"
                  value="50"
                  class="v3-ba-slider absolute inset-0 w-full h-full opacity-0 cursor-col-resize z-10"
                  aria-label={`Before and after comparison slider for ${project.title}`}
                />

                <!-- Warm wooden-style divider handle -->
                <div class="v3-ba-divider absolute top-0 bottom-0 left-1/2 w-0.5 pointer-events-none z-20 -translate-x-1/2" style="background: #fef8f0;">
                  <div class="absolute top-1/2 -translate-y-1/2 -translate-x-1/2 w-10 h-10 rounded-full shadow-xl flex items-center justify-center" style="background:#fef8f0; border: 2px solid #d4b896;">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true" style="color:#2d5a27;">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l-3 3 3 3M16 9l3 3-3 3"/>
                    </svg>
                  </div>
                </div>

                <!-- Before/After labels — warm style -->
                <div class="absolute top-4 left-4 font-nunito font-bold text-xs px-3 py-1.5 rounded-full pointer-events-none z-20 uppercase tracking-wider" style="background:rgba(44,35,24,0.7); color:#fef8f0;" aria-hidden="true">Before</div>
                <div class="absolute top-4 right-4 font-nunito font-bold text-xs px-3 py-1.5 rounded-full pointer-events-none z-20 uppercase tracking-wider" style="background:rgba(45,90,39,0.85); color:#fef8f0;" aria-hidden="true">After</div>
              </div>

              <!-- Project info — warm parchment panel -->
              <div class="pt-6 pb-4 px-6" style="background:#fef8f0;">
                <h3 class="font-playfair font-bold text-2xl leading-tight mb-1" style="color:#2c2318;">
                  {project.title}
                </h3>
                <p class="font-nunito font-semibold text-sm mb-2 flex items-center gap-1" style="color:#c4622d;">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 1 1 9.9 9.9L10 18.9l-4.95-4.95a7 7 0 0 1 0-9.9ZM10 11a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" clip-rule="evenodd"/>
                  </svg>
                  {project.location}, Greater Columbus
                </p>
                <p class="font-nunito text-sm" style="color:#8b7355;">{project.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Navigation -->
      <div class="flex items-center justify-between mt-6 px-1">
        <!-- Prev/Next buttons -->
        <div class="flex gap-3">
          <button
            id="v3-prev-btn"
            class="w-11 h-11 rounded-full border-2 flex items-center justify-center transition-all hover:opacity-80"
            style="border-color:#2d5a27; color:#2d5a27; background:#fef8f0;"
            aria-label="Previous project"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/>
            </svg>
          </button>
          <button
            id="v3-next-btn"
            class="w-11 h-11 rounded-full flex items-center justify-center text-white transition-all hover:opacity-80"
            style="background:#2d5a27;"
            aria-label="Next project"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
            </svg>
          </button>
        </div>

        <!-- Warm dot indicators -->
        <div class="flex gap-2" role="tablist" aria-label="Project slides">
          {business.projects.map((_, i) => (
            <button
              class={`v3-dot rounded-full transition-all ${i === 0 ? 'w-7 h-3' : 'w-3 h-3'}`}
              style={i === 0 ? 'background:#2d5a27;' : 'background:#c4b090;'}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-label={`Go to project ${i + 1}`}
              data-index={i}
            />
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // ── Before/After sliders ────────────────────────────────────────────────────
  document.querySelectorAll<HTMLInputElement>('.v3-ba-slider').forEach((slider) => {
    const container = slider.closest<HTMLDivElement>('.relative');
    if (!container) return;
    const afterImg = container.querySelector<HTMLImageElement>('.v3-after-img');
    const divider = container.querySelector<HTMLDivElement>('.v3-ba-divider');
    if (!afterImg || !divider) return;

    slider.addEventListener('input', () => {
      const val = Number(slider.value);
      afterImg.style.clipPath = `inset(0 ${100 - val}% 0 0)`;
      divider.style.left = `${val}%`;
    });
  });

  // ── Carousel ────────────────────────────────────────────────────────────────
  const track = document.getElementById('v3-project-track') as HTMLDivElement | null;
  const prevBtn = document.getElementById('v3-prev-btn');
  const nextBtn = document.getElementById('v3-next-btn');
  const dots = document.querySelectorAll<HTMLButtonElement>('.v3-dot');
  const total = dots.length;
  let current = 0;

  function goTo(index: number) {
    current = (index + total) % total;
    if (track) track.style.transform = `translateX(-${current * (100 / total)}%)`;

    dots.forEach((dot, i) => {
      const active = i === current;
      dot.style.background = active ? '#2d5a27' : '#c4b090';
      dot.style.width = active ? '1.75rem' : '0.75rem';
      dot.style.height = '0.75rem';
      dot.setAttribute('aria-selected', active ? 'true' : 'false');
    });
  }

  prevBtn?.addEventListener('click', () => goTo(current - 1));
  nextBtn?.addEventListener('click', () => goTo(current + 1));
  dots.forEach((dot) => {
    dot.addEventListener('click', () => goTo(Number(dot.dataset.index)));
  });

  // Auto-advance every 7 seconds
  setInterval(() => goTo(current + 1), 7000);
</script>
