---
import { Image } from 'astro:assets';
import { business } from '../../data/v3';
import { getProjectImage } from '../../assets/projects';
---

<section id="projects" class="py-20 lg:py-28" style="background:#f5ead8;" aria-labelledby="projects-heading">
  <div class="max-w-6xl mx-auto px-6 sm:px-8">

    <!-- Editorial header -->
    <div class="max-w-2xl mb-16">
      <p class="font-nunito text-xs mb-5" style="color:#a08060; letter-spacing:0.12em;">— our work —</p>
      <h2
        id="projects-heading"
        class="font-playfair italic leading-tight mb-6"
        style="font-size:clamp(2.25rem, 5vw, 3.75rem); color:#2c2318;"
      >
        Every job, done like<br/>
        <span style="color:#2d5a27;">it's our own home.</span>
      </h2>
      <p class="font-nunito leading-relaxed" style="color:#7a6552; font-size:1.05rem;">
        These are a few recent projects — before and after. Drag the divider to compare. Every project gets the same care, no matter the size.
      </p>
    </div>

    <!-- Carousel -->
    <div class="relative" aria-roledescription="carousel" aria-label="Recent projects before and after">

      <!-- Frame -->
      <div
        id="v3-project-carousel"
        class="overflow-hidden"
        style="border-radius: 4px; border: 2px solid #c4b090; box-shadow: 4px 6px 28px rgba(44,35,24,0.14);"
      >
        <div
          id="v3-project-track"
          class="flex transition-transform duration-500 ease-out"
          style="width: 300%;"
        >
          {business.projects.map((project, i) => (
            <div
              class="w-full flex-shrink-0 flex flex-col lg:flex-row"
              style="width:33.333%;"
              role="group"
              aria-roledescription="slide"
              aria-label={`Project ${i + 1} of ${business.projects.length}: ${project.title}`}
            >
              <!-- Before/After image comparison -->
              <div class="relative overflow-hidden lg:w-3/5" style="aspect-ratio:4/3; background:#e8d5b8; min-height:280px;">
                <!-- Before image -->
                <Image
                  src={getProjectImage(project.beforeImg)}
                  alt={`Before: ${project.title} in ${project.location}`}
                  widths={[400, 800, 1200]}
                  sizes="(min-width: 1024px) 720px, 100vw"
                  class="absolute inset-0 w-full h-full object-cover"
                  loading={i === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                  style="filter:sepia(8%) saturate(80%);"
                />
                <!-- After image clipped -->
                <Image
                  src={getProjectImage(project.afterImg)}
                  alt={`After: ${project.title} in ${project.location}`}
                  widths={[400, 800, 1200]}
                  sizes="(min-width: 1024px) 720px, 100vw"
                  class="v3-after-img absolute inset-0 w-full h-full object-cover"
                  style="clip-path: inset(0 50% 0 0); filter:sepia(4%) saturate(95%);"
                  loading={i === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                />
                <!-- Range slider -->
                <input
                  type="range"
                  min="0"
                  max="100"
                  value="50"
                  class="v3-ba-slider absolute inset-0 w-full h-full opacity-0 cursor-col-resize z-10"
                  aria-label={`Before and after slider for ${project.title}`}
                />
                <!-- Divider handle -->
                <div class="v3-ba-divider absolute top-0 bottom-0 left-1/2 -translate-x-1/2 pointer-events-none z-20" style="width:2px; background:#fef8f0;">
                  <div
                    class="absolute top-1/2 -translate-y-1/2 -translate-x-1/2 w-9 h-9 rounded-full flex items-center justify-center"
                    style="background:#fef8f0; border: 2px solid #c4b090; box-shadow: 0 2px 8px rgba(44,35,24,0.2);"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true" style="color:#2d5a27;">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l-3 3 3 3M16 9l3 3-3 3"/>
                    </svg>
                  </div>
                </div>
                <!-- Before/After labels -->
                <div
                  class="absolute top-4 left-4 font-nunito font-bold text-xs px-3 py-1 rounded pointer-events-none z-20"
                  style="background:rgba(44,35,24,0.6); color:#fef8f0; letter-spacing:0.06em;"
                  aria-hidden="true"
                >
                  before
                </div>
                <div
                  class="absolute top-4 right-4 font-nunito font-bold text-xs px-3 py-1 rounded pointer-events-none z-20"
                  style="background:rgba(45,90,39,0.8); color:#fef8f0; letter-spacing:0.06em;"
                  aria-hidden="true"
                >
                  after
                </div>
              </div>

              <!-- Editorial project info panel -->
              <div
                class="flex flex-col justify-center lg:w-2/5 p-8 lg:p-10"
                style="background:#fef8f0;"
              >
                <!-- Number -->
                <p class="font-nunito text-xs mb-4" style="color:#c4622d; letter-spacing:0.1em;">
                  project 0{i + 1}
                </p>
                <h3
                  class="font-playfair italic leading-tight mb-3"
                  style="font-size:clamp(1.5rem, 2.5vw, 2rem); color:#2c2318;"
                >
                  {project.title}
                </h3>
                <p class="font-nunito font-semibold text-sm mb-4 flex items-center gap-2" style="color:#a08060;">
                  <svg class="w-3.5 h-3.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true" style="color:#c4622d;">
                    <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 1 1 9.9 9.9L10 18.9l-4.95-4.95a7 7 0 0 1 0-9.9ZM10 11a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" clip-rule="evenodd"/>
                  </svg>
                  {project.location}, Greater Columbus
                </p>
                <p class="font-nunito leading-relaxed" style="color:#7a6552;">{project.description}</p>

                <!-- CTA -->
                <a
                  href="#quote"
                  class="inline-flex items-center gap-2 font-nunito font-semibold text-sm mt-8 self-start transition-opacity hover:opacity-70"
                  style="color:#2d5a27;"
                >
                  Get a similar result
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
                  </svg>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Carousel controls -->
      <div class="flex items-center justify-between mt-6 px-1">
        <div class="flex gap-3">
          <button
            id="v3-prev-btn"
            class="w-10 h-10 rounded-full border-2 flex items-center justify-center transition-opacity hover:opacity-70"
            style="border-color:#2d5a27; color:#2d5a27; background:transparent;"
            aria-label="Previous project"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/>
            </svg>
          </button>
          <button
            id="v3-next-btn"
            class="w-10 h-10 rounded-full flex items-center justify-center text-white transition-opacity hover:opacity-80"
            style="background:#2d5a27;"
            aria-label="Next project"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
            </svg>
          </button>
        </div>

        <!-- Dots -->
        <div class="flex gap-2" role="tablist" aria-label="Project slides">
          {business.projects.map((_, i) => (
            <button
              class={`v3-dot rounded-full transition-all ${i === 0 ? 'w-7 h-3' : 'w-3 h-3'}`}
              style={i === 0 ? 'background:#2d5a27;' : 'background:#c4b090;'}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-label={`Go to project ${i + 1}`}
              data-index={i}
            />
          ))}
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  // Before/After sliders
  document.querySelectorAll<HTMLInputElement>('.v3-ba-slider').forEach((slider) => {
    const container = slider.closest<HTMLDivElement>('.relative');
    if (!container) return;
    const afterImg = container.querySelector<HTMLImageElement>('.v3-after-img');
    const divider = container.querySelector<HTMLDivElement>('.v3-ba-divider');
    if (!afterImg || !divider) return;

    slider.addEventListener('input', () => {
      const val = Number(slider.value);
      afterImg.style.clipPath = `inset(0 ${100 - val}% 0 0)`;
      divider.style.left = `${val}%`;
    });
  });

  // Carousel
  const track = document.getElementById('v3-project-track') as HTMLDivElement | null;
  const prevBtn = document.getElementById('v3-prev-btn');
  const nextBtn = document.getElementById('v3-next-btn');
  const dots = document.querySelectorAll<HTMLButtonElement>('.v3-dot');
  const total = dots.length;
  let current = 0;

  function goTo(index: number) {
    current = (index + total) % total;
    if (track) track.style.transform = `translateX(-${current * (100 / total)}%)`;
    dots.forEach((dot, i) => {
      const active = i === current;
      dot.style.background = active ? '#2d5a27' : '#c4b090';
      dot.style.width = active ? '1.75rem' : '0.75rem';
      dot.style.height = '0.75rem';
      dot.setAttribute('aria-selected', active ? 'true' : 'false');
    });
  }

  prevBtn?.addEventListener('click', () => goTo(current - 1));
  nextBtn?.addEventListener('click', () => goTo(current + 1));
  dots.forEach((dot) => {
    dot.addEventListener('click', () => goTo(Number(dot.dataset.index)));
  });

  setInterval(() => goTo(current + 1), 8000);
</script>
