---
import { business } from '../../data/v3';
---

<section id="quote" class="py-20 lg:py-28 relative" style="background:#fef8f0;" aria-labelledby="quote-heading">
  <!-- Subtle diagonal texture -->
  <div class="absolute inset-0 quote-texture pointer-events-none" aria-hidden="true"></div>

  <!-- Green top accent line -->
  <div class="absolute top-0 left-0 right-0 h-1" style="background:#2d5a27;" aria-hidden="true"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">

      <!-- Left: warm pitch copy -->
      <div>
        <span class="inline-block font-nunito font-semibold text-sm uppercase tracking-widest mb-4" style="color:#c4622d;">
          No Pressure. Just Honest Help.
        </span>
        <h2
          id="quote-heading"
          class="font-playfair font-bold leading-tight mb-4"
          style="font-size: clamp(2.25rem, 5vw, 3.75rem); color:#2d5a27;"
        >
          {business.form.headline}
        </h2>
        <p class="font-playfair italic font-semibold mb-6" style="font-size:1.25rem; color:#c4622d;">
          {business.form.subheadline}
        </p>
        <p class="font-nunito text-lg mb-10 leading-relaxed" style="color:#8b7355;">
          {business.form.note}
        </p>

        <!-- Years stat callout -->
        <div class="flex items-center gap-5 p-6 rounded-2xl mb-8 border" style="background:#f5ead8; border-color:#e8d5b8;">
          <div class="font-playfair font-bold leading-none flex-shrink-0" style="font-size:3rem; color:#2d5a27;">
            {business.form.calloutStat}
          </div>
          <div>
            <p class="font-nunito font-semibold" style="color:#2c2318;">{business.form.calloutLabel}</p>
            <p class="font-nunito text-sm" style="color:#8b7355;">Three generations, same promise.</p>
          </div>
        </div>

        <!-- Phone alternative -->
        <div class="flex flex-col gap-2">
          <p class="font-nunito text-sm uppercase tracking-widest" style="color:#8b7355;">Prefer to call directly?</p>
          <a
            href={business.phoneHref}
            class="inline-flex items-center gap-3 group transition-opacity hover:opacity-75"
            aria-label={`Call us at ${business.phone}`}
          >
            <div
              class="w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0"
              style="background:#2d5a27;"
              aria-hidden="true"
            >
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
              </svg>
            </div>
            <span class="font-nunito font-bold leading-none" style="font-size:2rem; color:#2c2318;">
              {business.phone}
            </span>
          </a>
          <p class="font-nunito text-sm font-semibold ml-15" style="color:#c4622d; padding-left:3.75rem;">
            {business.emergencyNote}
          </p>
        </div>

        <!-- Hours summary -->
        <div class="mt-8 rounded-2xl p-5 border" style="background:#f5ead8; border-color:#e8d5b8;">
          <p class="font-playfair font-bold mb-3" style="color:#2d5a27;">Service Hours</p>
          <ul class="space-y-2 list-none m-0 p-0">
            {business.hours.map((h) => (
              <li class="flex justify-between gap-4">
                <span class="font-nunito text-sm" style="color:#8b7355;">{h.day}</span>
                <span class="font-nunito font-semibold text-sm" style="color:#2c2318;">{h.hours}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Right: form — warm white card -->
      <div
        class="rounded-2xl p-8 border"
        style="background:#fff; border-color:#e8d5b8; box-shadow: 0 16px 48px rgba(44,35,24,0.10);"
      >
        <!-- Form header -->
        <div class="mb-6">
          <p class="font-playfair font-bold text-2xl" style="color:#2d5a27;">Tell Us About Your Home</p>
          <p class="font-nunito text-sm mt-1" style="color:#8b7355;">We'll call back within the hour during business hours.</p>
        </div>

        <form
          name="v3-quote-request"
          method="POST"
          class="space-y-5"
          aria-label="Schedule a service visit"
          novalidate
        >
          <!-- Name -->
          <div>
            <label for="v3-form-name" class="block font-nunito font-semibold text-sm mb-1.5" style="color:#2c2318;">
              Your Name <span style="color:#c4622d;" aria-hidden="true">*</span>
            </label>
            <input
              type="text"
              id="v3-form-name"
              name="name"
              required
              autocomplete="name"
              placeholder="Jane & Bob Smith"
              class="w-full rounded-xl px-4 py-3 font-nunito text-sm border transition-all focus:outline-none"
              style="border-color:#d4b896; color:#2c2318; background:#fef8f0;"
              aria-required="true"
              onfocus="this.style.borderColor='#2d5a27'; this.style.boxShadow='0 0 0 3px rgba(45,90,39,0.12)';"
              onblur="this.style.borderColor='#d4b896'; this.style.boxShadow='none';"
            />
          </div>

          <!-- Phone -->
          <div>
            <label for="v3-form-phone" class="block font-nunito font-semibold text-sm mb-1.5" style="color:#2c2318;">
              Best Phone Number <span style="color:#c4622d;" aria-hidden="true">*</span>
            </label>
            <input
              type="tel"
              id="v3-form-phone"
              name="phone"
              required
              autocomplete="tel"
              placeholder="(614) 555-0000"
              class="w-full rounded-xl px-4 py-3 font-nunito text-sm border transition-all focus:outline-none"
              style="border-color:#d4b896; color:#2c2318; background:#fef8f0;"
              aria-required="true"
              onfocus="this.style.borderColor='#2d5a27'; this.style.boxShadow='0 0 0 3px rgba(45,90,39,0.12)';"
              onblur="this.style.borderColor='#d4b896'; this.style.boxShadow='none';"
            />
          </div>

          <!-- Address -->
          <div>
            <label for="v3-form-address" class="block font-nunito font-semibold text-sm mb-1.5" style="color:#2c2318;">
              Service Address
            </label>
            <input
              type="text"
              id="v3-form-address"
              name="address"
              autocomplete="street-address"
              placeholder="123 Oak St, Columbus, OH"
              class="w-full rounded-xl px-4 py-3 font-nunito text-sm border transition-all focus:outline-none"
              style="border-color:#d4b896; color:#2c2318; background:#fef8f0;"
              onfocus="this.style.borderColor='#2d5a27'; this.style.boxShadow='0 0 0 3px rgba(45,90,39,0.12)';"
              onblur="this.style.borderColor='#d4b896'; this.style.boxShadow='none';"
            />
          </div>

          <!-- Service type select -->
          <div>
            <label for="v3-form-service" class="block font-nunito font-semibold text-sm mb-1.5" style="color:#2c2318;">
              What Do You Need Help With?
            </label>
            <select
              id="v3-form-service"
              name="service"
              class="w-full rounded-xl px-4 py-3 font-nunito text-sm border transition-all focus:outline-none appearance-none"
              style="border-color:#d4b896; color:#2c2318; background:#fef8f0;"
              onfocus="this.style.borderColor='#2d5a27'; this.style.boxShadow='0 0 0 3px rgba(45,90,39,0.12)';"
              onblur="this.style.borderColor='#d4b896'; this.style.boxShadow='none';"
            >
              <option value="">— Select a service —</option>
              {business.services.map((s) => (
                <option value={s.slug}>{s.title}</option>
              ))}
              <option value="other">Other / Not Sure</option>
            </select>
          </div>

          <!-- Notes -->
          <div>
            <label for="v3-form-notes" class="block font-nunito font-semibold text-sm mb-1.5" style="color:#2c2318;">
              Anything Else We Should Know? <span style="color:#8b7355;" class="font-normal">(optional)</span>
            </label>
            <textarea
              id="v3-form-notes"
              name="notes"
              rows="3"
              placeholder="e.g. Furnace won't start, it's getting cold in here..."
              class="w-full rounded-xl px-4 py-3 font-nunito text-sm border transition-all focus:outline-none resize-none"
              style="border-color:#d4b896; color:#2c2318; background:#fef8f0;"
              onfocus="this.style.borderColor='#2d5a27'; this.style.boxShadow='0 0 0 3px rgba(45,90,39,0.12)';"
              onblur="this.style.borderColor='#d4b896'; this.style.boxShadow='none';"
            ></textarea>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            class="w-full text-white font-nunito font-bold text-lg py-4 px-6 rounded-xl transition-all hover:opacity-90 flex items-center justify-center gap-2"
            style="background:#c4622d; box-shadow: 0 6px 24px rgba(196,98,45,0.3);"
          >
            {business.form.submitLabel}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
            </svg>
          </button>

          <p class="text-center font-nunito text-xs" style="color:#8b7355;">
            We'll call within the hour. We never share your information.
          </p>
        </form>
      </div>

    </div>
  </div>
</section>

<style>
  .quote-texture {
    background-image: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 50px,
      rgba(45, 90, 39, 0.015) 50px,
      rgba(45, 90, 39, 0.015) 100px
    );
  }
</style>
