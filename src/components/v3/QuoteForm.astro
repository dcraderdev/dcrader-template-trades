---
import { business } from '../../data/v3';
---

<section id="quote" class="py-20 lg:py-28 relative" style="background:#f5ead8;" aria-labelledby="quote-heading">
  <div class="max-w-6xl mx-auto px-6 sm:px-8">

    <div class="grid lg:grid-cols-2 gap-14 lg:gap-20 items-start">

      <!-- Left: editorial copy -->
      <div class="lg:sticky lg:top-8">
        <p class="font-nunito text-xs mb-6" style="color:#a08060; letter-spacing:0.12em;">— no pressure, just honest help —</p>
        <h2
          id="quote-heading"
          class="font-playfair italic leading-tight mb-6"
          style="font-size:clamp(2.25rem, 5vw, 3.75rem); color:#2c2318;"
        >
          {business.form.headline}
        </h2>
        <p class="font-playfair italic mb-8" style="font-size:1.2rem; color:#c4622d;">
          {business.form.subheadline}
        </p>
        <p class="font-nunito leading-relaxed mb-10" style="color:#7a6552; font-size:1.05rem;">
          {business.form.note}
        </p>

        <!-- Big stat callout -->
        <div class="mb-10 flex items-end gap-4">
          <span
            class="font-playfair italic font-bold leading-none"
            style="font-size:5rem; color:#2d5a27; opacity:0.6;"
          >
            {business.form.calloutStat}
          </span>
          <span class="font-nunito pb-3" style="color:#7a6552; font-size:1rem; max-width:10rem; line-height:1.4;">
            {business.form.calloutLabel}
          </span>
        </div>

        <!-- Phone -->
        <div class="mb-8">
          <p class="font-nunito text-xs mb-2" style="color:#a08060; letter-spacing:0.08em;">or call directly</p>
          <a
            href={business.phoneHref}
            class="inline-flex items-center gap-3 font-nunito font-bold transition-opacity hover:opacity-70"
            style="font-size:clamp(1.5rem, 3vw, 2rem); color:#2c2318; text-decoration:none;"
            aria-label={`Call us at ${business.phone}`}
          >
            {business.phone}
          </a>
          <p class="font-nunito text-sm mt-1" style="color:#c4622d;">{business.emergencyNote}</p>
        </div>

        <!-- Hours -->
        <div class="rounded-xl p-5" style="background:#ecdcc8; border: 1px solid #d4b896;">
          <p class="font-playfair italic font-semibold mb-3" style="color:#2d5a27;">Service hours</p>
          <ul class="space-y-2 list-none m-0 p-0">
            {business.hours.map((h) => (
              <li class="flex justify-between gap-4">
                <span class="font-nunito text-sm" style="color:#7a6552;">{h.day}</span>
                <span class="font-nunito font-semibold text-sm" style="color:#2c2318;">{h.hours}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Right: notepad paper form -->
      <div class="relative">
        <!-- Notepad wrapper -->
        <div
          class="rounded-lg overflow-hidden shadow-2xl relative"
          style="background:#fffff5; box-shadow: 2px 4px 24px rgba(44,35,24,0.18), 0 1px 4px rgba(44,35,24,0.1);"
        >
          <!-- Notepad top binding bar -->
          <div
            class="px-8 py-5"
            style="background:#c4622d;"
          >
            <p class="font-playfair italic text-white font-semibold" style="font-size:1.25rem;">Tell us about your home</p>
            <p class="font-nunito text-sm mt-0.5" style="color:rgba(255,255,255,0.75);">We'll call back within the hour</p>
          </div>

          <!-- Red left margin line + faint lines -->
          <div class="relative" style="background:#fffff5;">
            <!-- Faint horizontal lines background -->
            <div class="absolute inset-0 pointer-events-none notepad-lines" aria-hidden="true"></div>
            <!-- Red left margin -->
            <div class="absolute top-0 bottom-0 left-14 w-0.5 pointer-events-none" style="background:rgba(196,98,45,0.2);" aria-hidden="true"></div>

            <!-- Form content -->
            <form
              name="v3-quote-request"
              method="POST"
              class="relative z-10 px-8 pt-6 pb-8 space-y-6"
              aria-label="Schedule a service visit"
              novalidate
            >
              <!-- Spiral holes left decoration -->
              <div class="absolute left-5 top-6 bottom-6 flex flex-col justify-around" aria-hidden="true">
                {[0,1,2,3,4,5,6,7].map(() => (
                  <div class="w-3 h-3 rounded-full" style="background:#e8d5b8; border: 1px solid #c4b090;"></div>
                ))}
              </div>

              <!-- Name -->
              <div class="ml-6">
                <label for="v3n-name" class="block font-nunito font-semibold text-sm mb-1" style="color:#5a4a38;">
                  Your name <span style="color:#c4622d;" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="v3n-name"
                  name="name"
                  required
                  autocomplete="name"
                  placeholder="Jane & Bob Smith"
                  class="w-full py-2 px-0 font-nunito text-sm border-0 border-b focus:outline-none focus:ring-0 bg-transparent transition-colors"
                  style="border-bottom: 1.5px solid #c4b090; color:#2c2318;"
                  aria-required="true"
                  onfocus="this.style.borderColor='#2d5a27';"
                  onblur="this.style.borderColor='#c4b090';"
                />
              </div>

              <!-- Phone -->
              <div class="ml-6">
                <label for="v3n-phone" class="block font-nunito font-semibold text-sm mb-1" style="color:#5a4a38;">
                  Best phone number <span style="color:#c4622d;" aria-hidden="true">*</span>
                </label>
                <input
                  type="tel"
                  id="v3n-phone"
                  name="phone"
                  required
                  autocomplete="tel"
                  placeholder="(614) 555-0000"
                  class="w-full py-2 px-0 font-nunito text-sm border-0 border-b focus:outline-none focus:ring-0 bg-transparent transition-colors"
                  style="border-bottom: 1.5px solid #c4b090; color:#2c2318;"
                  aria-required="true"
                  onfocus="this.style.borderColor='#2d5a27';"
                  onblur="this.style.borderColor='#c4b090';"
                />
              </div>

              <!-- Address -->
              <div class="ml-6">
                <label for="v3n-address" class="block font-nunito font-semibold text-sm mb-1" style="color:#5a4a38;">
                  Service address
                </label>
                <input
                  type="text"
                  id="v3n-address"
                  name="address"
                  autocomplete="street-address"
                  placeholder="123 Oak St, Columbus, OH"
                  class="w-full py-2 px-0 font-nunito text-sm border-0 border-b focus:outline-none focus:ring-0 bg-transparent transition-colors"
                  style="border-bottom: 1.5px solid #c4b090; color:#2c2318;"
                  onfocus="this.style.borderColor='#2d5a27';"
                  onblur="this.style.borderColor='#c4b090';"
                />
              </div>

              <!-- Service type -->
              <div class="ml-6">
                <label for="v3n-service" class="block font-nunito font-semibold text-sm mb-1" style="color:#5a4a38;">
                  What do you need help with?
                </label>
                <select
                  id="v3n-service"
                  name="service"
                  class="w-full py-2 px-0 font-nunito text-sm border-0 border-b focus:outline-none focus:ring-0 bg-transparent appearance-none transition-colors"
                  style="border-bottom: 1.5px solid #c4b090; color:#2c2318;"
                  onfocus="this.style.borderColor='#2d5a27';"
                  onblur="this.style.borderColor='#c4b090';"
                >
                  <option value="">— pick a service —</option>
                  {business.services.map((s) => (
                    <option value={s.slug}>{s.title}</option>
                  ))}
                  <option value="other">Other / not sure</option>
                </select>
              </div>

              <!-- Notes -->
              <div class="ml-6">
                <label for="v3n-notes" class="block font-nunito font-semibold text-sm mb-1" style="color:#5a4a38;">
                  Anything else? <span class="font-normal" style="color:#a08060;">(optional)</span>
                </label>
                <textarea
                  id="v3n-notes"
                  name="notes"
                  rows="3"
                  placeholder="e.g. Furnace won't start, getting cold in here..."
                  class="w-full py-2 px-0 font-nunito text-sm border-0 border-b focus:outline-none focus:ring-0 bg-transparent resize-none transition-colors"
                  style="border-bottom: 1.5px solid #c4b090; color:#2c2318;"
                  onfocus="this.style.borderColor='#2d5a27';"
                  onblur="this.style.borderColor='#c4b090';"
                ></textarea>
              </div>

              <!-- Submit -->
              <div class="ml-6 pt-2">
                <button
                  type="submit"
                  class="w-full font-nunito font-bold text-white py-4 px-6 rounded-lg transition-opacity hover:opacity-90 flex items-center justify-center gap-3"
                  style="background:#2d5a27; font-size:1rem;"
                >
                  {business.form.submitLabel}
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
                  </svg>
                </button>
                <p class="text-center font-nunito text-xs mt-3" style="color:#a08060;">
                  We'll call within the hour. Your information stays private.
                </p>
              </div>

            </form>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .notepad-lines {
    background-image: repeating-linear-gradient(
      transparent,
      transparent 31px,
      rgba(196,176,144,0.3) 31px,
      rgba(196,176,144,0.3) 32px
    );
    background-size: 100% 32px;
  }
</style>
