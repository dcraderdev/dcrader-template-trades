---
import { business } from '../../data/v3';
---

<section
  id="service-area"
  class="py-20 lg:py-28"
  style="background:#fef8f0;"
  aria-labelledby="service-area-heading"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Section header — warm centered text intro -->
    <div class="text-center mb-14">
      <span class="inline-block font-nunito font-semibold text-sm uppercase tracking-widest mb-3" style="color:#c4622d;">
        Where We Work
      </span>
      <h2
        id="service-area-heading"
        class="font-playfair font-bold mb-4 leading-tight"
        style="font-size: clamp(2rem, 4.5vw, 3.25rem); color:#2d5a27;"
      >
        {business.serviceArea.headline}
      </h2>
      <p class="font-nunito max-w-2xl mx-auto text-lg leading-relaxed" style="color:#8b7355;">
        {business.serviceArea.subheadline}. We've been your Columbus-area neighbors since 1981 — three generations of local work, local roots.
      </p>
    </div>

    <!-- Main content: two-column layout -->
    <div class="grid lg:grid-cols-5 gap-10 lg:gap-16 items-start">

      <!-- Left (wider): city grid with warm styling -->
      <div class="lg:col-span-3">
        <p class="font-playfair italic font-semibold mb-6" style="color:#2d5a27; font-size:1.2rem;">
          We proudly serve these Columbus-area communities:
        </p>
        <ul
          class="grid grid-cols-2 sm:grid-cols-3 gap-x-4 gap-y-3 mb-10"
          role="list"
          aria-label="Cities we serve in Greater Columbus"
        >
          {business.serviceArea.cities.map((city) => (
            <li class="flex items-center gap-2 font-nunito font-medium" style="color:#2c2318;">
              <!-- Small leaf marker -->
              <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true" style="color:#2d5a27;">
                <path d="M17 8C8 10 5.9 16.17 3.82 19.77L5.6 21 7 19c.53.35 1.11.64 1.7.88C11 21.5 14.5 21.5 17 19.5c4-3 6-8 4-14z"/>
              </svg>
              {city}
            </li>
          ))}
        </ul>

        <!-- "Within 40 miles" callout strip -->
        <div class="flex items-center gap-4 rounded-2xl p-5 border" style="background:#f5ead8; border-color:#e8d5b8;">
          <div class="w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0" style="background:#2d5a27;" aria-hidden="true">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
            </svg>
          </div>
          <div>
            <p class="font-playfair font-bold" style="color:#2d5a27;">Within 40 miles of downtown Columbus</p>
            <p class="font-nunito text-sm" style="color:#8b7355;">Not sure if we cover your area? Just give us a call.</p>
          </div>
        </div>
      </div>

      <!-- Right (narrower): trust / story panel -->
      <div class="lg:col-span-2">
        <!-- Large "1981" year display -->
        <div class="rounded-2xl overflow-hidden border" style="border-color:#e8d5b8; background:#f5ead8;">
          <!-- Year badge top -->
          <div class="py-8 px-6 text-center border-b" style="border-color:#e8d5b8; background:#2d5a27;">
            <div class="font-playfair font-bold text-white leading-none mb-1" style="font-size:4rem;">1981</div>
            <p class="font-nunito text-sm font-semibold" style="color:rgba(255,255,255,0.75);">Year Earl started it all</p>
          </div>

          <!-- Story snippets -->
          <div class="p-6 space-y-5">
            {[
              { stat: "44 years", label: "Serving Columbus families" },
              { stat: "3 generations", label: "Earl → Dennis → Dale" },
              { stat: "40-mile radius", label: "Full Greater Columbus coverage" },
            ].map((item) => (
              <div class="flex items-center gap-4">
                <div class="flex-shrink-0 w-2 h-2 rounded-full" style="background:#c4622d;" aria-hidden="true"></div>
                <div>
                  <span class="font-playfair font-bold" style="color:#2d5a27;">{item.stat}</span>
                  <span class="font-nunito text-sm ml-2" style="color:#8b7355;">{item.label}</span>
                </div>
              </div>
            ))}
          </div>

          <!-- CTA inside panel -->
          <div class="px-6 pb-6">
            <a
              href={business.phoneHref}
              class="flex items-center justify-center gap-2 w-full font-nunito font-bold text-sm py-3 px-5 rounded-xl text-white transition-all hover:opacity-90"
              style="background:#c4622d;"
              aria-label={`Call us at ${business.phone}`}
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
              </svg>
              {business.phone}
            </a>
            <p class="font-nunito text-xs text-center mt-2" style="color:#8b7355;">{business.emergencyNote}</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
