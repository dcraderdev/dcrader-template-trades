---
import { business } from '../../data/v3';
---

<section
  id="service-area"
  class="py-20 lg:py-28"
  style="background:#fef8f0;"
  aria-labelledby="service-area-heading"
>
  <div class="max-w-6xl mx-auto px-6 sm:px-8">

    <!-- Editorial header -->
    <div class="max-w-2xl mb-16">
      <p class="font-nunito text-xs mb-5" style="color:#a08060; letter-spacing:0.12em;">— where we work —</p>
      <h2
        id="service-area-heading"
        class="font-playfair italic leading-tight mb-6"
        style="font-size:clamp(2.25rem, 5vw, 3.75rem); color:#2c2318;"
      >
        {business.serviceArea.headline}
      </h2>
      <p class="font-nunito leading-relaxed" style="color:#7a6552; font-size:1.1rem;">
        {business.serviceArea.subheadline}. Since Earl started this company in 1981, we've never left. We live here too — your neighbors for three generations.
      </p>
    </div>

    <!-- Two-column layout -->
    <div class="grid lg:grid-cols-3 gap-12 lg:gap-16 items-start">

      <!-- Left: personal prose + city list -->
      <div class="lg:col-span-2">

        <!-- Warm prose paragraph -->
        <p class="font-playfair italic leading-[1.8] mb-10" style="font-size:1.05rem; color:#5a4a38;">
          We've worked in every corner of Greater Columbus — from the old brick homes of Bexley to the new builds in Lewis Center. We know these neighborhoods because we grew up in them.
        </p>

        <!-- City list — flowing, not a grid of pills -->
        <div class="mb-10">
          <p class="font-nunito font-semibold text-sm mb-5" style="color:#2d5a27; letter-spacing:0.04em;">Communities we serve:</p>
          <ul
            class="flex flex-wrap gap-x-3 gap-y-3 list-none m-0 p-0"
            role="list"
            aria-label="Cities we serve in Greater Columbus"
          >
            {business.serviceArea.cities.map((city, i) => (
              <li>
                <span
                  class="font-nunito text-sm px-4 py-1.5 rounded-full"
                  style="background:#f5ead8; color:#5a4a38; border: 1px solid #d4b896;"
                >
                  {city}
                </span>
                {i < business.serviceArea.cities.length - 1 && (
                  <span class="sr-only">,</span>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Not-sure callout strip -->
        <div
          class="flex items-center gap-5 rounded-xl p-5"
          style="background:#f5ead8; border: 1px solid #d4b896;"
        >
          <div
            class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0"
            style="background:#2d5a27;"
            aria-hidden="true"
          >
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
            </svg>
          </div>
          <div class="flex-1">
            <p class="font-playfair italic font-semibold" style="color:#2d5a27;">Within 40 miles of downtown Columbus</p>
            <p class="font-nunito text-sm" style="color:#7a6552;">Not sure if we cover your area? Just call — we'll tell you straight.</p>
          </div>
          <a
            href={business.phoneHref}
            class="hidden sm:block font-nunito font-semibold text-sm px-4 py-2 rounded-lg text-white flex-shrink-0 transition-opacity hover:opacity-90"
            style="background:#c4622d;"
            aria-label={`Call us at ${business.phone}`}
          >
            Call us
          </a>
        </div>
      </div>

      <!-- Right: year panel -->
      <div class="lg:col-span-1">
        <div
          class="rounded-2xl overflow-hidden"
          style="border: 1px solid #d4b896; box-shadow: 0 8px 32px rgba(44,35,24,0.1);"
        >
          <!-- Green top panel with big year -->
          <div
            class="py-10 px-6 text-center"
            style="background:#2d5a27;"
          >
            <p
              class="font-playfair italic font-bold text-white leading-none mb-2"
              style="font-size:4.5rem;"
            >
              1981
            </p>
            <p class="font-nunito text-sm" style="color:rgba(255,255,255,0.65);">Year Earl started it all</p>
          </div>

          <!-- Stats -->
          <div class="p-6 space-y-6" style="background:#fef8f0;">
            {[
              { stat: '44 years', label: 'Serving Columbus families' },
              { stat: '3 generations', label: 'Earl → Mike → Tyler' },
              { stat: '40-mile radius', label: 'Greater Columbus coverage' },
            ].map((item) => (
              <div class="flex items-start gap-4">
                <div class="w-1.5 h-1.5 rounded-full flex-shrink-0 mt-2" style="background:#c4622d;"></div>
                <div>
                  <p class="font-playfair italic font-semibold" style="color:#2d5a27; font-size:1rem;">{item.stat}</p>
                  <p class="font-nunito text-sm" style="color:#a08060;">{item.label}</p>
                </div>
              </div>
            ))}

            <div style="border-top: 1px solid #e8d5b8; padding-top:1.25rem;">
              <a
                href={business.phoneHref}
                class="flex items-center justify-center gap-2 w-full font-nunito font-semibold text-sm py-3 px-5 rounded-lg text-white transition-opacity hover:opacity-90"
                style="background:#c4622d;"
                aria-label={`Call us at ${business.phone}`}
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
                </svg>
                {business.phone}
              </a>
              <p class="font-nunito text-xs text-center mt-2" style="color:#a08060;">{business.emergencyNote}</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
