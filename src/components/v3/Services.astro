---
import { business } from '../../data/v3';

// Picsum image seeds for each service
const serviceImages: Record<string, string> = {
  'furnace-repair':  'heating-service',
  'ac-install':      'cooling-service',
  'heat-pump':       'heat-pump-outdoor',
  'duct-cleaning':   'duct-work-clean',
  'boiler':          'boiler-room',
  'air-quality':     'indoor-air-home',
  'thermostat':      'smart-thermostat',
  'maintenance':     'hvac-tune-up',
};

// Real photo overrides for services where the picsum seed produced
// off-topic / broken-looking imagery. These point to bundled local assets
// in /public/images/v3 so they are guaranteed to load.
const serviceImageOverrides: Record<string, string> = {
  'air-quality': '/images/v3/air-quality.jpg',
  'thermostat':  '/images/v3/thermostat.jpg',
};

// For alternating layout: odd index = image left + text right, even = text left + image right
---

<section id="services" class="py-24 lg:py-32" style="background:#fef8f0;" aria-labelledby="services-heading">

  <!-- Section header — editorial centered -->
  <div class="max-w-3xl mx-auto px-6 sm:px-8 text-center mb-20">
    <p class="font-nunito text-xs mb-4" style="color:#a08060; letter-spacing:0.12em;">
      — what we do —
    </p>
    <h2
      id="services-heading"
      class="font-playfair italic mb-6 leading-tight"
      style="font-size:clamp(2.25rem, 5vw, 3.75rem); color:#2c2318;"
    >
      Heating &amp; cooling,<br/>
      <span style="color:#2d5a27;">done right.</span>
    </h2>
    <p class="font-nunito leading-relaxed" style="color:#7a6552; font-size:1.05rem;">
      Whatever your HVAC need — repair, installation, or seasonal tune-up — our family has handled it for over four decades. We've seen it all, and we fix it right the first time.
    </p>
  </div>

  <!-- Alternating editorial rows -->
  <div class="max-w-6xl mx-auto px-6 sm:px-8 space-y-0">
    {business.services.map((service, i) => {
      const imageLeft = i % 2 !== 0; // odd = image left; even = text left
      const seed = serviceImages[service.slug] || service.slug;
      const imgSrc = serviceImageOverrides[service.slug] ||
                     `https://picsum.photos/seed/${seed}/700/480`;
      return (
        <article
          class="flex flex-col lg:flex-row items-stretch border-b"
          style={`border-color: #ecdcc8; ${i === 0 ? 'border-top: 1px solid #ecdcc8;' : ''}`}
          aria-label={service.title}
        >
          {imageLeft ? (
            <>
              <!-- Image left -->
              <div class="w-full lg:w-2/5 overflow-hidden" style="min-height:320px;">
                <img
                  src={imgSrc}
                  alt={`${service.title} — Three Generations Heating & Cooling`}
                  class="w-full h-full object-cover editorial-img"
                  style="filter:sepia(8%) saturate(85%) brightness(0.98); display:block;"
                  loading="lazy"
                />
              </div>
              <!-- Text right -->
              <div class="flex flex-col justify-center w-full lg:w-3/5 py-12 px-8 lg:px-16">
                <p class="font-nunito text-xs mb-4" style="color:#c4622d; letter-spacing:0.1em;">
                  0{i + 1}
                </p>
                <h3 class="font-playfair italic mb-4 leading-tight" style="font-size:clamp(1.75rem, 3vw, 2.5rem); color:#2c2318;">
                  {service.title}
                </h3>
                <p class="font-nunito leading-relaxed mb-8" style="color:#7a6552; font-size:1.05rem;">
                  {service.description}
                </p>
                <a
                  href="#quote"
                  class="inline-flex items-center gap-2 font-nunito font-semibold text-sm self-start transition-opacity hover:opacity-70"
                  style="color:#2d5a27;"
                >
                  Schedule this service
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
                  </svg>
                </a>
              </div>
            </>
          ) : (
            <>
              <!-- Text left -->
              <div class="flex flex-col justify-center w-full lg:w-3/5 py-12 px-8 lg:px-16 order-2 lg:order-1">
                <p class="font-nunito text-xs mb-4" style="color:#c4622d; letter-spacing:0.1em;">
                  0{i + 1}
                </p>
                <h3 class="font-playfair italic mb-4 leading-tight" style="font-size:clamp(1.75rem, 3vw, 2.5rem); color:#2c2318;">
                  {service.title}
                </h3>
                <p class="font-nunito leading-relaxed mb-8" style="color:#7a6552; font-size:1.05rem;">
                  {service.description}
                </p>
                <a
                  href="#quote"
                  class="inline-flex items-center gap-2 font-nunito font-semibold text-sm self-start transition-opacity hover:opacity-70"
                  style="color:#2d5a27;"
                >
                  Schedule this service
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
                  </svg>
                </a>
              </div>
              <!-- Image right -->
              <div class="w-full lg:w-2/5 overflow-hidden order-1 lg:order-2" style="min-height:320px;">
                <img
                  src={imgSrc}
                  alt={`${service.title} — Three Generations Heating & Cooling`}
                  class="w-full h-full object-cover editorial-img"
                  style="filter:sepia(8%) saturate(85%) brightness(0.98); display:block;"
                  loading="lazy"
                />
              </div>
            </>
          )}
        </article>
      );
    })}
  </div>

  <!-- Bottom pull quote + CTA -->
  <div class="max-w-3xl mx-auto px-6 sm:px-8 text-center mt-20">
    <p class="font-playfair italic mb-8" style="font-size:1.2rem; color:#7a6552;">
      Not sure what you need? Give us a call — no pressure, just honest advice.
    </p>
    <a
      href="#quote"
      class="inline-flex items-center gap-3 font-nunito font-bold text-white px-8 py-4 rounded-lg transition-opacity hover:opacity-90"
      style="background:#2d5a27; font-size:1rem; box-shadow:0 6px 28px rgba(45,90,39,0.22);"
    >
      Schedule a free visit
    </a>
  </div>

</section>

<style>
  .editorial-img {
    transition: transform 0.6s ease;
  }
  article:hover .editorial-img {
    transform: scale(1.02);
  }
</style>
