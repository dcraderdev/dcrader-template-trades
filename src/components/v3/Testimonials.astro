---
import { business } from '../../data/v3';
---

<section id="reviews" class="py-20 lg:py-28" style="background:#fef8f0;" aria-labelledby="reviews-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Section header -->
    <div class="text-center mb-14">
      <span class="inline-block font-nunito font-semibold text-sm uppercase tracking-widest mb-3" style="color:#c4622d;">
        Real Customers
      </span>
      <h2
        id="reviews-heading"
        class="font-playfair font-bold mb-4 leading-tight"
        style="font-size: clamp(2rem, 4.5vw, 3.25rem); color:#2d5a27;"
      >
        What Columbus Families Say
      </h2>
      <p class="font-nunito max-w-xl mx-auto" style="color:#8b7355; font-size:1.05rem;">
        Forty-four years of trusting relationships — one honest job at a time.
      </p>

      <!-- Google aggregate badge -->
      <div class="inline-flex items-center gap-3 mt-6 rounded-xl px-5 py-3 border" style="background:#f5ead8; border-color:#e8d5b8;">
        <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        <div>
          <div class="font-nunito font-bold text-sm leading-none" style="color:#2c2318;">4.9 / 5.0 on Google</div>
          <div class="font-nunito text-xs leading-none mt-0.5" style="color:#8b7355;">300+ verified reviews</div>
        </div>
        <div class="flex gap-0.5" aria-label="4.9 out of 5 stars">
          {[1,2,3,4,5].map(() => (
            <svg class="w-4 h-4" fill="#f59e0b" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>
      </div>
    </div>

    <!-- Letter-style testimonial cards -->
    <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" role="list" aria-label="Customer testimonials">
      {business.testimonials.map((review, i) => (
        <li>
          <article
            class="h-full rounded-2xl p-7 flex flex-col border transition-all duration-300 hover:shadow-lg"
            style="background:#fef8f0; border-color:#e8d5b8; border-top: 3px solid #2d5a27;"
          >
            <!-- Stars -->
            <div class="flex gap-1 mb-5" role="img" aria-label={`${review.rating} out of 5 stars`}>
              {Array.from({ length: review.rating }).map(() => (
                <svg class="w-4 h-4" fill="#f59e0b" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>

            <!-- Large opening quote mark — warm green -->
            <div class="font-playfair leading-none mb-3 select-none" style="font-size:3.5rem; color:#2d5a27; opacity:0.25; line-height:1;" aria-hidden="true">"</div>

            <!-- Quote body — personal, letter-style -->
            <blockquote class="flex-1 mb-6">
              <p class="font-playfair italic leading-relaxed" style="color:#2c2318; font-size:1.025rem;">
                {review.text}
              </p>
            </blockquote>

            <!-- Author footer — "handwritten" italic serif name -->
            <footer class="flex items-center gap-3 pt-5 border-t" style="border-color:#e8d5b8;">
              <!-- Initials circle -->
              <div
                class="w-10 h-10 rounded-full flex items-center justify-center font-playfair font-bold text-white text-sm flex-shrink-0"
                style="background:#2d5a27;"
                aria-hidden="true"
              >
                {review.name.charAt(0)}
              </div>
              <div class="flex-1 min-w-0">
                <!-- Name in italic Playfair — "handwritten" feel -->
                <cite class="not-italic font-playfair italic font-semibold block leading-none" style="color:#2c2318; font-size:1.05rem;">{review.name}</cite>
                <p class="font-nunito text-xs mt-0.5 truncate" style="color:#8b7355;">{review.neighborhood}, Columbus</p>
              </div>
              <!-- Verified badge -->
              <div class="flex-shrink-0">
                <span class="inline-flex items-center gap-1 font-nunito font-semibold text-xs px-2 py-1 rounded-full" style="background:#e8f5e3; color:#2d5a27;">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  Verified
                </span>
              </div>
            </footer>
          </article>
        </li>
      ))}
    </ul>

    <!-- Bottom CTA -->
    <div class="text-center mt-12">
      <a
        href={business.social.google}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 font-nunito font-bold text-sm px-6 py-3 rounded-xl border-2 transition-all hover:opacity-80"
        style="color:#2d5a27; border-color:#2d5a27;"
      >
        Read More Reviews on Google
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>
