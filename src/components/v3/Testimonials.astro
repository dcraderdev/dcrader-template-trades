---
import { business } from '../../data/v3';

// Different subtle rotations for the postcard feel
const rotations = ['-1.2deg', '0.8deg', '-0.5deg', '1.4deg', '-1.8deg', '0.6deg'];
---

<section id="reviews" class="py-20 lg:py-28 overflow-hidden" style="background:#fef8f0;" aria-labelledby="reviews-heading">
  <div class="max-w-7xl mx-auto px-6 sm:px-8">

    <!-- Section header -->
    <div class="max-w-2xl mx-auto text-center mb-16">
      <p class="font-nunito text-xs mb-4" style="color:#a08060; letter-spacing:0.12em;">— real words, real neighbors —</p>
      <h2
        id="reviews-heading"
        class="font-playfair italic leading-tight mb-6"
        style="font-size:clamp(2.25rem, 5vw, 3.5rem); color:#2c2318;"
      >
        Letters from Columbus families.
      </h2>
      <p class="font-nunito leading-relaxed" style="color:#7a6552;">
        Forty-four years of trusting relationships — one honest job at a time. These are the neighbors who let us into their homes.
      </p>

      <!-- Google rating pill -->
      <div
        class="inline-flex items-center gap-3 mt-8 px-5 py-3 rounded-full"
        style="background:#f5ead8; border: 1px solid #d4b896;"
      >
        <div class="flex gap-0.5" aria-label="4.9 out of 5 stars">
          {[1,2,3,4,5].map(() => (
            <svg class="w-4 h-4" fill="#c4622d" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>
        <p class="font-nunito font-semibold text-sm" style="color:#2c2318;">4.9 on Google · 300+ reviews</p>
      </div>
    </div>

    <!-- Letter/postcard grid -->
    <ul
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10"
      role="list"
      aria-label="Customer letters and reviews"
    >
      {business.testimonials.map((review, i) => (
        <li
          class="letter-card"
          style={`transform: rotate(${rotations[i % rotations.length]});`}
        >
          <article
            class="relative rounded-sm p-8 flex flex-col"
            style="background:#fef9f2; border: 1px solid #dcc9a8; box-shadow: 3px 4px 18px rgba(44,35,24,0.12), 0 1px 3px rgba(44,35,24,0.08);"
            aria-label={`Review from ${review.name}, ${review.neighborhood}`}
          >
            <!-- Top tape strip simulation -->
            <div
              class="absolute -top-3 left-1/2 -translate-x-1/2 w-12 h-5 rounded-sm opacity-40"
              style="background:#c4b090;"
              aria-hidden="true"
            ></div>

            <!-- Postmark-style stamp area -->
            <div
              class="absolute top-5 right-5 w-12 h-12 rounded-sm flex flex-col items-center justify-center"
              style="border: 1.5px solid #c4622d; opacity:0.5;"
              aria-hidden="true"
            >
              <span class="font-nunito text-xs font-bold" style="color:#c4622d; font-size:0.5rem; letter-spacing:0.05em;">COL</span>
              <span class="font-nunito text-xs font-bold" style="color:#c4622d; font-size:0.5rem;">OH</span>
            </div>

            <!-- Opening — "Dear..." -->
            <p
              class="font-playfair italic mb-4"
              style="font-size:0.85rem; color:#a08060;"
            >
              Dear Three Generations,
            </p>

            <!-- The letter body -->
            <blockquote class="flex-1 mb-6">
              <!-- Large open quote -->
              <span
                class="block font-playfair leading-none mb-2 select-none"
                style="font-size:3rem; color:#2d5a27; opacity:0.2; line-height:0.8;"
                aria-hidden="true"
              >
                "
              </span>
              <p
                class="font-playfair italic leading-[1.75]"
                style="color:#3a2e22; font-size:1rem;"
              >
                {review.text}
              </p>
            </blockquote>

            <!-- Signature footer -->
            <footer style="border-top: 1px dashed #d4b896; padding-top:1rem;">
              <p
                class="font-playfair mb-0.5"
                style="font-style:italic; font-size:1.1rem; color:#2c2318; transform:rotate(-0.5deg) skewX(-3deg); display:inline-block;"
              >
                {review.name}
              </p>
              <p class="font-nunito text-xs" style="color:#a08060;">
                {review.neighborhood}, Columbus · ★ {review.rating}.0
              </p>
            </footer>
          </article>
        </li>
      ))}
    </ul>

    <!-- Bottom link -->
    <div class="text-center mt-14">
      <a
        href={business.social.google}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 font-nunito font-semibold text-sm transition-opacity hover:opacity-70"
        style="color:#2d5a27; text-decoration:underline; text-underline-offset:4px;"
      >
        Read more reviews on Google
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  .letter-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .letter-card:hover {
    transform: rotate(0deg) translateY(-4px) !important;
    z-index: 10;
    position: relative;
  }
</style>
