---
import { business } from '../../data/v4';
---

<footer class="bg-[#080808] border-t-4 border-emergency-red" aria-label="Site footer">

  <!-- Giant phone CTA band -->
  <div class="bg-[#050505] border-b border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14 text-center">
      <p class="font-body font-black text-emergency-red text-xs uppercase tracking-[0.3em] mb-4">
        EMERGENCY? DON'T WAIT. CALL NOW.
      </p>
      <a
        href={business.phoneHref}
        class="inline-block font-anton text-white hover:text-emergency-red transition-colors leading-none tracking-wider"
        style="font-size: clamp(3rem, 12vw, 9rem); text-shadow: 0 0 100px rgba(239,68,68,0.2);"
        aria-label={`Call now: ${business.phone}`}
      >
        {business.phone}
      </a>
      <div class="flex items-center justify-center gap-4 mt-6">
        <span class="relative flex h-2.5 w-2.5 flex-shrink-0" aria-hidden="true">
          <span class="animate-ping absolute inline-flex h-full w-full bg-emergency-red opacity-75"></span>
          <span class="relative inline-flex h-2.5 w-2.5 bg-emergency-red"></span>
        </span>
        <p class="font-body font-black text-gray-400 text-xs uppercase tracking-[0.25em]">
          {business.emergencyNote}
        </p>
      </div>
    </div>
  </div>

  <!-- Info grid -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6">

      <!-- Brand column -->
      <div>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-8 bg-emergency-red flex items-center justify-center flex-shrink-0" aria-hidden="true">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
            </svg>
          </div>
          <span class="font-anton text-white text-xl uppercase tracking-wider">{business.shortName}</span>
        </div>
        <p class="font-body text-gray-500 text-sm leading-relaxed mb-6">
          {business.footer.description}
        </p>
        <dl class="space-y-2">
          {business.hours.map(h => (
            <div>
              <dt class="font-body text-gray-600 text-xs uppercase tracking-widest">{h.day}</dt>
              <dd class="font-body font-bold text-white text-sm">{h.hours}</dd>
            </div>
          ))}
        </dl>
        <div class="mt-4 border border-emergency-red/30 bg-emergency-red/5 px-4 py-3">
          <p class="font-body font-black text-emergency-red text-xs uppercase tracking-widest">
            LIVE DISPATCHER — EVERY CALL ANSWERED
          </p>
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="font-anton text-white text-lg uppercase tracking-wider mb-5">QUICK ACCESS</h3>
        <nav aria-label="Footer navigation">
          <ul class="space-y-0 list-none p-0 m-0 divide-y divide-white/5" role="list">
            {business.footer.links.map(link => (
              <li>
                <a
                  href={link.href}
                  class="flex items-center gap-3 py-3 font-body font-bold text-gray-400 hover:text-emergency-red transition-colors text-sm uppercase tracking-wider"
                >
                  <span class="w-1.5 h-1.5 bg-emergency-red flex-shrink-0" aria-hidden="true"></span>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- Contact + social -->
      <div>
        <h3 class="font-anton text-white text-lg uppercase tracking-wider mb-5">CONTACT</h3>
        <div class="space-y-3 mb-6">
          <a
            href={business.phoneHref}
            class="flex items-center gap-3 font-body font-bold text-white hover:text-emergency-red transition-colors text-sm group"
            aria-label={`Call ${business.phone}`}
          >
            <svg class="w-4 h-4 text-emergency-red flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
            </svg>
            {business.phone}
          </a>
          <a
            href={business.emailHref}
            class="flex items-center gap-3 font-body text-gray-500 hover:text-white transition-colors text-sm"
            aria-label={`Email ${business.email}`}
          >
            <svg class="w-4 h-4 text-emergency-red flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
            </svg>
            {business.email}
          </a>
          <p class="flex items-center gap-3 font-body text-gray-500 text-sm">
            <svg class="w-4 h-4 text-emergency-red flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
            </svg>
            {business.address}
          </p>
        </div>

        <!-- Social icons row -->
        <div class="flex items-center gap-4 mt-6" aria-label="Social media links">
          {[
            { href: business.social.google, label: "Google Maps", icon: `<path d="M12.545 10.239v3.821h5.445c-.712 2.315-2.647 3.972-5.445 3.972a6.033 6.033 0 1 1 0-12.064 5.97 5.97 0 0 1 3.985 1.53l2.816-2.816A9.96 9.96 0 0 0 12.545 2C7.021 2 2.543 6.477 2.543 12s4.478 10 10.002 10c8.396 0 10.249-7.85 9.426-11.748l-9.426-.013z"/>` },
            { href: business.social.yelp, label: "Yelp", icon: `<path d="M20.996 12.042c.024.3-.096.58-.331.745l-4.227 2.94c-.44.305-.987.1-1.228-.245-.088-.125-.35-.532-.35-.532s.044-.472.083-.679c.04-.208.152-.524.152-.524l.78-2.45c.038-.12.09-.16.18-.185a.72.72 0 0 1 .23-.015l4.282.61c.26.037.452.211.429.335zm-7.31 6.773l-.748 4.906c-.055.36-.315.579-.617.579-.08 0-.156-.016-.23-.048L8.17 22.48a.682.682 0 0 1-.384-.77l1.22-4.829c.062-.247.208-.403.4-.478.192-.075.41-.066.606.034l3.226 1.544a.69.69 0 0 1 .448.834z"/>` },
            { href: business.social.facebook, label: "Facebook", icon: `<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>` },
            { href: business.social.instagram, label: "Instagram", icon: `<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>` },
          ].map(s => (
            <a
              href={s.href}
              class="text-gray-600 hover:text-emergency-red transition-colors"
              aria-label={s.label}
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={s.icon} />
            </a>
          ))}
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom strip -->
  <div class="border-t border-white/5 bg-[#050505]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="font-body text-gray-700 text-xs uppercase tracking-wider text-center sm:text-left">
        {business.footer.copyright}
      </p>
      <p class="font-body text-gray-700 text-xs uppercase tracking-wider text-center sm:text-right">
        {business.license} &nbsp;·&nbsp; Licensed &amp; Insured &nbsp;·&nbsp; $2M Liability
      </p>
    </div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 pb-5 text-center">
      <p class="font-body text-gray-700 text-xs uppercase tracking-wider">
        Built by <a href="https://dcrader.dev" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-emergency-red transition-colors">Donovan Crader · dcrader.dev</a>
      </p>
    </div>
  </div>

</footer>
