---
import { business } from '../../data/v4';
---

<footer class="bg-emergency-black border-t border-white/10" aria-label="Site footer">

  <!-- Top red stripe -->
  <div class="h-1 bg-emergency-red w-full" aria-hidden="true"></div>

  <!-- Main footer content -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Brand + phone -->
      <div class="md:col-span-1">
        <a href="/" class="inline-block mb-5" aria-label={`${business.name} home`}>
          <span class="font-anton text-white text-2xl uppercase tracking-wider">{business.shortName}</span>
        </a>
        <p class="font-body text-gray-500 text-sm leading-relaxed mb-6">
          {business.footer.description}
        </p>
        <!-- Big phone number -->
        <a
          href={business.phoneHref}
          class="block font-anton text-emergency-red hover:text-red-400 transition-colors leading-none tracking-wider"
          style="font-size: clamp(1.75rem, 5vw, 3rem);"
          aria-label={`Call us now at ${business.phone}`}
        >
          {business.phone}
        </a>
        <p class="font-body text-gray-600 text-xs uppercase tracking-widest mt-2">
          {business.emergencyNote}
        </p>
      </div>

      <!-- Hours -->
      <div>
        <h3 class="font-anton text-white text-lg uppercase tracking-wider mb-5">Hours</h3>
        <dl class="space-y-2">
          {business.hours.map(h => (
            <div class="flex flex-col">
              <dt class="font-body text-gray-500 text-xs uppercase tracking-widest">{h.day}</dt>
              <dd class="font-body text-white font-semibold text-sm">{h.hours}</dd>
            </div>
          ))}
        </dl>
        <div class="mt-5 border border-emergency-red/30 px-4 py-3">
          <p class="font-body text-emergency-red text-xs font-bold uppercase tracking-widest">
            Live Dispatcher — Every Call Answered
          </p>
        </div>
      </div>

      <!-- Links + contact -->
      <div>
        <h3 class="font-anton text-white text-lg uppercase tracking-wider mb-5">Quick Links</h3>
        <nav aria-label="Footer navigation">
          <ul class="space-y-2 list-none p-0 m-0" role="list">
            {business.footer.links.map(link => (
              <li>
                <a
                  href={link.href}
                  class="font-body text-gray-400 hover:text-emergency-red transition-colors text-sm uppercase tracking-wider"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <!-- Social icons -->
        <div class="mt-6 flex items-center gap-4" aria-label="Social media links">
          <a
            href={business.social.google}
            class="text-gray-600 hover:text-emergency-red transition-colors"
            aria-label="Google Maps"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12.545 10.239v3.821h5.445c-.712 2.315-2.647 3.972-5.445 3.972a6.033 6.033 0 1 1 0-12.064 5.97 5.97 0 0 1 3.985 1.53l2.816-2.816A9.96 9.96 0 0 0 12.545 2C7.021 2 2.543 6.477 2.543 12s4.478 10 10.002 10c8.396 0 10.249-7.85 9.426-11.748l-9.426-.013z"/>
            </svg>
          </a>
          <a
            href={business.social.yelp}
            class="text-gray-600 hover:text-emergency-red transition-colors"
            aria-label="Yelp"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.996 12.042c.024.3-.096.58-.331.745l-4.227 2.94c-.44.305-.987.1-1.228-.245-.088-.125-.35-.532-.35-.532s.044-.472.083-.679c.04-.208.152-.524.152-.524l.78-2.45c.038-.12.09-.16.18-.185a.72.72 0 0 1 .23-.015l4.282.61c.26.037.452.211.429.335zm-7.31 6.773l-.748 4.906c-.055.36-.315.579-.617.579-.08 0-.156-.016-.23-.048L8.17 22.48a.682.682 0 0 1-.384-.77l1.22-4.829c.062-.247.208-.403.4-.478.192-.075.41-.066.606.034l3.226 1.544a.69.69 0 0 1 .448.834zm-8.57-1.89l-4.5-2.118A.69.69 0 0 1 .22 14.1c.01-.104.038-.205.09-.297l1.935-3.444c.148-.265.404-.377.636-.304l4.596 1.45c.228.072.368.26.38.482.01.222-.107.42-.31.527l-1.74.93-.71.432c-.2.121-.295.237-.362.451-.067.213-.067.213-.12.505l.01.003zM3.79 9.65 1.16 6.55a.686.686 0 0 1-.076-.72c.05-.112.132-.204.237-.27L5.24 3.276c.27-.164.598-.106.793.14l2.855 3.502c.14.172.184.397.117.608-.067.21-.237.364-.452.408L4.47 8.619c-.302.062-.564-.148-.68-.97zM13.1 1.88l-.356 5.127a.683.683 0 0 1-.502.616c-.22.063-.449.006-.62-.153L8.495 4.51c-.214-.197-.256-.508-.1-.757L10.623.568a.683.683 0 0 1 .72-.305c.107.024.206.076.289.155L13.023 1.4a.686.686 0 0 1 .077.48z"/>
            </svg>
          </a>
          <a
            href={business.social.facebook}
            class="text-gray-600 hover:text-emergency-red transition-colors"
            aria-label="Facebook"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a
            href={business.social.instagram}
            class="text-gray-600 hover:text-emergency-red transition-colors"
            aria-label="Instagram"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/5">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="font-body text-gray-700 text-xs text-center sm:text-left">
        {business.footer.copyright}
      </p>
      <p class="font-body text-gray-700 text-xs text-center sm:text-right">
        {business.license} &nbsp;·&nbsp; Licensed &amp; Insured
      </p>
    </div>
  </div>

</footer>
