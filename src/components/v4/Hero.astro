---
import { business } from '../../data/v4';
---

<section
  class="emergency-hero-bg relative min-h-[100svh] flex flex-col justify-center overflow-hidden"
  aria-labelledby="hero-heading"
>
  <!-- Red top stripe -->
  <div class="absolute top-0 left-0 right-0 h-1 bg-emergency-red z-10" aria-hidden="true"></div>

  <!-- Faint diagonal watermark text -->
  <div
    class="absolute right-[-5%] bottom-10 font-anton text-[22vw] leading-none text-white/[0.02] select-none pointer-events-none uppercase tracking-widest"
    aria-hidden="true"
  >
    911
  </div>

  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 w-full pt-32 pb-28 text-center lg:text-left">

    <!-- Live dispatch badge -->
    <div class="inline-flex items-center gap-3 mb-8">
      <span class="relative flex h-3 w-3 flex-shrink-0" aria-hidden="true">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emergency-red opacity-75"></span>
        <span class="relative inline-flex rounded-full h-3 w-3 bg-emergency-red"></span>
      </span>
      <span class="font-body font-bold text-white text-sm tracking-widest uppercase">
        {business.hero.eyebrow}
      </span>
    </div>

    <!-- Main headline -->
    <h1 id="hero-heading" class="font-anton uppercase leading-none tracking-wider mb-4">
      <span class="block text-white" style="font-size: clamp(3rem, 10vw, 7.5rem);">
        {business.hero.headlineTop}
      </span>
      <span class="block text-white" style="font-size: clamp(3rem, 10vw, 7.5rem);">
        {business.hero.headlineBottom}
      </span>
    </h1>

    <!-- Phone number — the hero -->
    <div class="my-8 lg:my-10">
      <a
        href={business.phoneHref}
        class="inline-block font-anton text-emergency-red animate-ring-pulse rounded-lg px-4 py-2 hover:text-red-400 transition-colors leading-none"
        style="font-size: clamp(3.5rem, 12vw, 8.75rem);"
        aria-label="Call us now at (404) 555-0911"
      >
        {business.phone}
      </a>
    </div>

    <!-- Urgency line -->
    <p class="font-body font-bold text-white uppercase tracking-widest mb-6" style="font-size: clamp(0.85rem, 2vw, 1.125rem);">
      {business.hero.urgencyLine}
    </p>

    <!-- Response guarantee badge -->
    <div class="inline-flex items-center gap-3 border border-emergency-red/60 px-5 py-2.5 mb-10">
      <svg class="w-5 h-5 text-emergency-red flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
      </svg>
      <span class="font-body font-bold text-white text-sm uppercase tracking-widest">
        {business.hero.responseGuarantee}
      </span>
    </div>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row gap-4 mb-14 justify-center lg:justify-start">
      <a
        href={business.phoneHref}
        class="flex items-center justify-center gap-3 bg-emergency-red hover:bg-emergency-red-dark text-white font-anton text-2xl tracking-wider uppercase px-10 py-5 transition-colors shadow-[0_8px_32px_rgba(239,68,68,0.4)]"
        aria-label={`Call now at ${business.phone}`}
      >
        <svg class="w-6 h-6 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
        </svg>
        {business.hero.cta}
      </a>
      <a
        href={`sms:${business.phone.replace(/\D/g, '')}`}
        class="flex items-center justify-center gap-3 border-2 border-white/20 hover:border-emergency-red/60 text-gray-400 hover:text-white font-body font-semibold text-base uppercase tracking-widest px-8 py-5 transition-colors"
      >
        <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z"/>
        </svg>
        {business.hero.ctaSecondary}
      </a>
    </div>

    <!-- Trust badges -->
    <div class="flex flex-wrap gap-3 justify-center lg:justify-start" role="list" aria-label="Trust certifications">
      {business.badges.map(badge => (
        <div
          class="flex flex-col items-center border border-white/10 hover:border-emergency-red/40 transition-colors px-5 py-3 min-w-[90px]"
          role="listitem"
        >
          <span class="font-anton text-emergency-red text-xl tracking-wider uppercase leading-none">{badge.label}</span>
          <span class="font-body text-gray-500 text-xs uppercase tracking-wider mt-1 leading-none">{badge.sublabel}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom separator line -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-emergency-red/30" aria-hidden="true"></div>
</section>

<style>
  .emergency-hero-bg {
    background-color: #080808;
    background-image: repeating-linear-gradient(
      -45deg,
      transparent 0px,
      transparent 20px,
      rgba(239, 68, 68, 0.04) 20px,
      rgba(239, 68, 68, 0.04) 40px
    );
  }
</style>
