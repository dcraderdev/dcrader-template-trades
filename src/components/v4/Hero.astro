---
import { business } from '../../data/v4';
---

<section
  class="hero-dispatch-bg relative min-h-screen flex flex-col justify-center overflow-hidden"
  aria-labelledby="v4-hero-heading"
>

  <!-- Diagonal hazard stripe accent — top left -->
  <div class="absolute top-0 left-0 w-full h-2 bg-emergency-red z-10" aria-hidden="true"></div>

  <!-- Giant watermark 911 -->
  <div
    class="absolute right-[-8%] bottom-[-5%] font-anton leading-none text-white/[0.025] select-none pointer-events-none uppercase"
    style="font-size: clamp(10rem, 40vw, 28rem);"
    aria-hidden="true"
  >
    911
  </div>

  <!-- Red corner accent -->
  <div class="absolute top-0 right-0 w-0 h-0" aria-hidden="true"
    style="border-top: 120px solid #ef4444; border-left: 120px solid transparent; opacity: 0.15;">
  </div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 w-full py-20 text-center">

    <!-- LIVE DISPATCH badge -->
    <div class="inline-flex items-center gap-3 border border-emergency-red/50 bg-emergency-red/10 px-5 py-2.5 mb-10">
      <span class="relative flex h-2.5 w-2.5 flex-shrink-0" aria-hidden="true">
        <span class="animate-ping absolute inline-flex h-full w-full bg-emergency-red opacity-75"></span>
        <span class="relative inline-flex h-2.5 w-2.5 bg-emergency-red"></span>
      </span>
      <span class="font-body font-black text-white text-xs uppercase tracking-[0.3em]">
        LIVE DISPATCH · 24/7 · 365 DAYS
      </span>
    </div>

    <!-- Main question -->
    <h1 id="v4-hero-heading" class="font-anton uppercase leading-none tracking-wider mb-0">
      <span class="block text-white" style="font-size: clamp(3.5rem, 10vw, 8rem);">
        PLUMBING
      </span>
      <span class="block text-white" style="font-size: clamp(3.5rem, 10vw, 8rem);">
        EMERGENCY?
      </span>
    </h1>

    <!-- THE phone number — hero element -->
    <div class="my-6 md:my-8">
      <a
        href={business.phoneHref}
        class="inline-block font-anton text-emergency-red hover:text-red-400 transition-colors leading-none tracking-wider"
        style="font-size: clamp(3rem, 14vw, 11rem); text-shadow: 0 0 80px rgba(239,68,68,0.3);"
        aria-label={`Call us now: ${business.phone}`}
      >
        {business.phone}
      </a>
    </div>

    <!-- Response stat bar -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-0 mb-10 border border-white/10">
      <div class="flex-1 flex flex-col items-center py-5 px-6 border-b sm:border-b-0 sm:border-r border-white/10">
        <span class="font-anton text-emergency-red leading-none tracking-wider" style="font-size: clamp(2rem, 5vw, 3.5rem);">
          47 MIN
        </span>
        <span class="font-body font-bold text-gray-400 text-xs uppercase tracking-[0.2em] mt-1.5">
          AVG RESPONSE TIME
        </span>
      </div>
      <div class="flex-1 flex flex-col items-center py-5 px-6 border-b sm:border-b-0 sm:border-r border-white/10">
        <span class="font-anton text-emergency-red leading-none tracking-wider" style="font-size: clamp(2rem, 5vw, 3.5rem);">
          3 RINGS
        </span>
        <span class="font-body font-bold text-gray-400 text-xs uppercase tracking-[0.2em] mt-1.5">
          WE ANSWER EVERY CALL
        </span>
      </div>
      <div class="flex-1 flex flex-col items-center py-5 px-6">
        <span class="font-anton text-emergency-red leading-none tracking-wider" style="font-size: clamp(2rem, 5vw, 3.5rem);">
          24/7
        </span>
        <span class="font-body font-bold text-gray-400 text-xs uppercase tracking-[0.2em] mt-1.5">
          NO VOICEMAIL EVER
        </span>
      </div>
    </div>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
      <a
        href={business.phoneHref}
        class="flex items-center justify-center gap-3 bg-emergency-red hover:bg-red-700 text-white font-anton tracking-widest uppercase px-12 py-5 transition-colors w-full sm:w-auto"
        style="font-size: clamp(1.1rem, 2.5vw, 1.5rem); box-shadow: 0 8px 40px rgba(239,68,68,0.45);"
        aria-label={`Call now at ${business.phone}`}
      >
        <svg class="w-6 h-6 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
        </svg>
        CALL NOW
      </a>
      <a
        href={`sms:${business.phone.replace(/\D/g, '')}`}
        class="flex items-center justify-center gap-3 border-2 border-emergency-red text-white hover:bg-emergency-red/10 font-anton tracking-widest uppercase px-12 py-5 transition-colors w-full sm:w-auto"
        style="font-size: clamp(1.1rem, 2.5vw, 1.5rem);"
      >
        <svg class="w-6 h-6 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z"/>
        </svg>
        TEXT US
      </a>
    </div>

    <!-- Trust badges -->
    <div class="flex flex-wrap gap-3 justify-center" role="list" aria-label="Service guarantees">
      {business.badges.map(badge => (
        <div
          class="border border-white/15 hover:border-emergency-red/60 px-5 py-3 transition-colors"
          role="listitem"
        >
          <span class="block font-anton text-emergency-red text-lg tracking-wider uppercase leading-none">{badge.label}</span>
          <span class="block font-body text-gray-500 text-xs uppercase tracking-wider mt-1 leading-none">{badge.sublabel}</span>
        </div>
      ))}
    </div>

  </div>

  <!-- Bottom red rule -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-emergency-red/40" aria-hidden="true"></div>

</section>

<style>
  .hero-dispatch-bg {
    background-color: #080808;
    background-image:
      repeating-linear-gradient(
        -55deg,
        transparent 0px,
        transparent 18px,
        rgba(239, 68, 68, 0.035) 18px,
        rgba(239, 68, 68, 0.035) 36px
      );
  }
</style>
