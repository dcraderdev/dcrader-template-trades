---
import { business } from '../../data/v4';

// Case file numbers for the dispatch-file look
const caseNums = ["CF-2024-0891", "CF-2024-1204", "CF-2025-0033"];
const outcomes = ["CONTAINED", "CLEARED", "SEALED"];
const durations = ["40 MIN", "55 MIN", "3 HRS"];
---

<section
  id="projects"
  class="bg-[#080808] border-t border-white/10"
  aria-labelledby="projects-heading"
>

  <!-- Header -->
  <div class="border-b border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
      <p class="font-body font-black text-emergency-red text-xs uppercase tracking-[0.3em] mb-2">
        CLOSED CASE FILES — FIELD DOCUMENTATION
      </p>
      <h2
        id="projects-heading"
        class="font-anton text-white uppercase tracking-wider leading-none"
        style="font-size: clamp(2.5rem, 7vw, 5rem);"
      >
        EMERGENCIES<br/>WE STOPPED
      </h2>
    </div>
  </div>

  <!-- Case file entries -->
  <div
    class="max-w-6xl mx-auto px-4 sm:px-6 py-10 space-y-8"
    role="list"
    aria-label="Emergency case files"
  >
    {business.projects.map((project, i) => {
      const caseNum = caseNums[i] ?? `CF-2025-00${String(i + 10)}`;
      const outcome = outcomes[i] ?? "RESOLVED";
      const duration = durations[i] ?? "< 60 MIN";
      return (
        <article
          class="border border-white/10 hover:border-emergency-red/50 transition-colors overflow-hidden"
          role="listitem"
          aria-label={`Case file: ${project.title}`}
        >
          <!-- Case file header bar -->
          <div class="bg-[#0e0e0e] border-b border-white/10 px-5 py-4 flex flex-wrap items-center gap-x-6 gap-y-2 justify-between">
            <div class="flex items-center gap-4">
              <span class="font-body font-black text-emergency-red text-xs uppercase tracking-[0.2em]">
                CASE: {caseNum}
              </span>
              <span class="text-white/20" aria-hidden="true">·</span>
              <span class="font-body font-bold text-gray-500 text-xs uppercase tracking-widest">
                {project.location.toUpperCase()}, GA
              </span>
            </div>
            <div class="flex items-center gap-3">
              <span class="font-body font-bold text-gray-500 text-xs uppercase tracking-widest">
                RESOLVED IN {duration}
              </span>
              <span class="inline-flex items-center gap-1.5 bg-emergency-red px-3 py-1 font-body font-black text-white text-xs uppercase tracking-widest">
                {outcome}
              </span>
            </div>
          </div>

          <!-- Before / After image pair -->
          <div class="grid grid-cols-2 gap-0">
            <div class="relative overflow-hidden border-r border-white/10">
              <img
                src={project.beforeImg}
                alt={`Before: ${project.title}`}
                class="w-full object-cover grayscale"
                style="height: clamp(180px, 25vw, 280px);"
                loading="lazy"
                  decoding="async"
                width="800"
                height="500"
              />
              <!-- Before overlay -->
              <div class="absolute inset-0 bg-black/50" aria-hidden="true"></div>
              <div class="absolute top-0 left-0 right-0 bottom-0 flex items-center justify-center" aria-hidden="true">
                <span class="font-anton text-white/30 uppercase tracking-widest" style="font-size: clamp(1.5rem, 4vw, 3rem);">BEFORE</span>
              </div>
              <div class="absolute top-3 left-3 bg-[#080808]/90 border border-white/20 px-3 py-1.5">
                <span class="font-body font-black text-white text-xs uppercase tracking-widest">SCENE: ACTIVE</span>
              </div>
            </div>
            <div class="relative overflow-hidden">
              <img
                src={project.afterImg}
                alt={`After: ${project.title}`}
                class="w-full object-cover"
                style="height: clamp(180px, 25vw, 280px);"
                loading="lazy"
                  decoding="async"
                width="800"
                height="500"
              />
              <div class="absolute top-3 right-3 bg-emergency-red px-3 py-1.5">
                <span class="font-body font-black text-white text-xs uppercase tracking-widest">SCENE: CLEARED</span>
              </div>
            </div>
          </div>

          <!-- Case detail row -->
          <div class="bg-[#0a0a0a] border-t border-white/10 px-5 py-5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <div>
              <h3 class="font-anton text-white uppercase tracking-wider leading-none" style="font-size: clamp(1rem, 2.5vw, 1.35rem);">
                {project.title}
              </h3>
              <p class="font-body text-gray-500 text-sm mt-2 leading-snug">
                {project.description}
              </p>
            </div>
            <a
              href={business.phoneHref}
              class="flex-shrink-0 flex items-center gap-2 border border-emergency-red/50 hover:border-emergency-red hover:bg-emergency-red/10 text-emergency-red font-body font-black text-xs uppercase tracking-[0.2em] px-5 py-3 transition-colors"
              aria-label={`Report similar emergency — call ${business.phone}`}
            >
              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
              </svg>
              REPORT SIMILAR
            </a>
          </div>

        </article>
      );
    })}
  </div>

  <!-- Bottom CTA -->
  <div class="border-t-2 border-emergency-red bg-emergency-red/5">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10 flex flex-col sm:flex-row items-center justify-between gap-6">
      <div>
        <p class="font-anton text-white uppercase tracking-wider leading-none" style="font-size: clamp(1.25rem, 3vw, 2rem);">
          YOUR EMERGENCY IS NEXT ON THE BOARD
        </p>
        <p class="font-body text-gray-500 text-xs uppercase tracking-widest mt-2">
          Dispatch available immediately — no hold, no wait
        </p>
      </div>
      <a
        href={business.phoneHref}
        class="flex-shrink-0 flex items-center gap-3 bg-emergency-red hover:bg-red-700 text-white font-anton tracking-widest uppercase px-10 py-5 transition-colors"
        style="font-size: clamp(1rem, 2vw, 1.25rem);"
        aria-label={`Open a case — call ${business.phone}`}
      >
        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
        </svg>
        OPEN A CASE NOW
      </a>
    </div>
  </div>

</section>
