---
import { business } from '../../data/v4';
---

<section
  id="services"
  class="py-20 bg-emergency-black border-t border-white/5"
  aria-labelledby="services-heading"
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6">

    <!-- Section header -->
    <div class="mb-12">
      <div class="flex items-center gap-4 mb-4">
        <div class="h-px flex-1 bg-emergency-red/40" aria-hidden="true"></div>
        <span class="font-body text-emergency-red text-xs font-bold uppercase tracking-[0.2em]">DISPATCH BOARD</span>
        <div class="h-px flex-1 bg-emergency-red/40" aria-hidden="true"></div>
      </div>
      <h2
        id="services-heading"
        class="font-anton text-white uppercase tracking-wider text-center"
        style="font-size: clamp(2.5rem, 6vw, 4.5rem);"
      >
        EMERGENCY SERVICES
      </h2>
      <p class="text-center text-gray-500 font-body mt-3 text-sm uppercase tracking-widest">
        Every call dispatched immediately — 24 hours, 365 days
      </p>
    </div>

    <!-- Dispatch board list -->
    <div class="border border-white/10" role="list" aria-label="Emergency services and response times">
      {business.services.map((service, i) => (
        <div
          class={`group flex items-baseline justify-between gap-4 px-6 py-5 border-b border-white/5 hover:bg-emergency-gray transition-colors ${i === business.services.length - 1 ? 'border-b-0' : ''}`}
          role="listitem"
        >
          <!-- Service name + description -->
          <div class="flex items-baseline gap-4 min-w-0">
            <span class="font-body text-emergency-red text-xs font-bold uppercase tracking-widest flex-shrink-0 w-4">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div class="min-w-0">
              <span class="font-anton text-white uppercase tracking-wider group-hover:text-emergency-red transition-colors" style="font-size: clamp(1.1rem, 2.5vw, 1.5rem);">
                {service.title.toUpperCase()}
              </span>
              <span class="hidden sm:inline font-body text-gray-600 text-sm ml-3">
                — {service.description}
              </span>
            </div>
          </div>

          <!-- Dots + response time -->
          <div class="flex items-center gap-3 flex-shrink-0">
            <span class="hidden md:block text-gray-700 font-body text-sm tracking-[0.3em]" aria-hidden="true">
              ············
            </span>
            <span class="font-body font-bold text-emergency-red text-sm uppercase tracking-widest whitespace-nowrap">
              {service.responseTime}
            </span>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="mt-10 text-center">
      <a
        href={business.phoneHref}
        class="inline-flex items-center gap-3 bg-emergency-red hover:bg-emergency-red-dark text-white font-anton text-xl tracking-wider uppercase px-10 py-4 transition-colors"
        aria-label={`Call now at ${business.phone}`}
      >
        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
        </svg>
        CALL {business.phone}
      </a>
    </div>
  </div>
</section>
