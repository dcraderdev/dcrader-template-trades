---
import { business } from '../../data/v4';
---

<section
  id="services"
  class="bg-[#080808] border-t-4 border-emergency-red"
  aria-labelledby="services-heading"
>

  <!-- Section header bar -->
  <div class="bg-[#0e0e0e] border-b border-white/10 px-4 sm:px-6 py-8">
    <div class="max-w-6xl mx-auto">
      <p class="font-body font-black text-emergency-red text-xs uppercase tracking-[0.3em] mb-2">
        DISPATCH BOARD — ACTIVE 24/7
      </p>
      <h2
        id="services-heading"
        class="font-anton text-white uppercase tracking-wider leading-none"
        style="font-size: clamp(2.5rem, 7vw, 5.5rem);"
      >
        EMERGENCY SERVICES
      </h2>
    </div>
  </div>

  <!-- Column header row -->
  <div class="border-b border-white/5 bg-[#050505]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid items-center py-3" style="grid-template-columns: 80px 1fr auto 120px;">
        <span class="font-body font-black text-gray-600 text-xs uppercase tracking-[0.2em]">PRIORITY</span>
        <span class="font-body font-black text-gray-600 text-xs uppercase tracking-[0.2em]">SERVICE</span>
        <span class="hidden md:block font-body font-black text-gray-600 text-xs uppercase tracking-[0.2em] text-right pr-6">RESPONSE</span>
        <span class="font-body font-black text-gray-600 text-xs uppercase tracking-[0.2em] text-right">DISPATCH</span>
      </div>
    </div>
  </div>

  <!-- Dispatch board rows -->
  <div
    class="max-w-6xl mx-auto px-4 sm:px-6 divide-y divide-white/5"
    role="list"
    aria-label="Emergency services priority dispatch board"
  >
    {business.services.map((service, i) => (
      <div
        class="group dispatch-row grid items-center py-0 hover:bg-emergency-red/5 transition-colors"
        style="grid-template-columns: 80px 1fr auto 120px;"
        role="listitem"
      >
        <!-- Priority badge -->
        <div class="py-5 pr-4 flex-shrink-0">
          <span class="inline-flex items-center justify-center w-12 h-7 bg-emergency-red font-anton text-white text-xs tracking-wider uppercase">
            {String(i + 1).padStart(2, '0')}
          </span>
        </div>

        <!-- Service name + description -->
        <div class="py-5 min-w-0 pr-4">
          <p class="font-anton text-white group-hover:text-emergency-red transition-colors uppercase tracking-wider leading-none" style="font-size: clamp(1rem, 2.5vw, 1.5rem);">
            {service.title}
          </p>
          <p class="font-body text-gray-600 text-xs uppercase tracking-wider mt-1 leading-none hidden sm:block">
            {service.description}
          </p>
        </div>

        <!-- Response time -->
        <div class="hidden md:flex py-5 pr-6 items-center justify-end">
          <span class="font-anton text-emergency-red uppercase tracking-wider text-right" style="font-size: clamp(0.85rem, 1.5vw, 1rem);">
            {service.responseTime.toUpperCase()}
          </span>
        </div>

        <!-- Dispatch / Call button -->
        <div class="py-4 flex justify-end">
          <a
            href={business.phoneHref}
            class="inline-flex items-center gap-1.5 bg-emergency-red hover:bg-red-700 text-white font-body font-black text-xs uppercase tracking-widest px-4 py-2.5 transition-colors whitespace-nowrap"
            aria-label={`Call now about ${service.title}`}
          >
            <svg class="w-3.5 h-3.5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
            </svg>
            CALL
          </a>
        </div>
      </div>
    ))}
  </div>

  <!-- Bottom CTA bar -->
  <div class="border-t-2 border-emergency-red bg-emergency-red/5">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-6">
      <div>
        <p class="font-anton text-white uppercase tracking-wider leading-none" style="font-size: clamp(1.25rem, 3vw, 2rem);">
          ALL DISPATCHES ANSWERED IMMEDIATELY
        </p>
        <p class="font-body text-gray-500 text-xs uppercase tracking-widest mt-2">
          No voicemail. No hold music. A real dispatcher, every time.
        </p>
      </div>
      <a
        href={business.phoneHref}
        class="flex-shrink-0 flex items-center gap-3 bg-emergency-red hover:bg-red-700 text-white font-anton tracking-widest uppercase px-10 py-5 transition-colors"
        style="font-size: clamp(1rem, 2vw, 1.25rem);"
        aria-label={`Call dispatch now at ${business.phone}`}
      >
        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
        </svg>
        CALL DISPATCH NOW
      </a>
    </div>
  </div>

</section>
