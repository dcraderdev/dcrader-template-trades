---
import { business } from '../../data/v4';

// Fake dispatch numbers and timestamps for log format
const dispatchMeta = [
  { id: "0042", time: "2:17 AM", date: "DEC 14" },
  { id: "0089", time: "11:52 PM", date: "JAN 03" },
  { id: "0127", time: "12:08 AM", date: "DEC 25" },
  { id: "0201", time: "8:43 PM", date: "NOV 29" },
  { id: "0318", time: "10:31 PM", date: "FEB 07" },
  { id: "0444", time: "3:02 AM", date: "MAR 12" },
];
---

<section
  id="reviews"
  class="bg-[#080808] border-t border-white/10"
  aria-labelledby="reviews-heading"
>

  <!-- Header -->
  <div class="border-b border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
      <p class="font-body font-black text-emergency-red text-xs uppercase tracking-[0.3em] mb-2">
        CLOSED DISPATCH LOG — VERIFIED CALLS
      </p>
      <h2
        id="reviews-heading"
        class="font-anton text-white uppercase tracking-wider leading-none"
        style="font-size: clamp(2.5rem, 7vw, 5rem);"
      >
        REAL CUSTOMERS.<br/>REAL EMERGENCIES.
      </h2>
    </div>
  </div>

  <!-- Dispatch log entries -->
  <div
    class="max-w-6xl mx-auto px-4 sm:px-6 py-0 divide-y divide-white/5"
    role="list"
    aria-label="Customer dispatch log reviews"
  >
    {business.testimonials.map((t, i) => {
      const meta = dispatchMeta[i] ?? { id: String(i + 100).padStart(4, '0'), time: "11:59 PM", date: "JAN 01" };
      return (
        <article
          class="group py-8 hover:bg-emergency-red/5 transition-colors -mx-4 sm:-mx-6 px-4 sm:px-6"
          role="listitem"
        >
          <!-- Dispatch header row -->
          <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mb-4">
            <span class="font-body font-black text-emergency-red text-xs uppercase tracking-[0.2em]">
              DISPATCH #{meta.id}
            </span>
            <span class="text-white/20 font-body text-xs" aria-hidden="true">·</span>
            <span class="font-body font-bold text-gray-500 text-xs uppercase tracking-widest">
              {t.neighborhood.toUpperCase()}, GA
            </span>
            <span class="text-white/20 font-body text-xs" aria-hidden="true">·</span>
            <span class="font-body font-bold text-gray-500 text-xs uppercase tracking-widest">
              {meta.date} @ {meta.time}
            </span>
            <span class="text-white/20 font-body text-xs" aria-hidden="true">·</span>
            <span class="inline-flex items-center gap-1 font-body font-black text-emergency-red text-xs uppercase tracking-widest">
              <span class="w-1.5 h-1.5 bg-emergency-red inline-block" aria-hidden="true"></span>
              RESOLVED
            </span>
          </div>

          <!-- Quote -->
          <blockquote class="font-body text-gray-200 leading-relaxed mb-4" style="font-size: clamp(0.9rem, 1.5vw, 1.05rem);">
            "{t.text}"
          </blockquote>

          <!-- Attribution + stars -->
          <footer class="flex items-center justify-between gap-4">
            <span class="font-anton text-white uppercase tracking-wider text-sm">
              — {t.name.toUpperCase()}
            </span>
            <div class="flex gap-0.5" aria-label={`${t.rating} out of 5 stars`}>
              {Array.from({ length: t.rating }).map(() => (
                <svg class="w-4 h-4 text-emergency-red flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
          </footer>
        </article>
      );
    })}
  </div>

  <!-- Bottom CTA bar -->
  <div class="border-t-2 border-emergency-red bg-emergency-red/5">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10 flex flex-col sm:flex-row items-center justify-between gap-6">
      <div>
        <p class="font-anton text-white uppercase tracking-wider leading-none" style="font-size: clamp(1.25rem, 3vw, 2rem);">
          JOIN THOUSANDS OF ATLANTA HOMEOWNERS
        </p>
        <p class="font-body text-gray-500 text-xs uppercase tracking-widest mt-2">
          Who call us first when it matters most
        </p>
      </div>
      <a
        href={business.phoneHref}
        class="flex-shrink-0 flex items-center gap-3 bg-emergency-red hover:bg-red-700 text-white font-anton tracking-widest uppercase px-10 py-5 transition-colors"
        style="font-size: clamp(1rem, 2vw, 1.25rem);"
        aria-label={`Call now at ${business.phone}`}
      >
        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1C9.61 21 3 14.39 3 6c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.24 1.02l-2.21 2.2z"/>
        </svg>
        CALL {business.phone}
      </a>
    </div>
  </div>

</section>
