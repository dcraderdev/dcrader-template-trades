---
import { business } from '../../data/v4';

// The questions panicked Atlanta homeowners actually call us at 2am asking
const faq = [
  {
    q: "Am I going to pay 3x because it's after midnight?",
    a: "No. Our rate at 2am is the same as our rate at 2pm — flat-rate, written in the quote before any work starts. You'll see the number before we touch a tool.",
    tag: "PRICING",
  },
  {
    q: "How fast can a tech actually be at my door?",
    a: "Inside I-285 we average 38 minutes from the call to the doorbell. Outside the perimeter, under 60. If we're late beyond 60 minutes, we discount the bill — and we tell you that on the phone.",
    tag: "RESPONSE",
  },
  {
    q: "Will I get someone qualified, or a junior at 3am?",
    a: "Every after-hours dispatch is a state-licensed master plumber. We do not run trainees on emergency calls — full stop. Your tech's license # is on the truck and on your invoice.",
    tag: "STAFFING",
  },
  {
    q: "What if you make the leak worse?",
    a: "We carry $2M general liability on every truck. If we damage anything in your home, you call our office and we settle it — not your insurance, not a fight.",
    tag: "INSURANCE",
  },
  {
    q: "Do you take card / Apple Pay at 3am?",
    a: "Yes. Every tech has a tap-to-pay reader in the truck. Card, Apple Pay, Google Pay, or check. We don't do cash-only.",
    tag: "PAYMENT",
  },
  {
    q: "What's actually covered by the warranty?",
    a: "Parts and labor for 12 months on every repair, 5 years on every replacement. If the same issue comes back inside that window, we fix it for $0.",
    tag: "WARRANTY",
  },
];
---

<section
  id="why-us"
  class="bg-[#080808] border-t border-white/10"
  aria-labelledby="why-us-heading"
>

  <!-- Section label + header -->
  <div class="border-b border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
      <p class="font-body font-black text-emergency-red text-xs uppercase tracking-[0.3em] mb-2">
        WHAT YOU'RE ACTUALLY THINKING AT 2 AM
      </p>
      <h2
        id="why-us-heading"
        class="font-anton text-white uppercase tracking-wider leading-none"
        style="font-size: clamp(2.5rem, 7vw, 5rem);"
      >
        ASK THE HARD QUESTIONS FIRST
      </h2>
      <p class="font-body text-gray-500 text-sm uppercase tracking-widest mt-4">
        Six straight answers — no asterisks.
      </p>
    </div>
  </div>

  <!-- Emergency FAQ accordion -->
  <div class="border-b border-white/10">
    <ul class="max-w-6xl mx-auto px-4 sm:px-6 py-2" role="list" aria-label="Frequently asked questions">
      {faq.map((item, i) => (
        <li class={`border-b border-white/8 ${i === faq.length - 1 ? 'border-b-0' : ''}`} role="listitem">
          <details class="group emergency-faq">
            <summary
              class="cursor-pointer list-none flex items-start gap-5 py-6 outline-none focus-visible:bg-emergency-red/5"
              aria-label={`${item.tag}: ${item.q}`}
            >
              <!-- Index -->
              <span
                class="font-anton text-emergency-red leading-none flex-shrink-0 select-none"
                style="font-size: clamp(2rem, 4vw, 3rem);"
                aria-hidden="true"
              >
                {String(i + 1).padStart(2, '0')}
              </span>

              <div class="flex-1 min-w-0">
                <span class="block font-body font-black text-emergency-red text-[10px] uppercase tracking-[0.3em] mb-2">
                  {item.tag}
                </span>
                <span class="block font-anton text-white uppercase tracking-wide leading-tight" style="font-size: clamp(1.05rem, 2vw, 1.5rem);">
                  {item.q}
                </span>
              </div>

              <!-- Plus / minus indicator -->
              <span
                class="font-anton text-emergency-red leading-none flex-shrink-0 self-center select-none transition-transform group-open:rotate-45"
                style="font-size: 2rem;"
                aria-hidden="true"
              >
                +
              </span>
            </summary>
            <div class="pl-[clamp(2rem,4vw,3rem)] pr-12 pb-7 -mt-1">
              <div class="border-l-2 border-emergency-red/40 pl-5">
                <p class="font-body text-gray-300 leading-relaxed text-sm sm:text-base max-w-3xl">
                  {item.a}
                </p>
              </div>
            </div>
          </details>
        </li>
      ))}
    </ul>
  </div>

  <!-- License/insurance bar -->
  <div class="bg-[#0a0a0a] border-b border-white/5">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-4">
        <div class="w-1 h-8 bg-emergency-red flex-shrink-0" aria-hidden="true"></div>
        <div>
          <p class="font-anton text-white uppercase tracking-wider text-sm leading-none">
            STATE LICENSED MASTER PLUMBERS
          </p>
          <p class="font-body text-gray-500 text-xs uppercase tracking-widest mt-1">
            {business.license} · $2M Liability Insurance on Every Call
          </p>
        </div>
      </div>
      <a
        href={business.phoneHref}
        class="flex items-center gap-2 border border-emergency-red/60 hover:border-emergency-red hover:bg-emergency-red/10 text-emergency-red font-body font-black text-xs uppercase tracking-[0.2em] px-5 py-3 transition-colors flex-shrink-0"
        aria-label={`Verify our license — Call ${business.phone}`}
      >
        VERIFY CREDENTIALS
      </a>
    </div>
  </div>

</section>
