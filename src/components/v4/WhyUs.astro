---
import { business } from '../../data/v4';

const metrics = [
  { stat: "60 MIN", label: "OR WE DISCOUNT\nYOUR BILL", detail: "Guaranteed on-site. Late = we pay.", border: true },
  { stat: "3 RINGS", label: "WE ANSWER.\nEVERY CALL.", detail: "No voicemail. No phone tree. Ever.", border: true },
  { stat: "24/7", label: "LIVE DISPATCH.\nALL YEAR.", detail: "365 days. Midnight. Christmas. Us.", border: true },
  { stat: "$0", label: "HIDDEN FEES.\nFLAT RATE.", detail: "Same price at 3am as 3pm.", border: false },
];
---

<section
  id="why-us"
  class="bg-[#080808] border-t border-white/10"
  aria-labelledby="why-us-heading"
>

  <!-- Section label + header -->
  <div class="border-b border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
      <p class="font-body font-black text-emergency-red text-xs uppercase tracking-[0.3em] mb-2">
        PERFORMANCE GUARANTEES — NOT SUGGESTIONS
      </p>
      <h2
        id="why-us-heading"
        class="font-anton text-white uppercase tracking-wider leading-none"
        style="font-size: clamp(2.5rem, 7vw, 5rem);"
      >
        WE BACK EVERY PROMISE
      </h2>
    </div>
  </div>

  <!-- 4 giant metric panels — full-width bands -->
  <div
    class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 border-b border-white/10"
    role="list"
    aria-label="Service guarantees"
  >
    {metrics.map((m, i) => (
      <div
        class={`group flex flex-col items-center justify-center text-center py-16 px-8 hover:bg-emergency-red/8 transition-colors border-b sm:border-b-0 border-white/10 ${i < 3 ? 'lg:border-r' : ''} ${i < 2 ? 'sm:border-r' : ''}`}
        role="listitem"
      >
        <!-- Giant stat number -->
        <div
          class="font-anton text-emergency-red leading-none tracking-wide group-hover:scale-105 transition-transform"
          style="font-size: clamp(3.5rem, 8vw, 6rem);"
          aria-label={m.stat}
        >
          {m.stat}
        </div>

        <!-- Label -->
        <div class="mt-4 font-anton text-white uppercase tracking-wider leading-tight text-center whitespace-pre-line" style="font-size: clamp(0.9rem, 1.5vw, 1.1rem);">
          {m.label}
        </div>

        <!-- Red rule -->
        <div class="w-12 h-0.5 bg-emergency-red my-4" aria-hidden="true"></div>

        <!-- Detail text -->
        <p class="font-body text-gray-500 text-xs uppercase tracking-wider leading-relaxed">
          {m.detail}
        </p>
      </div>
    ))}
  </div>

  <!-- License/insurance bar -->
  <div class="bg-[#0a0a0a] border-b border-white/5">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-4">
        <div class="w-1 h-8 bg-emergency-red flex-shrink-0" aria-hidden="true"></div>
        <div>
          <p class="font-anton text-white uppercase tracking-wider text-sm leading-none">
            STATE LICENSED MASTER PLUMBERS
          </p>
          <p class="font-body text-gray-500 text-xs uppercase tracking-widest mt-1">
            {business.license} · $2M Liability Insurance on Every Call
          </p>
        </div>
      </div>
      <a
        href={business.phoneHref}
        class="flex items-center gap-2 border border-emergency-red/60 hover:border-emergency-red hover:bg-emergency-red/10 text-emergency-red font-body font-black text-xs uppercase tracking-[0.2em] px-5 py-3 transition-colors flex-shrink-0"
        aria-label={`Verify our license — Call ${business.phone}`}
      >
        VERIFY CREDENTIALS
      </a>
    </div>
  </div>

</section>
