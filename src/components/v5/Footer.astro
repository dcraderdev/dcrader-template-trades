---
import { business } from '../../data/v5';
---

<footer
  class="bg-luxury-dark"
  role="contentinfo"
  aria-label="Site footer"
>
  <!-- Top gold line -->
  <div class="h-px bg-gradient-to-r from-transparent via-luxury-gold/40 to-transparent" aria-hidden="true"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Main footer body -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 py-16 lg:py-20">

      <!-- Brand column -->
      <div class="lg:col-span-4">
        <!-- Wordmark -->
        <div class="mb-6">
          <p class="font-outfit font-semibold tracking-[0.18em] uppercase text-luxury-cream/80 text-sm mb-1">
            Cedar Hill
          </p>
          <p class="font-outfit font-light tracking-[0.1em] uppercase text-luxury-gold/50 text-[10px]">
            Custom Electric
          </p>
        </div>

        <!-- Thin gold rule -->
        <div class="w-8 h-px bg-luxury-gold/40 mb-6" aria-hidden="true"></div>

        <!-- Description -->
        <p class="font-outfit font-light text-luxury-cream/40 text-sm leading-relaxed mb-8 max-w-xs">
          {business.footer.description}
        </p>

        <!-- Social links -->
        <div class="flex items-center gap-5" role="list" aria-label="Social media links">
          <a
            href={business.social.instagram}
            class="text-luxury-cream/25 hover:text-luxury-gold transition-colors"
            aria-label="Instagram"
            target="_blank"
            rel="noopener noreferrer"
            role="listitem"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a
            href={business.social.houzz}
            class="text-luxury-cream/25 hover:text-luxury-gold transition-colors"
            aria-label="Houzz"
            target="_blank"
            rel="noopener noreferrer"
            role="listitem"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M 5 2 L 5 13 L 12 10 L 12 13 L 19 10 L 19 22 L 12 22 L 12 17 L 9 17 L 9 22 L 5 22 L 5 22 L 5 2 Z"/>
            </svg>
          </a>
          <a
            href={business.social.google}
            class="text-luxury-cream/25 hover:text-luxury-gold transition-colors"
            aria-label="Google Maps"
            target="_blank"
            rel="noopener noreferrer"
            role="listitem"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 0C5.372 0 0 5.373 0 12s5.372 12 12 12 12-5.373 12-12S18.628 0 12 0zm0 2a10 10 0 0 1 9.95 10.999H12V2zm-1 0v11H2.05A10.001 10.001 0 0 1 11 2zM2.05 13h8.95v8.95A10.001 10.001 0 0 1 2.05 13zm10.95 8.95V13h8.95A10.001 10.001 0 0 1 13 21.95z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation links -->
      <div class="lg:col-span-3 lg:col-start-6">
        <p class="font-outfit font-light text-[10px] tracking-[0.2em] uppercase text-luxury-cream/30 mb-6">
          Navigate
        </p>
        <nav aria-label="Footer navigation">
          <ul class="flex flex-col gap-4 list-none m-0 p-0" role="list">
            {business.footer.links.map(link => (
              <li>
                <a
                  href={link.href}
                  class="font-outfit font-light text-sm text-luxury-cream/45 hover:text-luxury-cream transition-colors duration-200"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- Contact column -->
      <div class="lg:col-span-3 lg:col-start-10">
        <p class="font-outfit font-light text-[10px] tracking-[0.2em] uppercase text-luxury-cream/30 mb-6">
          Contact
        </p>
        <div class="flex flex-col gap-5">
          <div>
            <a
              href={business.phoneHref}
              class="font-outfit font-medium text-luxury-cream/70 hover:text-luxury-gold transition-colors text-sm block"
            >
              {business.phone}
            </a>
          </div>
          <div>
            <a
              href={business.emailHref}
              class="font-outfit font-light text-luxury-cream/45 hover:text-luxury-gold transition-colors text-sm block"
            >
              {business.email}
            </a>
          </div>
          <div>
            <p class="font-outfit font-light text-luxury-cream/30 text-xs">
              {business.address}
            </p>
          </div>

          <!-- Hours -->
          <div class="pt-2">
            {business.hours.map(h => (
              <p class="font-outfit font-light text-luxury-cream/30 text-xs leading-relaxed">
                <span class="text-luxury-cream/45">{h.day}:</span> {h.hours}
              </p>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-luxury-cream/8 py-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="font-outfit font-light text-luxury-cream/25 text-xs">
        {business.footer.copyright}
      </p>
      <div class="flex items-center gap-6">
        <p class="font-outfit font-light text-luxury-cream/20 text-[10px] tracking-wide uppercase">
          {business.license}
        </p>
        <div class="w-px h-3 bg-luxury-cream/10" aria-hidden="true"></div>
        <p class="font-outfit font-light text-luxury-cream/20 text-[10px] tracking-wide uppercase">
          Licensed · Bonded · Insured
        </p>
      </div>
    </div>

  </div>
</footer>
