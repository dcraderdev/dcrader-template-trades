---
import { business } from '../../data/v5';
---

<footer
  class="bg-luxury-dark"
  role="contentinfo"
  aria-label="Site footer"
>
  <!-- Thin gold hairline at top -->
  <div
    class="h-px"
    style="background: linear-gradient(to right, transparent, rgba(201,169,110,0.30) 30%, rgba(201,169,110,0.30) 70%, transparent);"
    aria-hidden="true"
  ></div>

  <div class="max-w-5xl mx-auto px-8 lg:px-12">

    <!-- Main footer body -->
    <div class="py-20 lg:py-28 grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-20">

      <!-- Brand: Cormorant wordmark, description, social -->
      <div class="lg:col-span-5">
        <!-- Logotype -->
        <div class="mb-10">
          <p
            class="font-cormorant italic text-luxury-cream/70 leading-none mb-2"
            style="font-size: 1.625rem;"
          >
            Cedar Hill
          </p>
          <p
            class="font-outfit font-light text-luxury-gold/40 uppercase tracking-[0.22em]"
            style="font-size: 0.6rem;"
          >
            Custom Electric
          </p>
        </div>

        <!-- Thin gold rule -->
        <div class="w-10 h-px bg-luxury-gold/25 mb-8" aria-hidden="true"></div>

        <!-- Description: Outfit light, very subdued -->
        <p
          class="font-outfit font-light text-luxury-cream/30 leading-relaxed mb-10 max-w-sm"
          style="font-size: 0.82rem;"
        >
          {business.footer.description}
        </p>

        <!-- Social links: text-based, minimal -->
        <div
          class="flex items-center gap-6"
          role="list"
          aria-label="Social media links"
        >
          <a
            href={business.social.instagram}
            class="font-outfit font-light text-luxury-cream/20 hover:text-luxury-gold transition-colors duration-300 uppercase tracking-[0.18em]"
            style="font-size: 0.6rem;"
            target="_blank"
            rel="noopener noreferrer"
            role="listitem"
          >
            Instagram
          </a>
          <div class="w-px h-3 bg-luxury-cream/10" aria-hidden="true"></div>
          <a
            href={business.social.houzz}
            class="font-outfit font-light text-luxury-cream/20 hover:text-luxury-gold transition-colors duration-300 uppercase tracking-[0.18em]"
            style="font-size: 0.6rem;"
            target="_blank"
            rel="noopener noreferrer"
            role="listitem"
          >
            Houzz
          </a>
          <div class="w-px h-3 bg-luxury-cream/10" aria-hidden="true"></div>
          <a
            href={business.social.google}
            class="font-outfit font-light text-luxury-cream/20 hover:text-luxury-gold transition-colors duration-300 uppercase tracking-[0.18em]"
            style="font-size: 0.6rem;"
            target="_blank"
            rel="noopener noreferrer"
            role="listitem"
          >
            Google Maps
          </a>
        </div>
      </div>

      <!-- Navigation: discreet links -->
      <div class="lg:col-span-3 lg:col-start-7">
        <p
          class="font-outfit font-light text-luxury-cream/20 uppercase tracking-[0.22em] mb-8"
          style="font-size: 0.6rem;"
        >
          Navigate
        </p>
        <nav aria-label="Footer navigation">
          <ul class="flex flex-col gap-5 list-none m-0 p-0" role="list">
            {business.footer.links.map(link => (
              <li>
                <a
                  href={link.href}
                  class="font-outfit font-light text-luxury-cream/35 hover:text-luxury-cream transition-colors duration-200"
                  style="font-size: 0.82rem;"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- Contact: phone, email, hours -->
      <div class="lg:col-span-4 lg:col-start-10">
        <p
          class="font-outfit font-light text-luxury-cream/20 uppercase tracking-[0.22em] mb-8"
          style="font-size: 0.6rem;"
        >
          Contact
        </p>
        <div class="flex flex-col gap-6">
          <a
            href={business.phoneHref}
            class="font-cormorant italic text-luxury-cream/50 hover:text-luxury-gold transition-colors"
            style="font-size: 1.25rem;"
          >
            {business.phone}
          </a>
          <a
            href={business.emailHref}
            class="font-outfit font-light text-luxury-cream/30 hover:text-luxury-gold transition-colors"
            style="font-size: 0.8rem;"
          >
            {business.email}
          </a>
          <div
            class="pt-2 flex flex-col gap-2"
          >
            {business.hours.map(h => (
              <p
                class="font-outfit font-light text-luxury-cream/20 leading-relaxed"
                style="font-size: 0.75rem;"
              >
                <span class="text-luxury-cream/35">{h.day}:</span> {h.hours}
              </p>
            ))}
          </div>
          <p
            class="font-cormorant italic text-luxury-gold/30"
            style="font-size: 0.88rem;"
          >
            {business.emergencyNote}
          </p>
        </div>
      </div>

    </div>

    <!-- Bottom bar: copyright + license, very quiet -->
    <div
      class="border-t py-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4"
      style="border-color: rgba(201,169,110,0.10);"
    >
      <p
        class="font-outfit font-light text-luxury-cream/15"
        style="font-size: 0.72rem;"
      >
        {business.footer.copyright}
      </p>
      <div class="flex items-center gap-5">
        <p
          class="font-outfit font-light text-luxury-cream/15 uppercase tracking-wide"
          style="font-size: 0.62rem;"
        >
          {business.license}
        </p>
        <div class="w-px h-3 bg-luxury-cream/10" aria-hidden="true"></div>
        <p
          class="font-outfit font-light text-luxury-cream/15 uppercase tracking-wide"
          style="font-size: 0.62rem;"
        >
          Licensed · Bonded · Insured
        </p>
      </div>
    </div>

  </div>
</footer>
