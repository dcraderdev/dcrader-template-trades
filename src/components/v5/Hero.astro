---
import { Image } from 'astro:assets';
import { business } from '../../data/v5';
import { getProjectImage } from '../../assets/projects';
---

<section
  class="relative w-full overflow-hidden"
  style="height: 100svh; min-height: 600px;"
  aria-labelledby="hero-heading"
>
  <!-- Full-bleed background photo -->
  <div class="absolute inset-0" aria-hidden="true">
    <Image
      src={getProjectImage('luxury-modern-interior-v5')}
      alt=""
      widths={[768, 1200, 1600]}
      sizes="100vw"
      class="w-full h-full object-cover"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <!-- Multi-layer gradient: dark at bottom and edges, subtle across top -->
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to top, rgba(28,37,34,0.90) 0%, rgba(28,37,34,0.50) 35%, rgba(28,37,34,0.15) 65%, rgba(28,37,34,0.30) 100%);"
    ></div>
    <!-- Left vignette for text legibility -->
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to right, rgba(28,37,34,0.60) 0%, rgba(28,37,34,0.20) 45%, transparent 70%);"
    ></div>
  </div>

  <!-- Text block: anchored bottom-left -->
  <div class="absolute bottom-0 left-0 right-0 z-10">
    <div class="px-8 lg:px-16 pb-16 lg:pb-20 max-w-3xl">

      <!-- Eyebrow: "By Appointment Only" in small italic gold -->
      <p
        class="font-cormorant italic text-luxury-gold mb-5 leading-none"
        style="font-size: 0.9rem; letter-spacing: 0.04em;"
      >
        By Appointment Only
      </p>

      <!-- Location line -->
      <p
        class="font-outfit font-light text-luxury-cream/50 mb-6 tracking-[0.18em] uppercase"
        style="font-size: 0.65rem;"
      >
        {business.hero.eyebrow}
      </p>

      <!-- Headline: large Cormorant italic, line break intentional -->
      <h1
        id="hero-heading"
        class="font-cormorant italic text-luxury-cream leading-[0.92] mb-10"
        style="font-size: clamp(3.25rem, 7vw, 6.5rem);"
      >
        {business.hero.headlineSmall}<br/>
        <span class="text-luxury-cream">{business.hero.headlineLarge}</span>
      </h1>

      <!-- Single CTA: thin underlined link, no button -->
      <a
        href="#portfolio"
        class="inline-flex items-center gap-3 font-outfit font-light text-luxury-cream/70 hover:text-luxury-cream transition-colors duration-400 group border-b border-luxury-cream/30 hover:border-luxury-cream/60 pb-px"
        style="font-size: 0.8rem; letter-spacing: 0.1em;"
      >
        View our portfolio
        <svg
          class="w-3 h-3 transition-transform duration-300 group-hover:translate-y-0.5"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3"/>
        </svg>
      </a>
    </div>

    <!-- Thin gold hairline above text block -->
    <div
      class="absolute bottom-0 left-0 right-0 h-px pointer-events-none"
      style="background: linear-gradient(to right, rgba(201,169,110,0.0), rgba(201,169,110,0.25) 30%, rgba(201,169,110,0.0));"
      aria-hidden="true"
    ></div>
  </div>

  <!-- Scroll indicator: bottom center, very discreet -->
  <div
    class="absolute bottom-8 right-12 lg:right-16 z-10 hidden md:flex flex-col items-center gap-3"
    aria-hidden="true"
  >
    <span
      class="font-outfit font-light text-luxury-cream/25 tracking-[0.18em] uppercase"
      style="font-size: 0.55rem; writing-mode: vertical-rl;"
    >
      Scroll
    </span>
    <div class="w-px h-10 bg-gradient-to-b from-luxury-cream/25 to-transparent"></div>
  </div>

  <!-- Caption: bottom right, editorial -->
  <div
    class="absolute bottom-16 right-12 lg:right-16 z-10 hidden lg:block"
    aria-hidden="true"
  >
    <p
      class="font-outfit font-light text-luxury-cream/25 tracking-[0.15em] uppercase text-right"
      style="font-size: 0.6rem;"
    >
      Paradise Valley Estate · 2024
    </p>
  </div>
</section>
