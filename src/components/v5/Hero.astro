---
import { business } from '../../data/v5';
---

<section
  class="relative min-h-screen flex items-center overflow-hidden"
  aria-labelledby="hero-heading"
  style="background: #1c2522;"
>
  <!-- Subtle texture overlay -->
  <div class="absolute inset-0 hero-texture" aria-hidden="true"></div>

  <!-- Very faint gold line at top -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-luxury-gold/50 to-transparent" aria-hidden="true"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-10 w-full pt-32 pb-24 lg:pt-40 lg:pb-32">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">

      <!-- LEFT: Editorial copy block -->
      <div>
        <!-- Thin decorative rule above eyebrow -->
        <div class="flex items-center gap-4 mb-8" aria-hidden="true">
          <div class="w-8 h-px bg-luxury-gold/60"></div>
          <div class="w-1.5 h-1.5 rounded-full bg-luxury-gold/60"></div>
        </div>

        <!-- Eyebrow -->
        <p class="font-outfit uppercase tracking-[0.22em] text-xs text-luxury-sage mb-8 font-light">
          {business.hero.eyebrow}
        </p>

        <!-- Headline: Cormorant Garamond, editorial scale -->
        <h1 id="hero-heading" class="mb-8">
          <span
            class="block font-cormorant font-light text-luxury-cream/80 leading-[1.1]"
            style="font-size: clamp(1.5rem, 3vw, 2.25rem);"
          >
            {business.hero.headlineSmall}
          </span>
          <span
            class="block font-cormorant font-bold italic text-luxury-cream leading-[0.95]"
            style="font-size: clamp(3.5rem, 7vw, 6rem);"
          >
            {business.hero.headlineLarge}
          </span>
        </h1>

        <!-- Subheadline with gold rule -->
        <div class="flex items-center gap-4 mb-8">
          <div class="w-12 h-px bg-luxury-gold/50" aria-hidden="true"></div>
          <span class="font-cormorant italic text-luxury-gold text-xl font-light">
            {business.hero.subheadline}
          </span>
        </div>

        <!-- Description -->
        <p class="font-outfit font-light text-luxury-cream/60 text-base leading-relaxed max-w-md mb-12">
          {business.hero.description}
        </p>

        <!-- CTAs — refined, not urgent -->
        <div class="flex flex-col sm:flex-row gap-4 mb-14">
          <a
            href="#quote"
            class="inline-flex items-center justify-center gap-3 font-outfit font-light text-sm tracking-[0.12em] uppercase text-luxury-dark bg-luxury-gold hover:bg-luxury-gold-light transition-colors duration-300 px-8 py-4"
          >
            {business.hero.cta}
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
            </svg>
          </a>
          <a
            href="#portfolio"
            class="inline-flex items-center justify-center gap-3 font-outfit font-light text-sm tracking-[0.12em] uppercase text-luxury-cream/70 hover:text-luxury-cream border border-luxury-cream/20 hover:border-luxury-cream/40 transition-all duration-300 px-8 py-4"
          >
            {business.hero.ctaSecondary}
          </a>
        </div>

        <!-- Discreet credentials list — not badges -->
        <div class="border-t border-luxury-cream/10 pt-8">
          <ul class="flex flex-wrap gap-x-8 gap-y-3 list-none m-0 p-0" role="list" aria-label="Credentials">
            {business.badges.map(badge => (
              <li class="flex items-center gap-2.5">
                <div class="w-1 h-1 rounded-full bg-luxury-gold/70 flex-shrink-0" aria-hidden="true"></div>
                <span class="font-outfit font-medium text-luxury-cream/80 text-xs tracking-wide">{badge.label}</span>
                <span class="font-outfit font-light text-luxury-cream/35 text-xs">{badge.sublabel}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- RIGHT: Image with gold-frame editorial treatment -->
      <div class="relative hidden lg:block">
        <!-- Outer gold frame offset -->
        <div
          class="absolute inset-0 border border-luxury-gold/25 translate-x-4 translate-y-4"
          aria-hidden="true"
        ></div>

        <!-- Image container -->
        <div class="relative overflow-hidden aspect-[4/5]">
          <img
            src="https://picsum.photos/seed/luxury-hero-v5/700/875"
            alt="Luxury estate electrical installation — Paradise Valley custom home"
            class="w-full h-full object-cover"
            loading="eager"
            width="700"
            height="875"
          />
          <!-- Dark vignette at bottom -->
          <div class="absolute inset-0 bg-gradient-to-t from-luxury-dark/60 via-transparent to-transparent" aria-hidden="true"></div>

          <!-- Caption overlay at bottom -->
          <div class="absolute bottom-0 left-0 right-0 p-8">
            <p class="font-outfit font-light text-xs tracking-[0.18em] uppercase text-luxury-cream/50">
              Paradise Valley Estate · 2024
            </p>
          </div>
        </div>

        <!-- Editorial marker top-right -->
        <div class="absolute -top-6 -right-6 w-20 h-20 border border-luxury-gold/20 flex items-center justify-center" aria-hidden="true">
          <span class="font-outfit text-[9px] tracking-[0.15em] uppercase text-luxury-gold/50 text-center leading-tight">
            Since<br/>2011
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom fade to cream -->
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-luxury-cream/8 to-transparent pointer-events-none" aria-hidden="true"></div>
</section>

<style>
  .hero-texture {
    background-image:
      radial-gradient(ellipse 70% 50% at 80% 30%, rgba(74,124,89,0.08) 0%, transparent 60%),
      radial-gradient(ellipse 50% 70% at 20% 80%, rgba(201,169,110,0.05) 0%, transparent 60%);
  }
</style>
