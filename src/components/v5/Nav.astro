---
import { business } from '../../data/v5';
---

<header
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-700"
  role="banner"
  aria-label="Site header"
>
  <!-- Desktop nav -->
  <nav
    class="hidden lg:grid nav-grid max-w-none px-12 h-20 items-center"
    style="grid-template-columns: 1fr auto 1fr;"
    aria-label="Main navigation"
  >
    <!-- Left: thin gold lines flanking wordmark (left side) -->
    <div class="flex items-center gap-0" aria-hidden="true">
      <div class="flex-1 h-px nav-rule"></div>
    </div>

    <!-- Center: Logotype -->
    <a
      href="/"
      class="flex flex-col items-center gap-0.5 px-10 group"
      aria-label={`${business.name} — return to top`}
    >
      <span
        class="logo-primary font-cormorant italic tracking-wide leading-none transition-colors duration-300"
        style="font-size: 1.5rem;"
      >
        Cedar Hill
      </span>
      <span
        class="logo-secondary font-outfit font-light tracking-[0.22em] uppercase leading-none transition-colors duration-300"
        style="font-size: 0.6rem;"
      >
        Custom Electric
      </span>
    </a>

    <!-- Right: gold line + two discreet links -->
    <div class="flex items-center gap-0">
      <div class="flex-1 h-px nav-rule"></div>
      <div class="flex items-center gap-8 pl-10">
        <a
          href="#portfolio"
          class="nav-link-muted font-outfit font-light transition-colors duration-300"
          style="font-size: 0.75rem; letter-spacing: 0.1em;"
        >
          Portfolio
        </a>
        <a
          href="#quote"
          class="nav-link-accent font-outfit font-light transition-colors duration-300 border-b pb-px"
          style="font-size: 0.75rem; letter-spacing: 0.1em;"
        >
          Inquire
        </a>
      </div>
    </div>
  </nav>

  <!-- Mobile nav -->
  <div class="lg:hidden flex items-center justify-between px-6 h-16">
    <a
      href="/"
      class="flex flex-col gap-0.5"
      aria-label={`${business.name} — return to top`}
    >
      <span class="logo-primary font-cormorant italic leading-none" style="font-size: 1.125rem;">
        Cedar Hill
      </span>
      <span class="logo-secondary font-outfit font-light tracking-[0.2em] uppercase leading-none" style="font-size: 0.55rem;">
        Custom Electric
      </span>
    </a>
    <button
      id="mobile-menu-btn"
      type="button"
      class="flex flex-col gap-[5px] p-2 group"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="nav-bar-icon block w-5 h-px transition-all"></span>
      <span class="nav-bar-icon block w-3 h-px transition-all ml-auto"></span>
    </button>
  </div>

  <!-- Mobile menu overlay -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden"
    style="background: rgba(28,37,34,0.98); backdrop-filter: blur(20px);"
    role="dialog"
    aria-label="Mobile navigation"
  >
    <div class="px-6 pt-4 pb-10 flex flex-col gap-8">
      <div class="w-full h-px bg-luxury-gold/20"></div>
      {[
        { label: 'Services', href: '#services' },
        { label: 'Selected Work', href: '#portfolio' },
        { label: 'Our Approach', href: '#why-us' },
        { label: 'Where We Work', href: '#service-area' },
        { label: 'Inquire', href: '#quote' },
      ].map(link => (
        <a
          href={link.href}
          class="font-cormorant italic text-luxury-cream/80 hover:text-luxury-gold transition-colors mobile-nav-link"
          style="font-size: 1.75rem;"
        >
          {link.label}
        </a>
      ))}
      <div class="w-full h-px bg-luxury-gold/20"></div>
      <a
        href={business.phoneHref}
        class="font-outfit font-light text-luxury-gold/60 text-sm tracking-wide"
      >
        {business.phone}
      </a>
    </div>
  </div>
</header>

<style>
  /* At top of page: nav is transparent over cream body — use dark ink */
  #site-nav .logo-primary { color: #1c2522; }
  #site-nav .logo-secondary { color: rgba(74,124,89,0.85); }
  #site-nav .nav-link-muted { color: rgba(28,37,34,0.6); }
  #site-nav .nav-link-accent { color: rgba(74,124,89,0.9); border-color: rgba(74,124,89,0.4); }
  #site-nav .nav-bar-icon { background: rgba(28,37,34,0.7); }
  #site-nav .logo-primary,
  #site-nav .logo-secondary,
  #site-nav .nav-link-muted,
  #site-nav .nav-link-accent {
    transition: color 300ms, border-color 300ms;
  }
  #site-nav a.group:hover .logo-primary { color: #4a7c59; }
  #site-nav a.group:hover .logo-secondary { color: #4a7c59; }
  #site-nav .nav-link-muted:hover { color: #1c2522; }
  #site-nav .nav-link-accent:hover { color: #2d5a3a; border-color: rgba(74,124,89,0.7); }

  /* Once scrolled: nav has dark background — use cream/gold like before */
  #site-nav.is-scrolled .logo-primary { color: #faf8f5; }
  #site-nav.is-scrolled .logo-secondary { color: rgba(201,169,110,0.6); }
  #site-nav.is-scrolled .nav-link-muted { color: rgba(250,248,245,0.5); }
  #site-nav.is-scrolled .nav-link-accent { color: rgba(201,169,110,0.7); border-color: rgba(201,169,110,0.3); }
  #site-nav.is-scrolled .nav-bar-icon { background: rgba(250,248,245,0.6); }
  #site-nav.is-scrolled a.group:hover .logo-primary { color: #c9a96e; }
  #site-nav.is-scrolled a.group:hover .logo-secondary { color: rgba(201,169,110,0.9); }
  #site-nav.is-scrolled .nav-link-muted:hover { color: #faf8f5; }
  #site-nav.is-scrolled .nav-link-accent:hover { color: #c9a96e; border-color: rgba(201,169,110,0.7); }

  .nav-rule {
    background: linear-gradient(to right, transparent, rgba(74,124,89,0.35));
    transition: background 300ms;
  }
  #site-nav.is-scrolled .nav-rule {
    background: linear-gradient(to right, transparent, rgba(201,169,110,0.25));
  }
</style>

<script>
  const nav = document.getElementById('site-nav');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

  function updateNav() {
    if (!nav) return;
    if (window.scrollY > 80) {
      nav.style.background = 'rgba(28,37,34,0.94)';
      nav.style.backdropFilter = 'blur(20px)';
      nav.style.borderBottom = '1px solid rgba(201,169,110,0.12)';
      nav.classList.add('is-scrolled');
    } else {
      nav.style.background = 'transparent';
      nav.style.backdropFilter = 'none';
      nav.style.borderBottom = 'none';
      nav.classList.remove('is-scrolled');
    }
  }
  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();

  mobileMenuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    mobileMenuBtn.setAttribute('aria-expanded', String(!isOpen));
  });

  mobileNavLinks.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      mobileMenuBtn?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
