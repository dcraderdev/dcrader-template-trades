---
import { business } from '../../data/v5';

// Gallery images with luxury seeds and editorial captions
const galleryItems = [
  {
    src: "/images/luxury-kitchen-estate.webp",
    alt: "Custom estate kitchen — Paradise Valley",
    caption: "Paradise Valley Estate · 2024 · $285,000 project",
    size: "tall", // spans 2 rows in masonry
  },
  {
    src: "/images/luxury-living-room-v5.webp",
    alt: "Grand living room lighting — Silverleaf",
    caption: "Silverleaf Residence · 2024 · $195,000 project",
    size: "normal",
  },
  {
    src: "/images/estate-exterior-night.webp",
    alt: "Exterior architectural lighting — Desert Mountain",
    caption: "Desert Mountain Estate · 2023 · $165,000 project",
    size: "normal",
  },
  {
    src: "/images/luxury-primary-suite.webp",
    alt: "Primary suite lighting design — DC Ranch",
    caption: "DC Ranch Villa · 2024 · $145,000 project",
    size: "tall",
  },
  {
    src: "/images/outdoor-pool-estate-v5.webp",
    alt: "Pool and casita outdoor system — Gainey Ranch",
    caption: "Gainey Ranch Estate · 2023 · $220,000 project",
    size: "normal",
  },
  {
    src: "/images/luxury-wine-cellar-v5.webp",
    alt: "Wine cellar and gallery lighting — Old Town Scottsdale",
    caption: "Old Town Residence · 2024 · $110,000 project",
    size: "normal",
  },
];
---

<section
  id="portfolio"
  class="bg-luxury-dark py-28 lg:py-44"
  aria-labelledby="portfolio-heading"
>
  <!-- Section header -->
  <div class="max-w-5xl mx-auto px-8 lg:px-12 mb-16 lg:mb-20">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-8">
      <div>
        <p
          class="font-outfit font-light text-luxury-gold/50 uppercase tracking-[0.25em] mb-8"
          style="font-size: 0.65rem;"
        >
          Portfolio
        </p>
        <h2
          id="portfolio-heading"
          class="font-cormorant italic text-luxury-cream leading-none"
          style="font-size: clamp(2.5rem, 4.5vw, 3.75rem);"
        >
          Selected Work
        </h2>
      </div>
      <p
        class="font-outfit font-light text-luxury-cream/30 max-w-xs leading-relaxed"
        style="font-size: 0.8rem;"
      >
        A curated selection. Full portfolio available during consultation.
      </p>
    </div>

    <!-- Gold hairline -->
    <div class="mt-14 h-px" style="background: rgba(201,169,110,0.20);"></div>
  </div>

  <!-- Masonry-style gallery grid -->
  <div class="px-6 lg:px-10">
    <div
      class="columns-1 sm:columns-2 lg:columns-3 gap-4 lg:gap-5"
      role="list"
      aria-label="Portfolio gallery"
    >
      {galleryItems.map((item, index) => (
        <article
          class="relative overflow-hidden mb-4 lg:mb-5 break-inside-avoid group"
          role="listitem"
          style={item.size === 'tall' ? 'aspect-ratio: 3/4;' : 'aspect-ratio: 4/3;'}
        >
          <img
            src={item.src}
            alt={item.alt}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading={index < 2 ? 'eager' : 'lazy'}
            fetchpriority={index < 2 ? 'high' : 'auto'}
            decoding="async"
            width="800"
            height={item.size === 'tall' ? '1067' : '600'}
            style="display: block;"
          />

          <!-- Gradient overlay always present, darkens on hover -->
          <div
            class="absolute inset-0 transition-opacity duration-500"
            style="background: linear-gradient(to top, rgba(28,37,34,0.80) 0%, rgba(28,37,34,0.15) 45%, transparent 70%); opacity: 0.7;"
            aria-hidden="true"
          ></div>
          <div
            class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            style="background: rgba(28,37,34,0.25);"
            aria-hidden="true"
          ></div>

          <!-- Caption overlay at bottom -->
          <div class="absolute bottom-0 left-0 right-0 p-5 lg:p-6">
            <p
              class="font-outfit font-light text-luxury-cream/60 leading-snug"
              style="font-size: 0.68rem; letter-spacing: 0.1em;"
            >
              {item.caption}
            </p>
          </div>

          <!-- Index -->
          <div
            class="absolute top-5 right-5 font-outfit font-light text-luxury-cream/20 tabular-nums"
            style="font-size: 0.65rem; letter-spacing: 0.1em;"
            aria-hidden="true"
          >
            {String(index + 1).padStart(2, '0')}
          </div>
        </article>
      ))}
    </div>
  </div>

  <!-- Footer: editorial note + discreet inquiry link -->
  <div class="max-w-5xl mx-auto px-8 lg:px-12 mt-16 lg:mt-20">
    <div class="h-px mb-14" style="background: rgba(201,169,110,0.15);"></div>
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-8">
      <p class="font-cormorant italic text-luxury-cream/30" style="font-size: 1.2rem;">
        Trusted by architects and designers across the Valley.
      </p>
      <a
        href="#quote"
        class="font-outfit font-light text-luxury-gold/60 hover:text-luxury-gold transition-colors duration-300 border-b border-luxury-gold/30 hover:border-luxury-gold/60 pb-px flex-shrink-0"
        style="font-size: 0.78rem; letter-spacing: 0.1em;"
      >
        Request a consultation
      </a>
    </div>
  </div>
</section>
