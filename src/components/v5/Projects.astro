---
import { business } from '../../data/v5';
---

<section
  id="portfolio"
  class="bg-luxury-parchment py-24 lg:py-36"
  aria-labelledby="portfolio-heading"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Section header -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-16">
      <div class="lg:col-span-5">
        <p class="font-outfit uppercase tracking-[0.22em] text-xs text-luxury-sage mb-5 font-light">
          05 / Our Work
        </p>
        <h2
          id="portfolio-heading"
          class="font-cormorant font-bold text-luxury-charcoal leading-[0.95]"
          style="font-size: clamp(2.75rem, 5vw, 4rem);"
        >
          Selected<br/>
          <span class="italic">Projects</span>
        </h2>
      </div>
      <div class="lg:col-span-7 flex items-end">
        <p class="font-outfit font-light text-luxury-charcoal/55 text-base leading-relaxed max-w-lg">
          A small selection from our portfolio. Each project is unique to its home, its architect, and its owners.
        </p>
      </div>
    </div>

    <hr class="border-luxury-gold/30 mb-16" />

    <!-- Projects: editorial portfolio spreads -->
    <div class="flex flex-col gap-24 lg:gap-32" role="list" aria-label="Portfolio projects">
      {business.projects.map((project, index) => (
        <article
          class={`grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-center ${index % 2 !== 0 ? 'lg:grid-flow-dense' : ''}`}
          role="listitem"
          aria-labelledby={`project-title-${index}`}
        >
          <!-- Images: Before/After editorial spread -->
          <div class={`lg:col-span-7 ${index % 2 !== 0 ? 'lg:col-start-6' : ''}`}>
            <div class="relative">
              <!-- Before/After toggle labels -->
              <div class="grid grid-cols-2 gap-3">
                <!-- Before -->
                <div class="relative overflow-hidden group">
                  <div class="relative overflow-hidden" style="aspect-ratio: 4/3;">
                    <!-- Gold frame offset -->
                    <div
                      class="absolute inset-0 border border-luxury-gold/20 translate-x-2 translate-y-2 z-0"
                      aria-hidden="true"
                    ></div>
                    <img
                      src={project.beforeImg}
                      alt={`${project.title} — before`}
                      class="relative z-10 w-full h-full object-cover"
                      loading="lazy"
                      width="400"
                      height="300"
                    />
                    <div class="absolute inset-0 z-20 bg-luxury-dark/40 flex items-end p-4">
                      <span class="font-outfit font-light text-[9px] tracking-[0.2em] uppercase text-luxury-cream/60 bg-luxury-dark/60 px-2 py-1">
                        Before
                      </span>
                    </div>
                  </div>
                </div>

                <!-- After -->
                <div class="relative overflow-hidden group">
                  <div class="relative overflow-hidden" style="aspect-ratio: 4/3;">
                    <img
                      src={project.afterImg}
                      alt={`${project.title} — after`}
                      class="w-full h-full object-cover"
                      loading="lazy"
                      width="400"
                      height="300"
                    />
                    <div class="absolute inset-0 bg-luxury-sage/20 flex items-end p-4">
                      <span class="font-outfit font-light text-[9px] tracking-[0.2em] uppercase text-luxury-cream/90 bg-luxury-sage/70 px-2 py-1">
                        After
                      </span>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Project number watermark -->
              <div
                class="absolute -bottom-4 -right-4 w-16 h-16 bg-luxury-gold/10 border border-luxury-gold/20 flex items-center justify-center"
                aria-hidden="true"
              >
                <span class="font-cormorant font-bold text-luxury-gold/50" style="font-size: 1.5rem;">
                  {String(index + 1).padStart(2, '0')}
                </span>
              </div>
            </div>
          </div>

          <!-- Project info -->
          <div class={`lg:col-span-5 ${index % 2 !== 0 ? 'lg:col-start-1 lg:row-start-1' : ''}`}>
            <div class="flex items-center gap-3 mb-6">
              <div class="w-6 h-px bg-luxury-gold/50" aria-hidden="true"></div>
              <p class="font-outfit font-light text-[10px] tracking-[0.18em] uppercase text-luxury-sage">
                {project.location}
              </p>
            </div>

            <h3
              id={`project-title-${index}`}
              class="font-cormorant font-bold text-luxury-charcoal leading-tight mb-6"
              style="font-size: clamp(1.75rem, 3vw, 2.5rem);"
            >
              {project.title}
            </h3>

            <div class="w-10 h-px bg-luxury-gold/50 mb-6" aria-hidden="true"></div>

            <p class="font-outfit font-light text-luxury-charcoal/60 text-base leading-relaxed mb-8">
              {project.description}
            </p>

            <a
              href="#quote"
              class="inline-flex items-center gap-3 font-outfit font-light text-xs tracking-[0.15em] uppercase text-luxury-sage hover:text-luxury-sage-dark transition-colors group"
            >
              Discuss a Similar Project
              <svg
                class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform"
                fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- Portfolio footer note -->
    <div class="mt-24 pt-12 border-t border-luxury-gold/20 text-center">
      <p class="font-cormorant italic text-luxury-charcoal/40 text-xl mb-6">
        Additional work available upon request during consultation.
      </p>
      <a
        href="#quote"
        class="inline-flex items-center gap-3 font-outfit font-light text-sm tracking-[0.12em] uppercase text-luxury-dark bg-luxury-gold hover:bg-luxury-gold-light transition-colors px-8 py-4"
      >
        Schedule a Consultation
      </a>
    </div>

  </div>
</section>
