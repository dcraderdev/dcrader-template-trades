---
import { Image } from 'astro:assets';
import { business } from '../../data/v5';
import { getProjectImage } from '../../assets/projects';
---

<section
  id="quote"
  class="bg-luxury-dark py-28 lg:py-44"
  aria-labelledby="quote-heading"
>
  <div class="max-w-6xl mx-auto px-8 lg:px-12">

    <!-- Section header -->
    <div class="mb-16 lg:mb-20">
      <p
        class="font-outfit font-light text-luxury-gold/50 uppercase tracking-[0.25em] mb-8"
        style="font-size: 0.65rem;"
      >
        Contact
      </p>
      <h2
        id="quote-heading"
        class="font-cormorant italic text-luxury-cream leading-none"
        style="font-size: clamp(2.5rem, 4.5vw, 3.75rem);"
      >
        Request a Consultation
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-0 lg:gap-0">

      <!-- LEFT: Cream consultation panel with form -->
      <div
        class="lg:col-span-7 bg-luxury-cream p-10 lg:p-14"
      >
        <!-- Top hairline: gold -->
        <div class="w-full h-px bg-luxury-gold/30 mb-12" aria-hidden="true"></div>

        <p
          class="font-outfit font-light text-luxury-dark/50 leading-relaxed mb-12"
          style="font-size: 0.85rem;"
        >
          {business.form.note}
        </p>

        <form
          action="#"
          method="post"
          novalidate
          aria-labelledby="quote-heading"
          class="flex flex-col gap-10"
        >
          <!-- Name + Email row -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-10">
            <div class="form-field">
              <label
                for="v5-name"
                class="font-outfit font-light text-luxury-dark/40 uppercase tracking-[0.2em] block mb-3"
                style="font-size: 0.62rem;"
              >
                Name <span class="text-luxury-sage" aria-label="required">*</span>
              </label>
              <input
                id="v5-name"
                type="text"
                name="name"
                required
                autocomplete="name"
                placeholder="Your full name"
                class="w-full bg-transparent border-0 border-b border-luxury-dark/20 focus:border-luxury-sage pb-3 text-luxury-dark font-outfit font-light placeholder:text-luxury-dark/20 outline-none transition-colors"
                style="font-size: 0.875rem;"
              />
            </div>

            <div class="form-field">
              <label
                for="v5-email"
                class="font-outfit font-light text-luxury-dark/40 uppercase tracking-[0.2em] block mb-3"
                style="font-size: 0.62rem;"
              >
                Email <span class="text-luxury-sage" aria-label="required">*</span>
              </label>
              <input
                id="v5-email"
                type="email"
                name="email"
                required
                autocomplete="email"
                placeholder="your@email.com"
                class="w-full bg-transparent border-0 border-b border-luxury-dark/20 focus:border-luxury-sage pb-3 text-luxury-dark font-outfit font-light placeholder:text-luxury-dark/20 outline-none transition-colors"
                style="font-size: 0.875rem;"
              />
            </div>
          </div>

          <!-- Project Type + Timeline row -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-10">
            <div class="form-field">
              <label
                for="v5-project-type"
                class="font-outfit font-light text-luxury-dark/40 uppercase tracking-[0.2em] block mb-3"
                style="font-size: 0.62rem;"
              >
                Project Type
              </label>
              <div class="relative">
                <select
                  id="v5-project-type"
                  name="project-type"
                  class="w-full appearance-none bg-transparent border-0 border-b border-luxury-dark/20 focus:border-luxury-sage pb-3 text-luxury-dark font-outfit font-light outline-none transition-colors cursor-pointer pr-5"
                  style="font-size: 0.875rem;"
                >
                  <option value="" class="bg-luxury-cream text-luxury-dark/40">Select…</option>
                  <option value="new-construction" class="bg-luxury-cream text-luxury-dark">New Construction</option>
                  <option value="major-renovation" class="bg-luxury-cream text-luxury-dark">Major Renovation</option>
                  <option value="smart-home" class="bg-luxury-cream text-luxury-dark">Smart Home Integration</option>
                  <option value="outdoor" class="bg-luxury-cream text-luxury-dark">Outdoor / Landscape</option>
                  <option value="other" class="bg-luxury-cream text-luxury-dark">Other</option>
                </select>
                <svg
                  class="absolute right-0 top-0.5 w-3 h-3 text-luxury-dark/30 pointer-events-none"
                  fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/>
                </svg>
              </div>
            </div>

            <div class="form-field">
              <label
                for="v5-timeline"
                class="font-outfit font-light text-luxury-dark/40 uppercase tracking-[0.2em] block mb-3"
                style="font-size: 0.62rem;"
              >
                Timeline
              </label>
              <div class="relative">
                <select
                  id="v5-timeline"
                  name="timeline"
                  class="w-full appearance-none bg-transparent border-0 border-b border-luxury-dark/20 focus:border-luxury-sage pb-3 text-luxury-dark font-outfit font-light outline-none transition-colors cursor-pointer pr-5"
                  style="font-size: 0.875rem;"
                >
                  <option value="" class="bg-luxury-cream text-luxury-dark/40">Select…</option>
                  <option value="immediate" class="bg-luxury-cream text-luxury-dark">Immediately</option>
                  <option value="1-3mo" class="bg-luxury-cream text-luxury-dark">1–3 months</option>
                  <option value="3-6mo" class="bg-luxury-cream text-luxury-dark">3–6 months</option>
                  <option value="6-12mo" class="bg-luxury-cream text-luxury-dark">6–12 months</option>
                  <option value="planning" class="bg-luxury-cream text-luxury-dark">Planning stage</option>
                </select>
                <svg
                  class="absolute right-0 top-0.5 w-3 h-3 text-luxury-dark/30 pointer-events-none"
                  fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/>
                </svg>
              </div>
            </div>
          </div>

          <!-- Vision textarea: optional -->
          <div class="form-field">
            <label
              for="v5-vision"
              class="font-outfit font-light text-luxury-dark/40 uppercase tracking-[0.2em] block mb-3"
              style="font-size: 0.62rem;"
            >
              Tell us about your vision <span class="text-luxury-dark/25 normal-case tracking-normal" style="font-size: 0.62rem;">(optional)</span>
            </label>
            <textarea
              id="v5-vision"
              name="vision"
              rows="4"
              placeholder="Describe your project, home size, architect or designer involvement, or anything else we should know…"
              class="w-full bg-transparent border-0 border-b border-luxury-dark/20 focus:border-luxury-sage pb-3 text-luxury-dark font-outfit font-light placeholder:text-luxury-dark/20 outline-none transition-colors resize-none leading-relaxed"
              style="font-size: 0.875rem;"
            ></textarea>
          </div>

          <!-- Submit: ghost outline, no fill, square, Outfit light -->
          <div class="flex flex-col sm:flex-row sm:items-center gap-6">
            <button
              type="submit"
              class="inline-flex items-center gap-4 font-outfit font-light text-luxury-dark border border-luxury-dark/30 hover:border-luxury-sage hover:text-luxury-sage transition-all duration-300 px-10 py-4 group"
              style="font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase;"
            >
              Send Inquiry
              <svg
                class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform flex-shrink-0"
                fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
              </svg>
            </button>
            <p
              class="font-outfit font-light text-luxury-dark/30"
              style="font-size: 0.75rem;"
            >
              We reply within one business day.
            </p>
          </div>

          <!-- License note -->
          <p
            class="font-outfit font-light text-luxury-dark/25 uppercase tracking-wide"
            style="font-size: 0.6rem;"
          >
            {business.license} · Licensed, bonded &amp; insured in Arizona
          </p>
        </form>
      </div>

      <!-- RIGHT: Editorial image panel -->
      <div class="lg:col-span-5 relative hidden lg:block">
        <Image
          src={getProjectImage('luxury-consult-interior')}
          alt="Luxury estate interior — Cedar Hill project"
          widths={[400, 600, 800]}
          sizes="(min-width: 1024px) 40vw, 0px"
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
          style="display: block; min-height: 560px;"
        />
        <!-- Overlay with contact details -->
        <div
          class="absolute bottom-0 left-0 right-0 p-10"
          style="background: linear-gradient(to top, rgba(28,37,34,0.92) 0%, rgba(28,37,34,0.50) 50%, transparent 100%);"
        >
          <p
            class="font-outfit font-light text-luxury-cream/30 uppercase tracking-[0.2em] mb-6"
            style="font-size: 0.6rem;"
          >
            Prefer to speak directly?
          </p>
          <a
            href={business.phoneHref}
            class="font-cormorant italic text-luxury-cream/70 hover:text-luxury-gold transition-colors block mb-2"
            style="font-size: 1.375rem;"
          >
            {business.phone}
          </a>
          <a
            href={business.emailHref}
            class="font-outfit font-light text-luxury-gold/50 hover:text-luxury-gold transition-colors block"
            style="font-size: 0.78rem;"
          >
            {business.email}
          </a>
        </div>
      </div>

    </div>

    <!-- Mobile contact details (below form on small screens) -->
    <div class="lg:hidden mt-12 pt-10 border-t border-luxury-gold/15 flex flex-col gap-4">
      <p
        class="font-outfit font-light text-luxury-cream/30 uppercase tracking-[0.2em]"
        style="font-size: 0.6rem;"
      >
        Or reach us directly
      </p>
      <a
        href={business.phoneHref}
        class="font-cormorant italic text-luxury-cream/60 hover:text-luxury-gold transition-colors"
        style="font-size: 1.375rem;"
      >
        {business.phone}
      </a>
      <a
        href={business.emailHref}
        class="font-outfit font-light text-luxury-gold/50 hover:text-luxury-gold transition-colors"
        style="font-size: 0.85rem;"
      >
        {business.email}
      </a>
    </div>

  </div>
</section>
