---
import { business } from '../../data/v5';
---

<section
  id="service-area"
  class="bg-luxury-cream py-28 lg:py-44 overflow-hidden"
  aria-labelledby="area-heading"
>
  <div class="max-w-5xl mx-auto px-8 lg:px-12">

    <!-- Section header -->
    <div class="mb-16 lg:mb-24">
      <p
        class="font-outfit font-light text-luxury-gold/70 uppercase tracking-[0.25em] mb-8"
        style="font-size: 0.65rem;"
      >
        Where We Work
      </p>
      <h2
        id="area-heading"
        class="font-cormorant italic text-luxury-dark leading-none mb-10"
        style="font-size: clamp(2.5rem, 4.5vw, 3.75rem);"
      >
        Our Territory
      </h2>
    </div>

    <!-- Editorial layout: paragraph left, neighborhood names right -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-20 items-start">

      <!-- Left: editorial prose -->
      <div class="lg:col-span-5">
        <div class="h-px bg-luxury-gold/25 mb-10" aria-hidden="true"></div>

        <p
          class="font-outfit font-light text-luxury-dark/55 leading-relaxed mb-10"
          style="font-size: 0.95rem;"
        >
          {business.serviceArea.subheadline}. We limit our geographic reach deliberately — to ensure every client in every neighborhood receives the same standard of craft and attention.
        </p>

        <p
          class="font-cormorant italic text-luxury-dark/40 leading-relaxed"
          style="font-size: 1.2rem;"
        >
          Projects beyond these areas are considered on a case-by-case basis. Please inquire.
        </p>

        <!-- Discreet location indicator -->
        <div class="mt-14 flex items-center gap-4">
          <svg
            class="w-5 h-5 text-luxury-gold/40 flex-shrink-0"
            fill="none" stroke="currentColor" stroke-width="1.25" viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
          </svg>
          <span
            class="font-outfit font-light text-luxury-dark/30 uppercase tracking-[0.2em]"
            style="font-size: 0.65rem;"
          >
            Scottsdale · Paradise Valley · Arizona
          </span>
        </div>
      </div>

      <!-- Right: neighborhood names — editorial, no icons, clean list -->
      <div class="lg:col-span-7">
        <div
          class="grid grid-cols-1 sm:grid-cols-2"
          role="list"
          aria-label="Service neighborhoods"
        >
          {business.serviceArea.neighborhoods.map((neighborhood, index) => (
            <div
              class="py-6 border-b group"
              style="border-color: rgba(201,169,110,0.15);"
              role="listitem"
            >
              <div class="flex items-baseline gap-5">
                <span
                  class="font-outfit font-light text-luxury-dark/20 tabular-nums flex-shrink-0"
                  style="font-size: 0.65rem; letter-spacing: 0.1em;"
                  aria-hidden="true"
                >
                  {String(index + 1).padStart(2, '0')}
                </span>
                <span
                  class="font-cormorant italic text-luxury-dark/80 leading-snug transition-colors duration-300 group-hover:text-luxury-sage"
                  style="font-size: clamp(1.1rem, 1.8vw, 1.375rem);"
                >
                  {neighborhood}
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>

  </div>
</section>
