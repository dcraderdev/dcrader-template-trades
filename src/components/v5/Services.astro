---
import { business } from '../../data/v5';
---

<section
  id="services"
  class="bg-luxury-cream py-28 lg:py-44"
  aria-labelledby="services-heading"
>
  <div class="max-w-5xl mx-auto px-8 lg:px-12">

    <!-- Section header: left-aligned editorial -->
    <div class="mb-20 lg:mb-28">
      <p
        class="font-outfit font-light text-luxury-gold/70 uppercase tracking-[0.25em] mb-8"
        style="font-size: 0.65rem;"
      >
        Services
      </p>
      <h2
        id="services-heading"
        class="font-cormorant italic text-luxury-dark leading-none mb-10"
        style="font-size: clamp(2.5rem, 4.5vw, 3.75rem);"
      >
        What We Do
      </h2>
      <div class="flex items-center gap-0">
        <div class="h-px bg-luxury-gold/40 flex-1"></div>
      </div>
    </div>

    <!-- Editorial two-column list, no icons, gold hairline rows -->
    <div role="list" aria-label="Electrical services">
      {business.services.map((service, index) => (
        <div
          class="service-row grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-16 py-9 border-b group"
          style="border-color: rgba(201,169,110,0.18);"
          role="listitem"
        >
          <!-- Left: service name in Cormorant italic -->
          <div class="flex items-baseline gap-6">
            <span
              class="font-outfit font-light text-luxury-dark/20 tabular-nums flex-shrink-0"
              style="font-size: 0.7rem; letter-spacing: 0.1em;"
              aria-hidden="true"
            >
              {String(index + 1).padStart(2, '0')}
            </span>
            <h3
              class="font-cormorant italic text-luxury-dark leading-tight transition-colors duration-300 group-hover:text-luxury-sage"
              style="font-size: clamp(1.375rem, 2.2vw, 1.75rem);"
            >
              {service.title}
            </h3>
          </div>

          <!-- Right: one-line description in Outfit light -->
          <div class="lg:flex lg:items-center pl-12 lg:pl-0">
            <p
              class="font-outfit font-light text-luxury-dark/55 leading-relaxed transition-colors duration-300 group-hover:text-luxury-dark/75"
              style="font-size: 0.9rem;"
            >
              {service.description}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Footer note -->
    <div class="mt-20 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8">
      <p class="font-cormorant italic text-luxury-dark/35" style="font-size: 1.2rem;">
        All engagements begin with a design consultation.
      </p>
      <a
        href="#quote"
        class="font-outfit font-light text-luxury-dark/60 hover:text-luxury-sage transition-colors duration-300 border-b border-luxury-dark/20 hover:border-luxury-sage pb-px flex-shrink-0"
        style="font-size: 0.78rem; letter-spacing: 0.1em;"
      >
        Begin a conversation
      </a>
    </div>

  </div>
</section>
