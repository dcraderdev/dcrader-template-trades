---
import { business } from '../../data/v5';

// Single featured testimonial — most editorial, most evocative
const featured = business.testimonials[0];
---

<section
  id="reviews"
  class="bg-luxury-dark py-28 lg:py-52 overflow-hidden"
  aria-labelledby="testimonial-heading"
>
  <div class="max-w-4xl mx-auto px-8 lg:px-12">

    <!-- Section label -->
    <div class="flex items-center gap-6 mb-20 lg:mb-28">
      <div class="h-px flex-1 bg-luxury-gold/20" aria-hidden="true"></div>
      <p
        class="font-outfit font-light text-luxury-gold/40 uppercase tracking-[0.25em] flex-shrink-0"
        style="font-size: 0.65rem;"
      >
        Client Words
      </p>
      <div class="h-px flex-1 bg-luxury-gold/20" aria-hidden="true"></div>
    </div>

    <!-- Single pull-quote: centered on page -->
    <blockquote
      class="text-center"
      aria-labelledby="testimonial-heading"
    >
      <!-- Giant gold quotation mark -->
      <div
        class="font-cormorant text-luxury-gold/20 leading-none select-none mb-6"
        style="font-size: 9rem; line-height: 0.7; margin-top: -0.3rem;"
        aria-hidden="true"
      >
        &ldquo;
      </div>

      <!-- The quote itself: large Cormorant italic, cream -->
      <p
        id="testimonial-heading"
        class="font-cormorant italic text-luxury-cream/85 leading-snug mx-auto mb-14"
        style="font-size: clamp(1.625rem, 3vw, 2.5rem); max-width: 42rem;"
      >
        {featured.text}
      </p>

      <!-- Attribution: name and project, no stars -->
      <footer>
        <div class="flex items-center justify-center gap-5">
          <div class="h-px w-8 bg-luxury-gold/40" aria-hidden="true"></div>
          <div class="text-center">
            <p
              class="font-outfit font-light text-luxury-cream/50 tracking-[0.15em] uppercase"
              style="font-size: 0.7rem;"
            >
              {featured.name}
            </p>
            <p
              class="font-cormorant italic text-luxury-gold/50 mt-1"
              style="font-size: 0.9rem;"
            >
              {featured.neighborhood} Estate
            </p>
          </div>
          <div class="h-px w-8 bg-luxury-gold/40" aria-hidden="true"></div>
        </div>
      </footer>
    </blockquote>

    <!-- Discreet line of secondary client names below — not rated, not starred -->
    <div class="mt-20 lg:mt-28 pt-12 border-t" style="border-color: rgba(201,169,110,0.12);">
      <p
        class="font-outfit font-light text-luxury-cream/20 uppercase tracking-[0.2em] text-center mb-8"
        style="font-size: 0.6rem;"
      >
        Also among our clients
      </p>
      <div
        class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3"
        role="list"
        aria-label="Additional client neighborhoods"
      >
        {business.testimonials.slice(1).map((t, i) => (
          <>
            <span
              class="font-cormorant italic text-luxury-cream/25"
              style="font-size: 1rem;"
              role="listitem"
            >
              {t.name} · {t.neighborhood}
            </span>
            {i < business.testimonials.length - 2 && (
              <span class="text-luxury-gold/15 hidden sm:inline" aria-hidden="true">·</span>
            )}
          </>
        ))}
      </div>
    </div>

  </div>
</section>
