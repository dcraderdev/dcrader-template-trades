---
import { business } from '../../data/v5';

// Numbered philosophy statements
const philosophy = [
  {
    number: "01",
    statement: "We listen first.",
    body: "Every engagement begins before a single drawing is reviewed. We sit with the homeowner, the architect, and the designer to understand the vision — not just the specifications.",
  },
  {
    number: "02",
    statement: "We source premium materials.",
    body: "Lutron, Savant, Kohler, Legrand Adorne. We specify and install the same equipment found in the world's finest residences. No substitutions without written approval.",
  },
  {
    number: "03",
    statement: "Our work disappears into the design.",
    body: "Wire routes are planned before walls are closed. Every junction box lands exactly where the drawings say. What you see is the design — not the infrastructure supporting it.",
  },
  {
    number: "04",
    statement: "We deliver on time.",
    body: "Fourteen years of estate-scale projects have taught us how to sequence work so we are never the reason a punch list grows. We coordinate with your GC and AV team — proactively, not reactively.",
  },
];
---

<section
  id="why-us"
  class="bg-luxury-cream py-28 lg:py-48"
  aria-labelledby="approach-heading"
>
  <div class="max-w-5xl mx-auto px-8 lg:px-12">

    <!-- Section header -->
    <div class="mb-20 lg:mb-32">
      <p
        class="font-outfit font-light text-luxury-gold/70 uppercase tracking-[0.25em] mb-8"
        style="font-size: 0.65rem;"
      >
        Our Approach
      </p>
      <h2
        id="approach-heading"
        class="font-cormorant italic text-luxury-dark leading-none"
        style="font-size: clamp(2.5rem, 4.5vw, 3.75rem);"
      >
        How We Work
      </h2>
    </div>

    <!-- Numbered philosophy statements: very generous whitespace -->
    <div class="flex flex-col gap-0" role="list" aria-label="Our approach">
      {philosophy.map((item, index) => (
        <div
          class="philosophy-item grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 py-14 lg:py-20 border-b"
          style="border-color: rgba(201,169,110,0.15);"
          role="listitem"
        >
          <!-- Number: large, ghosted -->
          <div class="lg:col-span-2 flex items-start">
            <span
              class="font-cormorant italic text-luxury-gold/20 leading-none"
              style="font-size: clamp(3rem, 5vw, 4.5rem);"
              aria-hidden="true"
            >
              {item.number}
            </span>
          </div>

          <!-- Statement + body -->
          <div class="lg:col-span-10">
            <h3
              class="font-cormorant italic text-luxury-dark leading-tight mb-8"
              style="font-size: clamp(1.75rem, 3vw, 2.5rem);"
            >
              {item.statement}
            </h3>
            <p
              class="font-outfit font-light text-luxury-dark/55 leading-relaxed max-w-2xl"
              style="font-size: 0.95rem;"
            >
              {item.body}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Closing editorial note: centered, generous breathing room -->
    <div class="mt-24 lg:mt-36 text-center">
      <div class="inline-flex items-center gap-6">
        <div class="h-px w-12 bg-luxury-gold/30"></div>
        <p
          class="font-cormorant italic text-luxury-dark/40"
          style="font-size: clamp(1.125rem, 2vw, 1.5rem);"
        >
          "We work on a selective basis so that every client receives our complete attention."
        </p>
        <div class="h-px w-12 bg-luxury-gold/30"></div>
      </div>
    </div>

  </div>
</section>
