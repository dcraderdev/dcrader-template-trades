---
interface Props {
  title?: string;
  description?: string;
  /** Full Google Fonts href — each variant provides its own */
  fontUrl?: string;
  /** <meta name="theme-color"> */
  themeColor?: string;
  /** Inline style applied to <body> — set bg + color per variant */
  bodyStyle?: string;
  /** Path to OG image (defaults to /og-image.png) */
  ogImage?: string;
}

const {
  title = 'Local Trade Business',
  description = 'Modern websites for HVAC, plumbing, electrical, and trade services.',
  fontUrl,
  themeColor = '#0f2855',
  bodyStyle = 'background:#060d1c;color:#e2e8f0;',
  ogImage = '/og-image.png',
} = Astro.props;

const siteBase = Astro.site ?? new URL('https://dcrader-template-trades.vercel.app');
const canonicalURL = new URL(Astro.url.pathname, siteBase).toString();
const ogImageURL = new URL(ogImage, siteBase).toString();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content={themeColor} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    {fontUrl && (
      <>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href={fontUrl} rel="stylesheet" />
      </>
    )}
    <script src="/template-topheader.js" defer></script>
  </head>

  <body style={bodyStyle}>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <slot />
  <script src="/back-pill.js" defer></script>
  </body>
</html>

<style is:global>
  /* Strip ALL animations and transitions for perf */
  *, *::before, *::after {
    animation: none !important;
    transition: none !important;
  }
  @media (prefers-reduced-motion: no-preference) {
    *, *::before, *::after {
      animation: none !important;
      transition: none !important;
    }
  }

  *, *::before, *::after { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { margin: 0; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }

  /* Offset sticky nav for anchor links */
  [id] { scroll-margin-top: 80px; }

  /* Portfolio top header (template-topheader.js, 34px tall, fixed top:0, z=2147483600)
     injects above page content. Any fixed/sticky element pinned to top:0 collides
     with it. Push such elements down by 34px when the bar is mounted, and grow
     the layout spacers below the nav so the hero isn't hidden. */
  html.dt-th-spaced .fixed.top-0 { top: 34px !important; }
  /* Wrappers that use pt-* to position a child (e.g. v2 floating pill nav) need
     additional offset rather than overriding their top. */
  html.dt-th-spaced .fixed.top-0.pt-4 { top: 0 !important; padding-top: calc(1rem + 34px) !important; }
  /* Push hero/main content down: the spacer divs under each Nav use h-[…] in px. */
  html.dt-th-spaced body { padding-top: 34px; }
  /* Anchor scroll offset accounts for the portfolio bar too */
  html.dt-th-spaced [id] { scroll-margin-top: 114px; }

  /* Skip link — each variant can override color */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    padding: 0.75rem 1.25rem;
    border-radius: 0 0 8px 8px;
    z-index: 9999;
    text-decoration: none;
    font-weight: 700;
    background: #f97316;
    color: #fff;
    transition: top 0.2s;
  }
  .skip-link:focus { top: 0; }

  /* Accessible focus ring */
  :focus-visible {
    outline: 3px solid currentColor;
    outline-offset: 3px;
    border-radius: 4px;
  }
</style>
