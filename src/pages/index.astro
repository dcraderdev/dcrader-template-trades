---
// Gallery index — no business data import, all content inline
const variants = [
  {
    id: "v1",
    slug: "v1-classic-trust",
    label: "V1 — CLASSIC TRUST",
    company: "Crader Plumbing & Drain",
    industry: "Plumbing · Drain · Sewer",
    bestFor: "Established local trades that lead with reliability and years-in-business",
    headline: "24/7 EMERGENCY PLUMBING",
    subline: "Fixed Right the First Time",
    phone: "(619) 555-0182",
    cta: "Request Service Now",
    palette: ["#0f2855", "#143266", "#f97316"],
    paletteLabels: ["Navy", "Navy 2", "Orange"],
    fonts: "Barlow Condensed + DM Sans",
    bg: "#0f2855",
    accent: "#f97316",
    cardBg: "linear-gradient(135deg,#0c1d38 0%,#0f2855 100%)",
    previewStyle: "classic",
  },
  {
    id: "v2",
    slug: "v2-modern-tech",
    label: "V2 — MODERN TECH",
    company: "BrightWatt Electric",
    industry: "EV Charging · Smart Home · Panel Upgrades",
    bestFor: "Tech-forward contractors targeting EV, automation, and modern home buyers",
    headline: "Power Your Home. Intelligently.",
    subline: ">_ (480) 555-0247",
    phone: "(480) 555-0247",
    cta: "Schedule an Install",
    palette: ["#080e1a", "#0d1527", "#2dd4bf"],
    paletteLabels: ["Near Black", "Card", "Teal"],
    fonts: "Sora + JetBrains Mono",
    bg: "#080e1a",
    accent: "#2dd4bf",
    cardBg: "linear-gradient(135deg,#080e1a 0%,#0d1527 100%)",
    previewStyle: "tech",
  },
  {
    id: "v3",
    slug: "v3-family-warm",
    label: "V3 — FAMILY WARM",
    company: "Three Generations Heating & Cooling",
    industry: "HVAC · Furnace · AC · Boiler",
    bestFor: "Multi-generational family businesses with deep community roots",
    headline: "Columbus Trusts Three Generations",
    subline: "Family-owned since 1981",
    phone: "(614) 555-0931",
    cta: "Call for Same-Day Service",
    palette: ["#fef8f0", "#2d5a27", "#c4622d"],
    paletteLabels: ["Cream", "Forest", "Terra"],
    fonts: "Playfair Display + Nunito Sans",
    bg: "#fef8f0",
    accent: "#2d5a27",
    cardBg: "linear-gradient(135deg,#fef8f0 0%,#f5ead8 100%)",
    previewStyle: "warm",
  },
  {
    id: "v4",
    slug: "v4-emergency-bold",
    label: "V4 — EMERGENCY BOLD",
    company: "Rapid Response Plumbing",
    industry: "Emergency Plumbing · 24/7 Response",
    bestFor: "Emergency-only operations where speed and a ringing phone are everything",
    headline: "PLUMBING EMERGENCY?",
    subline: "(404) 555-0911",
    phone: "(404) 555-0911",
    cta: "CALL NOW",
    palette: ["#080808", "#111111", "#ef4444"],
    paletteLabels: ["Black", "Card", "Red"],
    fonts: "Anton + DM Sans",
    bg: "#080808",
    accent: "#ef4444",
    cardBg: "linear-gradient(135deg,#080808 0%,#111111 100%)",
    previewStyle: "emergency",
  },
  {
    id: "v5",
    slug: "v5-luxury-trade",
    label: "V5 — LUXURY TRADE",
    company: "Cedar Hill Custom Electric",
    industry: "Custom Electrical · Automation · Luxury Homes",
    bestFor: "Premium contractors working with architects and designers on high-end builds",
    headline: "Exceptional Homes.",
    subline: "Electrical craftsmanship for",
    phone: "(480) 555-0673",
    cta: "Schedule a Consultation",
    palette: ["#faf8f5", "#4a7c59", "#c9a96e"],
    paletteLabels: ["Cream", "Sage", "Gold"],
    fonts: "Cormorant Garamond + Outfit",
    bg: "#faf8f5",
    accent: "#4a7c59",
    cardBg: "linear-gradient(135deg,#faf8f5 0%,#f0ece4 100%)",
    previewStyle: "luxury",
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="5 distinct local trade business landing page templates — Astro + Tailwind. One config file to white-label each." />
    <title>Trade Business Templates — dcrader</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@800;900&family=Anton&family=Playfair+Display:ital,wght@0,700;1,400&family=Cormorant+Garamond:ital,wght@0,400;1,400&family=Sora:wght@700;800&family=JetBrains+Mono:wght@700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { margin: 0; background: #060d1c; color: #e2e8f0; font-family: 'Inter', system-ui, sans-serif; -webkit-font-smoothing: antialiased; }
      :focus-visible { outline: 3px solid #f97316; outline-offset: 3px; border-radius: 4px; }
      a { text-decoration: none; }

      /* Preview card styles */
      .preview-card { transition: transform 0.3s ease, box-shadow 0.3s ease; }
      .preview-card:hover { transform: translateY(-6px); box-shadow: 0 32px 64px rgba(0,0,0,0.5); }

      /* Preview mockup: classic */
      .preview-classic { background: linear-gradient(135deg, #0c1d38, #0f2855); position: relative; overflow: hidden; }
      .preview-classic::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 60% 60% at 90% 0%, rgba(249,115,22,0.2), transparent); }
      .preview-classic::after { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: #f97316; }

      /* Preview mockup: tech */
      .preview-tech { background: #080e1a; position: relative; overflow: hidden; }
      .preview-tech::before { content: ''; position: absolute; inset: 0; background-image: radial-gradient(circle at 20px 20px, rgba(45,212,191,0.08) 1px, transparent 0); background-size: 32px 32px; }

      /* Preview mockup: warm */
      .preview-warm { background: linear-gradient(135deg, #fef8f0, #f5ead8); position: relative; overflow: hidden; }

      /* Preview mockup: emergency */
      .preview-emergency { background: #080808; position: relative; overflow: hidden; }
      .preview-emergency::before { content: ''; position: absolute; inset: 0; background: repeating-linear-gradient(-45deg, transparent, transparent 20px, rgba(239,68,68,0.04) 20px, rgba(239,68,68,0.04) 40px); }
      .preview-emergency::after { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: #ef4444; }

      /* Preview mockup: luxury */
      .preview-luxury { background: linear-gradient(135deg, #faf8f5, #f0ece4); position: relative; overflow: hidden; }
    </style>
  </head>

  <body>
    <!-- Skip link -->
    <a href="#templates" style="position:absolute;top:-100%;left:1rem;background:#f97316;color:#fff;font-weight:700;padding:0.75rem 1.25rem;border-radius:0 0 8px 8px;z-index:999;transition:top 0.2s;" onfocus="this.style.top='0'" onblur="this.style.top='-100%'">Skip to templates</a>

    <!-- Header -->
    <header style="border-bottom: 1px solid rgba(255,255,255,0.08);">
      <div style="max-width:1280px;margin:0 auto;padding:1.25rem 1.5rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
        <div style="display:flex;align-items:center;gap:0.75rem;">
          <div style="width:2rem;height:2rem;background:#f97316;border-radius:6px;display:flex;align-items:center;justify-content:center;" aria-hidden="true">
            <svg width="16" height="16" fill="none" stroke="white" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" />
            </svg>
          </div>
          <div>
            <span style="display:block;font-weight:700;color:#fff;font-size:0.9rem;letter-spacing:0.05em;text-transform:uppercase;">dcrader / trade-templates</span>
            <span style="display:block;color:#64748b;font-size:0.75rem;">Astro + Tailwind · 5 variants</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Hero -->
    <section style="max-width:1280px;margin:0 auto;padding:5rem 1.5rem 3rem;text-align:center;">
      <div style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(249,115,22,0.1);border:1px solid rgba(249,115,22,0.25);border-radius:100px;padding:0.375rem 1rem;margin-bottom:1.5rem;">
        <span style="width:0.5rem;height:0.5rem;background:#f97316;border-radius:50%;"></span>
        <span style="color:#fb923c;font-size:0.8rem;font-weight:600;">5 production-ready templates</span>
      </div>
      <h1 style="font-size:clamp(2.25rem,5vw,3.75rem);font-weight:700;color:#fff;line-height:1.15;margin:0 0 1.25rem;">
        Trade Business Landing Pages
      </h1>
      <p style="color:#94a3b8;font-size:clamp(1rem,2vw,1.25rem);max-width:640px;margin:0 auto 1.5rem;line-height:1.7;">
        Five distinct aesthetics, five fictional companies. Edit <code style="background:rgba(255,255,255,0.08);padding:0.2em 0.5em;border-radius:4px;font-size:0.9em;color:#e2e8f0;">src/data/v&#123;N&#125;.ts</code> — every word on the page changes. Astro + Tailwind. Deployed in minutes.
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:0.75rem;justify-content:center;color:#64748b;font-size:0.875rem;">
        {["Astro 4", "Tailwind CSS 3", "100% Static", "Vercel-ready", "axe-core 0", "One config file"].map(tag => (
          <span style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.08);padding:0.375rem 0.875rem;border-radius:100px;">{tag}</span>
        ))}
      </div>
    </section>

    <!-- Templates grid -->
    <main id="templates">
      <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem 6rem;display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,380px),1fr));gap:2rem;">
        {variants.map((v) => (
          <article class="preview-card" style="border-radius:16px;overflow:hidden;background:#0c1d38;border:1px solid rgba(255,255,255,0.08);">

            <!-- Template preview mockup -->
            <div
              class={`preview-${v.previewStyle}`}
              style="height:260px;padding:1.5rem;display:flex;flex-direction:column;justify-content:flex-end;position:relative;"
              aria-hidden="true"
            >
              <!-- V1 preview content -->
              {v.previewStyle === 'classic' && (
                <div style="position:relative;z-index:1;">
                  <div style="font-size:0.65rem;color:rgba(249,115,22,0.8);font-weight:600;letter-spacing:0.15em;text-transform:uppercase;margin-bottom:0.5rem;">Available 24/7</div>
                  <div style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2.5rem;color:#fff;line-height:0.9;text-transform:uppercase;letter-spacing:0.02em;">24/7 EMERGENCY<br/><span style="color:#f97316;">PLUMBING</span></div>
                  <div style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.5rem;color:#fff;margin-top:0.5rem;">(619) 555-0182</div>
                  <div style="margin-top:0.75rem;background:#f97316;color:#fff;font-size:0.7rem;font-weight:700;padding:0.4rem 0.9rem;border-radius:6px;display:inline-block;">Request Service Now →</div>
                </div>
              )}
              <!-- V2 preview content -->
              {v.previewStyle === 'tech' && (
                <div style="position:relative;z-index:1;">
                  <svg style="position:absolute;top:0;right:0;width:180px;height:180px;opacity:0.25;" viewBox="0 0 180 180" fill="none">
                    <path d="M20 80 L60 80 L60 40 L100 40" stroke="#2dd4bf" stroke-width="1.5"/>
                    <path d="M100 40 L140 40 L140 80 L160 80" stroke="#2dd4bf" stroke-width="1.5"/>
                    <path d="M60 80 L60 140 L100 140" stroke="#2dd4bf" stroke-width="1"/>
                    <circle cx="60" cy="80" r="4" fill="#2dd4bf"/>
                    <circle cx="100" cy="40" r="4" fill="#2dd4bf"/>
                    <circle cx="140" cy="80" r="3" stroke="#2dd4bf" stroke-width="1" fill="none"/>
                    <circle cx="60" cy="140" r="3" stroke="#2dd4bf" stroke-width="1" fill="none"/>
                  </svg>
                  <div style="font-size:0.6rem;color:#2dd4bf;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;margin-bottom:0.5rem;">Phoenix's EV & Smart Home Specialists</div>
                  <div style="font-family:'Sora',sans-serif;font-weight:800;font-size:1.5rem;color:#fff;line-height:1.2;margin-bottom:0.4rem;">Power Your Home.<br/>Intelligently.</div>
                  <div style="font-family:'JetBrains Mono',monospace;font-weight:700;font-size:1.1rem;color:#2dd4bf;">&gt;_ (480) 555-0247</div>
                  <div style="margin-top:0.75rem;background:#2dd4bf;color:#080e1a;font-size:0.7rem;font-weight:700;padding:0.4rem 0.9rem;border-radius:6px;display:inline-block;">Schedule an Install →</div>
                </div>
              )}
              <!-- V3 preview content -->
              {v.previewStyle === 'warm' && (
                <div style="position:relative;z-index:1;">
                  <div style="display:inline-flex;align-items:center;background:#c4622d;color:#fff;font-size:0.6rem;font-weight:700;padding:0.3rem 0.7rem;border-radius:100px;margin-bottom:0.75rem;text-transform:uppercase;letter-spacing:0.1em;">Since 1981</div>
                  <div style="font-family:'Playfair Display',serif;font-weight:700;font-size:1.5rem;color:#2c2318;line-height:1.2;margin-bottom:0.4rem;">Columbus Trusts<br/>Three Generations</div>
                  <div style="font-family:'Playfair Display',serif;font-style:italic;font-size:0.85rem;color:#8b7355;margin-bottom:0.5rem;">"We treat your home like our own."</div>
                  <div style="font-size:1rem;font-weight:700;color:#2d5a27;">(614) 555-0931</div>
                  <div style="margin-top:0.75rem;background:#2d5a27;color:#fff;font-size:0.7rem;font-weight:700;padding:0.4rem 0.9rem;border-radius:6px;display:inline-block;">Call for Same-Day Service →</div>
                </div>
              )}
              <!-- V4 preview content -->
              {v.previewStyle === 'emergency' && (
                <div style="position:relative;z-index:1;">
                  <div style="display:flex;align-items:center;gap:0.4rem;margin-bottom:0.5rem;">
                    <span style="width:0.5rem;height:0.5rem;background:#ef4444;border-radius:50%;"></span>
                    <span style="font-size:0.6rem;color:#ef4444;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;">Live Dispatch · 24/7 · 365 Days</span>
                  </div>
                  <div style="font-family:'Anton',sans-serif;font-size:2rem;color:#fff;line-height:0.95;letter-spacing:0.02em;text-transform:uppercase;">PLUMBING<br/>EMERGENCY?</div>
                  <div style="font-family:'Anton',sans-serif;font-size:2.5rem;color:#ef4444;margin-top:0.25rem;">(404) 555-0911</div>
                  <div style="margin-top:0.75rem;background:#ef4444;color:#fff;font-size:0.75rem;font-weight:700;padding:0.5rem 1.25rem;border-radius:6px;display:inline-block;letter-spacing:0.05em;">CALL NOW →</div>
                </div>
              )}
              <!-- V5 preview content -->
              {v.previewStyle === 'luxury' && (
                <div style="position:relative;z-index:1;">
                  <div style="height:1px;background:linear-gradient(90deg,transparent,#c9a96e,transparent);margin-bottom:1rem;"></div>
                  <div style="font-size:0.6rem;color:#4a7c59;font-weight:600;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:0.5rem;">Scottsdale · Paradise Valley · Arcadia</div>
                  <div style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:0.9rem;color:#8b7355;margin-bottom:0.2rem;">Electrical craftsmanship for</div>
                  <div style="font-family:'Cormorant Garamond',serif;font-weight:700;font-size:2rem;color:#2c2c2c;line-height:1.1;margin-bottom:0.5rem;">Exceptional Homes.</div>
                  <div style="font-size:0.85rem;color:#4a7c59;font-weight:500;">(480) 555-0673</div>
                  <div style="margin-top:0.75rem;border:1.5px solid #4a7c59;color:#4a7c59;font-size:0.7rem;font-weight:600;padding:0.4rem 0.9rem;border-radius:6px;display:inline-block;letter-spacing:0.05em;">Schedule a Consultation →</div>
                </div>
              )}
            </div>

            <!-- Card info -->
            <div style="padding:1.5rem;">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:0.75rem;">
                <div>
                  <div style="font-size:0.7rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#64748b;margin-bottom:0.3rem;">{v.label}</div>
                  <h2 style="font-size:1rem;font-weight:700;color:#fff;margin:0 0 0.2rem;">{v.company}</h2>
                  <p style="font-size:0.8rem;color:#64748b;margin:0;">{v.industry}</p>
                </div>
                <!-- Palette swatches -->
                <div style="display:flex;gap:4px;flex-shrink:0;" aria-label={`Color palette: ${v.paletteLabels.join(', ')}`}>
                  {v.palette.map((color, i) => (
                    <div
                      style={`width:20px;height:20px;border-radius:50%;background:${color};border:2px solid rgba(255,255,255,0.12);`}
                      title={v.paletteLabels[i]}
                      aria-label={v.paletteLabels[i]}
                    />
                  ))}
                </div>
              </div>

              <p style="font-size:0.85rem;color:#94a3b8;line-height:1.6;margin:0 0 1rem;">{v.bestFor}</p>

              <div style="display:flex;align-items:center;justify-content:space-between;gap:0.75rem;flex-wrap:wrap;">
                <span style="font-size:0.75rem;color:#475569;background:rgba(255,255,255,0.04);padding:0.25rem 0.6rem;border-radius:4px;border:1px solid rgba(255,255,255,0.06);">{v.fonts}</span>
                <a
                  href={`/${v.slug}`}
                  style={`display:inline-flex;align-items:center;gap:0.375rem;background:${v.accent};color:${v.previewStyle === 'warm' || v.previewStyle === 'luxury' ? (v.previewStyle === 'luxury' ? '#fff' : '#fff') : '#fff'};font-size:0.8rem;font-weight:700;padding:0.5rem 1rem;border-radius:8px;transition:opacity 0.2s;`}
                  onmouseover="this.style.opacity='0.85'"
                  onmouseout="this.style.opacity='1'"
                  aria-label={`View ${v.label} template — ${v.company}`}
                >
                  View Template
                  <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
                  </svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </main>

    <!-- Footer -->
    <footer style="border-top:1px solid rgba(255,255,255,0.06);padding:2rem 1.5rem;text-align:center;">
      <p style="color:#475569;font-size:0.85rem;margin:0 0 0.5rem;">
        Built with Astro + Tailwind CSS · Each template = one config file to edit
      </p>
      <p style="color:#334155;font-size:0.8rem;margin:0;">
Future subdomain: trades.dcrader.dev
      </p>
    </footer>
  </body>
</html>
