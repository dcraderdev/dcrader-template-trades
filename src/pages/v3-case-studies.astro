---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/v3/Nav.astro';
import Footer from '../components/v3/Footer.astro';
import { business } from '../data/v3';

const palette = { cream: '#fef8f0', creamDeep: '#f5ead8', forest: '#2d5a27', forestDark: '#1e3d1a', terra: '#c4622d', ink: '#2c2318', muted: '#8b7355' };

const cases = [
  {
    badge: 'Case 01 · German Village · Built 1903',
    title: 'The Krause boiler that wouldn\'t quit.',
    summary:
      'A 1960s cast-iron Burnham boiler that two competitors had quoted for replacement at $14,800. Dale\'s father had serviced this exact unit in 1987 — and we still had the paper invoice in the filing cabinet.',
    challenge:
      'Mrs. Krause inherited the German Village brick from her parents and was on a fixed retirement income. The boiler was struggling on the coldest mornings, two zones weren\'t calling, and the radiator in the upstairs bedroom hadn\'t heated since 2019. The two other estimates said full replacement was the only option — gas valve, controls, and pump were all "obsolete."',
    work: [
      'Rebuilt the original Honeywell gas valve with new internals (the part is still made under license).',
      'Re-piped the failing zone control with modern Taco circulators while keeping the original cast-iron manifold.',
      'Bled and re-charged the upstairs radiator — the issue turned out to be a stuck air vent, not a dead zone.',
      'Annual service contract added at the senior rate so the unit gets a tune every September.',
    ],
    outcome:
      'Total invoice came to $1,840. Mrs. Krause has heat in every room for the first time in five winters, and the boiler is rated for another 10 years of service. She called to ask if she could leave us in her will.',
    quote: '"My dad would have liked Dale. They\'re the same kind of men."',
    quoteFrom: 'Mrs. Janet Krause, German Village',
  },
  {
    badge: 'Case 02 · Dublin · 1996 Tract Home',
    title: 'A heat-pump conversion that paid for itself in 38 months.',
    summary:
      'The Whitfields were quoted $11,200 for a like-for-like furnace + AC replacement. We walked them through the heat-pump math instead. Three winters in, the utility savings have already covered the cost difference.',
    challenge:
      'The 28-year-old Goodman split system was at end-of-life. The family wanted a one-shot replacement before the next polar vortex. Their gas bill in January 2023 was $487. They had a south-facing roof, no shade trees, and AEP\'s heat-pump rebate program was still active for the 2024 install year.',
    work: [
      'Sized a Mitsubishi M-Series hyper-heat pump (rated to -13°F) using a true Manual J load calculation, not a rule-of-thumb swap.',
      'Kept the existing 80% AFUE furnace as backup heat for the three coldest weeks of the year.',
      'Re-zoned the upstairs bonus room (the cold room every Dublin family has) with a dedicated wall-mount head.',
      'Filed the $2,750 AEP rebate paperwork on their behalf — check arrived in 11 weeks.',
    ],
    outcome:
      'Annual utility cost down 41%. The system paid back the $4,200 cost differential in 38 months. The bonus room is now the second-warmest room in the house — and for the first time in 28 years, their teenage daughter sleeps with the door closed.',
    quote: '"Dale didn\'t just sell us a heat pump. He explained the math, the rebate, the cold-weather backup — everything. I felt like I was the one making the decision."',
    quoteFrom: 'Michael Whitfield, Dublin',
  },
  {
    badge: 'Case 03 · Bexley · 1924 Tudor',
    title: 'Three generations of Healys. Three generations of us.',
    summary:
      'Earl serviced their original gravity-feed furnace in 1983. Dad replaced it with a high-efficiency model in 2004. Dale did the most recent zoning retrofit in 2024. Same family, same trucks, three different decades.',
    challenge:
      'The Healy family\'s 1924 Tudor had been heated by some version of our work for four decades. The 2004 system was still operational but the second floor ran 6–8 degrees hotter than the first in summer, and the upstairs nursery was a constant complaint. Patricia Healy refused to add window AC units to a historic home.',
    work: [
      'Designed a two-zone retrofit using existing ductwork plus a small high-velocity SpacePak addition for the nursery and master bedroom.',
      'Added a Honeywell zoning panel and two stat controls so each floor maintains its own setpoint.',
      'Re-balanced the original supply registers — three of them were still in the positions Earl set in 1983.',
      'Installed an Aprilaire 800 steam humidifier to handle the dry Tudor air during winter.',
    ],
    outcome:
      'Upstairs and downstairs now hold within 1°F of each other. The nursery is silent and 72°F year-round. Patricia\'s mother (who originally hired Earl) sent us a handwritten thank-you note in cursive — we framed it and it hangs in the dispatch office.',
    quote: '"My grandmother trusted Earl. My mother trusted his son. I trust Dale. Three women, three generations, one HVAC company. That\'s not marketing — that\'s a record."',
    quoteFrom: 'Patricia Healy, Bexley',
  },
];

const stats = [
  { v: '44', l: 'Years in Columbus' },
  { v: '11,200+', l: 'Systems serviced' },
  { v: '38%', l: 'Avg energy savings on retrofits' },
  { v: '3', l: 'Family generations on the trucks' },
];
---

<Layout
  title={`Recent Projects & Case Studies | ${business.name} — Columbus HVAC`}
  description={`Three Columbus families. Three real HVAC projects. From a 1903 German Village boiler save to a Dublin heat-pump conversion that paid back in 38 months. ${business.yearsInBusiness} years on the trucks.`}
  fontUrl="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Nunito+Sans:wght@300;400;500;600;700;800&display=swap"
  themeColor="#2d5a27"
  bodyStyle="background:#fef8f0;color:#2c2318;font-family:'Nunito Sans',system-ui,sans-serif;"
>
  <Nav />

  <main id="main-content">

    <!-- ───── HERO ───── -->
    <section
      class="relative py-20 lg:py-28"
      style={`background:${palette.cream};`}
      aria-labelledby="hero-h1"
    >
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <span
          class="inline-block px-4 py-1.5 mb-6 text-xs font-bold uppercase tracking-widest rounded-full"
          style={`background:${palette.terra}; color:#ffffff;`}
        >
          Recent Projects · Case Studies
        </span>
        <h1
          id="hero-h1"
          class="leading-tight mb-6"
          style={`font-family:'Playfair Display',serif; font-weight:700; color:${palette.ink}; font-size:clamp(2.5rem, 5.5vw, 4.5rem); letter-spacing:-0.01em;`}
        >
          Forty-four winters.<br/>
          <em style={`color:${palette.forest};`}>Eleven thousand homes.</em>
        </h1>
        <p class="text-lg lg:text-xl leading-relaxed max-w-3xl mb-8" style={`color:${palette.muted};`}>
          Every furnace, every boiler, every heat pump on these pages belongs to a real Columbus family who let us into their basement and trusted us with their winter.
          We don't list trade-show installs or stock-photo systems. These are the projects we'd take you to see if you asked — and most of these neighbors would let us in the door.
        </p>

        <!-- Owner story -->
        <div
          class="mt-12 p-8 lg:p-10 relative"
          style={`background:${palette.creamDeep}; border-left:6px solid ${palette.forest};`}
        >
          <p
            style={`font-family:'Playfair Display',serif; font-style:italic; font-size:1.4rem; line-height:1.5; color:${palette.ink};`}
            class="mb-4"
          >
            "{business.story}"
          </p>
          <p class="text-sm uppercase tracking-widest font-bold" style={`color:${palette.forest};`}>
            — {business.ownerName}
          </p>
        </div>

        <!-- Stats strip -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-12 pt-10 border-t" style={`border-color:${palette.creamDeep};`}>
          {stats.map((s) => (
            <div>
              <p style={`font-family:'Playfair Display',serif; font-weight:700; font-size:2.5rem; color:${palette.forest}; line-height:1;`}>{s.v}</p>
              <p class="text-xs uppercase tracking-widest font-bold mt-2" style={`color:${palette.muted};`}>{s.l}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ───── CASE STUDIES ───── -->
    {cases.map((c, idx) => (
      <section
        class="py-20 lg:py-24"
        style={`background:${idx % 2 === 0 ? palette.creamDeep : palette.cream};`}
        aria-labelledby={`case-h2-${idx}`}
      >
        <div class="max-w-5xl mx-auto px-4 sm:px-6">
          <p class="text-xs uppercase tracking-widest font-bold mb-4" style={`color:${palette.terra};`}>
            {c.badge}
          </p>
          <h2
            id={`case-h2-${idx}`}
            class="leading-tight mb-6"
            style={`font-family:'Playfair Display',serif; font-weight:700; color:${palette.ink}; font-size:clamp(2rem, 4vw, 3.25rem); letter-spacing:-0.01em;`}
          >
            {c.title}
          </h2>
          <p class="text-lg leading-relaxed mb-8 max-w-3xl" style={`color:${palette.muted};`}>
            {c.summary}
          </p>

          <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mt-12">
            <div>
              <p
                class="mb-3 pb-2 border-b"
                style={`font-family:'Playfair Display',serif; font-weight:600; color:${palette.forest}; font-size:1.25rem; border-color:${palette.terra};`}
              >
                The Challenge
              </p>
              <p class="text-base leading-relaxed" style={`color:${palette.ink};`}>{c.challenge}</p>
            </div>
            <div>
              <p
                class="mb-3 pb-2 border-b"
                style={`font-family:'Playfair Display',serif; font-weight:600; color:${palette.forest}; font-size:1.25rem; border-color:${palette.terra};`}
              >
                What We Did
              </p>
              <ul class="space-y-3" role="list">
                {c.work.map((w) => (
                  <li class="flex items-start gap-2 text-base leading-relaxed" style={`color:${palette.ink};`}>
                    <span style={`color:${palette.terra};`} aria-hidden="true">✦</span>
                    {w}
                  </li>
                ))}
              </ul>
            </div>
            <div>
              <p
                class="mb-3 pb-2 border-b"
                style={`font-family:'Playfair Display',serif; font-weight:600; color:${palette.forest}; font-size:1.25rem; border-color:${palette.terra};`}
              >
                The Outcome
              </p>
              <p class="text-base leading-relaxed" style={`color:${palette.ink};`}>{c.outcome}</p>
            </div>
          </div>

          <blockquote
            class="mt-12 p-8 relative"
            style={`background:${palette.forest}; color:${palette.cream}; border-radius:6px;`}
          >
            <p
              class="mb-4"
              style={`font-family:'Playfair Display',serif; font-style:italic; font-size:1.5rem; line-height:1.4;`}
            >
              {c.quote}
            </p>
            <footer class="text-xs uppercase tracking-widest font-bold" style="opacity:0.8;">
              — {c.quoteFrom}
            </footer>
          </blockquote>
        </div>
      </section>
    ))}

    <!-- ───── WHY WE PUBLISH THESE ───── -->
    <section
      class="py-20 lg:py-24"
      style={`background:${palette.forest}; color:${palette.cream};`}
      aria-labelledby="why-h2"
    >
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <p class="text-xs uppercase tracking-widest font-bold mb-4" style={`color:${palette.terra};`}>
          Why we tell these stories
        </p>
        <h2
          id="why-h2"
          class="leading-tight mb-8"
          style={`font-family:'Playfair Display',serif; font-weight:700; color:${palette.cream}; font-size:clamp(2rem, 4.5vw, 3.5rem); letter-spacing:-0.01em;`}
        >
          Because in our trade, the best advertising is a neighbor pointing across the street.
        </h2>
        <div class="space-y-5 text-base lg:text-lg leading-relaxed" style="color:rgba(254,248,240,0.85);">
          <p>
            HVAC companies love before-and-after photos. We do too. But the photo doesn't tell you whether the homeowner felt heard, or whether the technician was honest, or whether the price held up
            against the estimate. The story does.
          </p>
          <p>
            Every project on this page passed three filters before we published it. First, the customer gave us written permission to use their name and neighborhood — we don't anonymize the stories we're proud of.
            Second, we checked back twelve months later to confirm the work was still performing. Third, the customer agreed to take a phone call from a future Three Generations prospect who wanted a real-world reference.
          </p>
          <p>
            That last filter is the one most companies won't survive. When we send a quote, we offer to put you on the phone with the homeowner from a similar project — same year of home, same scope of work, same neighborhood when we can.
            Forty-four years of doing things this way is why our customers stay customers.
          </p>
        </div>
      </div>
    </section>

    <!-- ───── CTA ───── -->
    <section class="py-16" style={`background:${palette.cream};`} aria-labelledby="cta-h2">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center">
        <h2
          id="cta-h2"
          class="mb-4"
          style={`font-family:'Playfair Display',serif; font-weight:700; color:${palette.ink}; font-size:clamp(2rem, 4vw, 3rem);`}
        >
          Want your project on the next page?
        </h2>
        <p class="text-lg max-w-2xl mx-auto mb-8" style={`color:${palette.muted};`}>
          Tell us what's wrong, what's loud, or what's broken. We'll come out, listen, and write you an honest plan — same way Earl did in 1981.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href={business.phoneHref}
            class="inline-flex items-center gap-2 px-8 py-4 text-base font-bold uppercase tracking-widest transition-opacity hover:opacity-90"
            style={`background:${palette.forest}; color:${palette.cream}; border-radius:4px;`}
          >
            Call {business.phone}
          </a>
          <a
            href="/v3-family-warm#quote"
            class="inline-flex items-center gap-2 px-8 py-4 text-base font-bold uppercase tracking-widest transition-opacity hover:opacity-90"
            style={`background:${palette.terra}; color:#ffffff; border-radius:4px;`}
          >
            Request a Visit
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
