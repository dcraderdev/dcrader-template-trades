---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/v5/Nav.astro';
import Footer from '../components/v5/Footer.astro';
import { business } from '../data/v5';

const palette = { cream: '#faf8f5', creamDeep: '#f0ece4', sage: '#4a7c59', sageDeep: '#36573f', gold: '#c9a96e', ink: '#2c2c2c', muted: '#8b7355' };

const licenses = [
  {
    issuer: 'Arizona Registrar of Contractors',
    type: 'C-10 Electrical Contractor',
    number: 'ROC #234567',
    detail: 'Active and in good standing since 2011. Annual continuing-education requirements current through 2026. Verifiable at azroc.gov.',
  },
  {
    issuer: 'Arizona Registrar of Contractors',
    type: 'CR-11 Electrical (Commercial)',
    number: 'ROC #234568',
    detail: 'Commercial dual-license maintained for estates exceeding 25,000 sq ft and mixed-use projects with detached guest residences or studios.',
  },
  {
    issuer: 'City of Scottsdale Building Department',
    type: 'Master Electrician of Record',
    number: 'ME #1187',
    detail: 'Owner Daniel Cedar is the firm\'s master electrician of record. Personally pulls permits on every estate project over $250,000.',
  },
  {
    issuer: 'Town of Paradise Valley',
    type: 'Preferred Subcontractor (Hillside Overlay)',
    number: '2018–present',
    detail: 'Approved for hillside-overlay and Camelback view-corridor projects requiring additional planning department coordination.',
  },
];

const insurance = [
  {
    label: 'General Liability',
    carrier: 'The Hartford · Construction Specialty',
    limit: '$5,000,000 per occurrence',
    note: 'Standard residential coverage maxes out around $1M. We carry five — because estate-scale damage isn\'t a $1M problem.',
  },
  {
    label: 'Workers\' Compensation',
    carrier: 'SCF Arizona',
    limit: 'Statutory limits, all employees',
    note: 'Every Cedar Hill technician is a W-2 employee — never a 1099 contractor. You are never liable for a stranger on your property.',
  },
  {
    label: 'Performance & Payment Bond',
    carrier: 'Liberty Mutual Surety',
    limit: 'Up to $3,000,000 per project',
    note: 'Project-specific bonds available on request. Required by some HOAs and recommended for new-construction estates above $1.5M.',
  },
  {
    label: 'Inland Marine / Tools',
    carrier: 'Travelers',
    limit: '$250,000',
    note: 'Covers the tools, instruments, and stocked materials on our trucks. Your driveway is not at risk if a truck gets broken into overnight.',
  },
];

const trusted = [
  { name: 'Candelaria Design Associates', role: 'Architect · 38 estate collaborations' },
  { name: 'Mark Tate Architects', role: 'Architect · Camelback corridor specialist' },
  { name: 'Schultz Development', role: 'Custom Home Builder · 14 active projects since 2019' },
  { name: 'Calvis Wyant Luxury Homes', role: 'Custom Home Builder · Silverleaf, DC Ranch, Whisper Rock' },
  { name: 'Berghoff Design Group', role: 'Interior Designer · Lighting design partnership' },
  { name: 'Wiseman & Gale', role: 'Interior Designer · Old Town and Arcadia historic estates' },
  { name: 'Refined Group AV', role: 'AV Integrator · Savant & Crestron certified partner' },
  { name: 'TouchStone Living', role: 'AV Integrator · Control4 platinum partner' },
];

const credentials = [
  'NECA — National Electrical Contractors Association, Member 2014–present',
  'IBEW Local 640 — Signatory union shop, journeyman-level wage and benefit standard',
  'CEDIA — Custom Electronic Design & Installation Association, certified through 2026',
  'BICSI — Building Industry Consulting Service International, low-voltage certified',
  'Lutron Authorized — Diamond-tier integrator for HomeWorks QS and RA3 systems',
  'Crestron CSP — Certified Service Provider with two Crestron-certified programmers on staff',
  'Generac Generator — Premier elite installing dealer (top 2% nationwide)',
  'NFPA 70E — Annual arc-flash certification for every field technician',
];
---

<Layout
  title={`Licensing, Insurance & Credentials | ${business.name}`}
  description={`Cedar Hill Custom Electric — fully licensed C-10/CR-11 contractor with $5M liability, $3M bonding capacity, and 14 years collaborating with Scottsdale and Paradise Valley's most respected architects and builders.`}
  fontUrl="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Outfit:wght@300;400;500;600;700&display=swap"
  themeColor="#4a7c59"
  bodyStyle="background:#faf8f5;color:#2c2c2c;font-family:'Outfit',system-ui,sans-serif;"
>
  <Nav />

  <main id="main-content">

    <!-- ───── HERO ───── -->
    <section
      class="py-24 lg:py-32"
      style={`background:${palette.cream};`}
      aria-labelledby="hero-h1"
    >
      <div class="max-w-5xl mx-auto px-6">
        <div
          class="h-px w-24 mb-8"
          style={`background:linear-gradient(90deg, ${palette.gold}, transparent);`}
          aria-hidden="true"
        ></div>
        <p class="text-xs uppercase tracking-[0.3em] mb-6 font-medium" style={`color:${palette.sage};`}>
          Licensing · Insurance · Credentials
        </p>
        <h1
          id="hero-h1"
          class="leading-tight mb-8"
          style={`font-family:'Cormorant Garamond',serif; font-weight:600; color:${palette.ink}; font-size:clamp(2.75rem, 6vw, 5rem); letter-spacing:-0.01em;`}
        >
          <em style={`color:${palette.sage};`}>Discreet</em>, fully bonded,<br/>
          and trusted by Scottsdale's<br/>
          most demanding builders.
        </h1>
        <p class="text-lg lg:text-xl leading-relaxed max-w-3xl mb-12" style={`color:${palette.muted};`}>
          Custom estate electrical is a profession of consequence. The wire behind your finished walls and the contractor you let into your home for fourteen months
          deserve more than a perfunctory license check. This page is the full paper trail — licenses, bonds, insurance carriers, design partners, and industry certifications — so you can verify what we tell you in conversation.
        </p>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 pt-10 border-t" style={`border-color:${palette.creamDeep};`}>
          <div>
            <p style={`font-family:'Cormorant Garamond',serif; font-weight:700; color:${palette.sage}; font-size:2.5rem; line-height:1;`}>14</p>
            <p class="text-xs uppercase tracking-widest mt-2" style={`color:${palette.muted};`}>Years in practice</p>
          </div>
          <div>
            <p style={`font-family:'Cormorant Garamond',serif; font-weight:700; color:${palette.sage}; font-size:2.5rem; line-height:1;`}>$5M</p>
            <p class="text-xs uppercase tracking-widest mt-2" style={`color:${palette.muted};`}>Liability coverage</p>
          </div>
          <div>
            <p style={`font-family:'Cormorant Garamond',serif; font-weight:700; color:${palette.sage}; font-size:2.5rem; line-height:1;`}>$3M</p>
            <p class="text-xs uppercase tracking-widest mt-2" style={`color:${palette.muted};`}>Bonding capacity</p>
          </div>
          <div>
            <p style={`font-family:'Cormorant Garamond',serif; font-weight:700; color:${palette.sage}; font-size:2.5rem; line-height:1;`}>0</p>
            <p class="text-xs uppercase tracking-widest mt-2" style={`color:${palette.muted};`}>Subcontracted technicians</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ───── LICENSES ───── -->
    <section
      id="licenses"
      class="py-24"
      style={`background:${palette.creamDeep};`}
      aria-labelledby="licenses-h2"
    >
      <div class="max-w-5xl mx-auto px-6">
        <p class="text-xs uppercase tracking-[0.3em] mb-4 font-medium" style={`color:${palette.gold};`}>
          State and municipal authority
        </p>
        <h2
          id="licenses-h2"
          class="mb-4"
          style={`font-family:'Cormorant Garamond',serif; font-weight:600; color:${palette.ink}; font-size:clamp(2rem, 4.5vw, 3.5rem); letter-spacing:-0.01em;`}
        >
          The licenses on every truck.
        </h2>
        <p class="text-base lg:text-lg leading-relaxed mb-12 max-w-3xl" style={`color:${palette.muted};`}>
          Every Cedar Hill credential is verifiable through the issuing authority. We encourage every prospective client to confirm them — and we'll provide the lookup links directly to your project manager or attorney on request.
        </p>

        <div class="space-y-px" style={`background:${palette.creamDeep};`}>
          {licenses.map((l) => (
            <article
              class="p-8 grid grid-cols-1 lg:grid-cols-12 gap-4"
              style={`background:${palette.cream}; border-left:3px solid ${palette.sage};`}
            >
              <div class="lg:col-span-4">
                <p class="text-xs uppercase tracking-widest font-medium mb-2" style={`color:${palette.gold};`}>{l.issuer}</p>
                <p
                  style={`font-family:'Cormorant Garamond',serif; font-weight:600; font-size:1.5rem; color:${palette.ink}; line-height:1.2;`}
                >
                  {l.type}
                </p>
              </div>
              <div class="lg:col-span-2 lg:text-right">
                <p
                  class="font-mono text-base font-semibold"
                  style={`color:${palette.sage};`}
                >
                  {l.number}
                </p>
              </div>
              <div class="lg:col-span-6">
                <p class="text-base leading-relaxed" style={`color:${palette.ink};`}>{l.detail}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ───── INSURANCE & BONDING ───── -->
    <section
      id="insurance"
      class="py-24"
      style={`background:${palette.cream};`}
      aria-labelledby="insurance-h2"
    >
      <div class="max-w-5xl mx-auto px-6">
        <p class="text-xs uppercase tracking-[0.3em] mb-4 font-medium" style={`color:${palette.gold};`}>
          Financial protection
        </p>
        <h2
          id="insurance-h2"
          class="mb-4"
          style={`font-family:'Cormorant Garamond',serif; font-weight:600; color:${palette.ink}; font-size:clamp(2rem, 4.5vw, 3.5rem); letter-spacing:-0.01em;`}
        >
          Insurance & bonding capacity.
        </h2>
        <p class="text-base lg:text-lg leading-relaxed mb-12 max-w-3xl" style={`color:${palette.muted};`}>
          Coverage written specifically for high-value residential construction. Certificates of insurance are issued from our broker directly to your GC or HOA on the day of contract — your project manager will coordinate.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {insurance.map((i) => (
            <article
              class="p-8"
              style={`background:${palette.creamDeep}; border-top:3px solid ${palette.gold};`}
            >
              <p class="text-xs uppercase tracking-widest font-medium mb-2" style={`color:${palette.sage};`}>{i.label}</p>
              <p
                class="mb-3"
                style={`font-family:'Cormorant Garamond',serif; font-weight:600; font-size:1.5rem; color:${palette.ink};`}
              >
                {i.limit}
              </p>
              <p class="text-sm font-medium mb-4" style={`color:${palette.gold};`}>{i.carrier}</p>
              <p class="text-sm leading-relaxed" style={`color:${palette.ink};`}>{i.note}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ───── TRUSTED BY ───── -->
    <section
      id="partners"
      class="py-24"
      style={`background:${palette.sage}; color:${palette.cream};`}
      aria-labelledby="partners-h2"
    >
      <div class="max-w-5xl mx-auto px-6">
        <p class="text-xs uppercase tracking-[0.3em] mb-4 font-medium" style={`color:${palette.gold};`}>
          Design & build partners
        </p>
        <h2
          id="partners-h2"
          class="mb-6"
          style={`font-family:'Cormorant Garamond',serif; font-weight:600; color:${palette.cream}; font-size:clamp(2rem, 4.5vw, 3.5rem); letter-spacing:-0.01em;`}
        >
          The references we offer first.
        </h2>
        <p class="text-base lg:text-lg leading-relaxed mb-12 max-w-3xl" style="color:rgba(250,248,245,0.85);">
          Eight studios and firms we've worked alongside repeatedly — most of them annually for the better part of a decade. They'll take a phone call from a serious prospective client and tell you, plainly, what it's like to have us on a project.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {trusted.map((t) => (
            <article
              class="p-6 flex items-start gap-4"
              style={`background:${palette.sageDeep}; border-left:2px solid ${palette.gold};`}
            >
              <span
                class="block w-10 h-10 flex-shrink-0 rounded-full"
                style={`background:${palette.gold}; opacity:0.85;`}
                aria-hidden="true"
              ></span>
              <div>
                <p
                  style={`font-family:'Cormorant Garamond',serif; font-weight:600; font-size:1.25rem; color:${palette.cream};`}
                >
                  {t.name}
                </p>
                <p class="text-sm mt-1" style="color:rgba(250,248,245,0.7);">{t.role}</p>
              </div>
            </article>
          ))}
        </div>

        <p class="text-sm leading-relaxed mt-10 max-w-2xl" style="color:rgba(250,248,245,0.65);">
          References furnished by request. We respect our partners' time — we vet inquiries before introduction and we never use a firm name in marketing without standing permission.
        </p>
      </div>
    </section>

    <!-- ───── INDUSTRY CREDENTIALS ───── -->
    <section
      id="industry"
      class="py-24"
      style={`background:${palette.cream};`}
      aria-labelledby="industry-h2"
    >
      <div class="max-w-5xl mx-auto px-6">
        <p class="text-xs uppercase tracking-[0.3em] mb-4 font-medium" style={`color:${palette.gold};`}>
          Industry credentials
        </p>
        <h2
          id="industry-h2"
          class="mb-6"
          style={`font-family:'Cormorant Garamond',serif; font-weight:600; color:${palette.ink}; font-size:clamp(2rem, 4.5vw, 3.5rem); letter-spacing:-0.01em;`}
        >
          The associations behind the work.
        </h2>
        <p class="text-base lg:text-lg leading-relaxed mb-10 max-w-3xl" style={`color:${palette.muted};`}>
          Beyond the licenses required to legally do the work, we maintain memberships and certifications that govern the standards we hold ourselves to. The list below is current as of {new Date().getFullYear()}.
        </p>

        <ul class="space-y-3 list-none p-0" role="list">
          {credentials.map((c) => (
            <li
              class="flex items-start gap-4 p-5"
              style={`background:${palette.creamDeep}; border-left:2px solid ${palette.gold};`}
            >
              <span
                class="flex-shrink-0 mt-0.5"
                style={`color:${palette.sage}; font-family:'Cormorant Garamond',serif; font-weight:700; font-size:1.25rem;`}
                aria-hidden="true"
              >
                ✦
              </span>
              <span class="text-base leading-relaxed" style={`color:${palette.ink};`}>{c}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ───── CTA ───── -->
    <section class="py-24" style={`background:${palette.creamDeep};`} aria-labelledby="cta-h2">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <div
          class="h-px w-24 mx-auto mb-8"
          style={`background:linear-gradient(90deg, transparent, ${palette.gold}, transparent);`}
          aria-hidden="true"
        ></div>
        <h2
          id="cta-h2"
          class="mb-6"
          style={`font-family:'Cormorant Garamond',serif; font-weight:600; color:${palette.ink}; font-size:clamp(2rem, 4.5vw, 3.25rem); letter-spacing:-0.01em;`}
        >
          <em style={`color:${palette.sage};`}>Verify everything</em>, then call.
        </h2>
        <p class="text-base lg:text-lg leading-relaxed max-w-2xl mx-auto mb-10" style={`color:${palette.muted};`}>
          We expect — and welcome — the diligence. Once you've confirmed what you've read, we'd be honored to discuss your project in person.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="/v5-luxury-trade#quote"
            class="inline-flex items-center gap-2 px-8 py-4 text-sm uppercase tracking-widest font-medium transition-opacity hover:opacity-90"
            style={`background:${palette.sage}; color:${palette.cream}; border-radius:4px;`}
          >
            Request a Consultation
          </a>
          <a
            href={business.phoneHref}
            class="inline-flex items-center gap-2 px-8 py-4 text-sm uppercase tracking-widest font-medium transition-opacity hover:opacity-90"
            style={`background:transparent; color:${palette.sage}; border:1.5px solid ${palette.sage}; border-radius:4px;`}
          >
            Call {business.phone}
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
